# Add-ons - keep structure, ignore data and build artifacts
addons/*/node_modules/
addons/*/*.sqlite
addons/*/*.db
addons/*/db.sqlite
!addons/.gitkeep
!addons/README.md
# In-place TypeScript build output (addon tsconfig outDir: ../..)
# These are generated by `cd addons/<name> && npx tsc` and are needed at runtime
# but must not be committed — regenerated on each build.
addons/*/**/*.js
!addons/*/public/**/*.js
addons/*/**/*.js.map
!addons/*/public/**/*.js.map
addons/*/**/*.d.ts
addons/*/**/*.d.ts.map
addons/*/.tsbuildinfo
addons/*/index.js
addons/*/index.js.map
addons/*/index.d.ts
addons/*/index.d.ts.map
# src/ .js files emitted as a side-effect of addon tsconfig (rootDir: ../..)
# These are NOT the main build output (which goes to dist/src/) but are
# required at runtime by the addon's compiled requires.
# Note: src/types/express.d.ts is tracked (hand-written) — .d.ts excluded narrowly below.
src/context/*.js
src/context/*.js.map
src/context/*.d.ts
src/context/*.d.ts.map
src/managers/*.js
src/managers/*.js.map
src/managers/*.d.ts
src/managers/*.d.ts.map
src/mail/*.js
src/mail/*.js.map
src/mail/*.d.ts
src/mail/*.d.ts.map
src/types/Asset.js
src/types/Asset.js.map
src/types/Asset.d.ts
src/types/Asset.d.ts.map
src/types/Config.js
src/types/Config.js.map
src/types/Config.d.ts
src/types/Config.d.ts.map
src/types/WikiEngine.js
src/types/WikiEngine.js.map
src/types/WikiEngine.d.ts
src/types/WikiEngine.d.ts.map
src/utils/*.js
src/utils/*.js.map
src/utils/*.d.ts
src/utils/*.d.ts.map
.DS_Store
xxx*/
zzz*/
ngdpbase.code-workspace
amdWiki.code-workspace

# Search index (generated at runtime)
search-index/

# Test results (generated)
test-results/
