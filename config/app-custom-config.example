{
  "_comment": "Local custom configuration overrides",
  "_description": "Copy this to app-custom-config.json and customize for your local environment",
  "_note": "app-custom-config.json is .gitignored and won't be committed",

  "_example_overrides": {
    "_comment_branding": "Customize application branding",
    "ngdpbase.application-name": "My Wiki",
    "ngdpbase.faviconPath": "/favicon.svg",

    "_comment_server": "Server configuration",
    "ngdpbase.server.port": 3000,
    "ngdpbase.server.host": "localhost",
    "ngdpbase.baseURL": "http://localhost:3000",

    "_comment_debugging": "Enable debug logging",
    "ngdpbase.logging.debug.session": true,
    "ngdpbase.logging.debug.login": true,

    "_comment_directories": "Custom directory locations",
    "ngdpbase.directories.pages": "./pages",
    "ngdpbase.directories.required-pages": "./required-pages",
    "ngdpbase.directories.attachments": "./attachments",

    "_comment_organization": "Install anchor Organization (#617). Set these when running headless (Docker/K8s) so the org file is seeded on first boot. The startup invariant requires the named file to exist on every boot after install completes.",
    "ngdpbase.application.organization.file": "acme-corporation.json",
    "ngdpbase.application.organization.url": "https://example.com/",
    "ngdpbase.application.organization.name": "Acme Corporation",
    "ngdpbase.application.organization.legal-name": "Acme Corporation, Inc.",
    "ngdpbase.application.organization.description": "Widget manufacturer",
    "ngdpbase.application.organization.contact-email": "support@example.com"
  }
}
