<%
  // Expects: entry (JournalIndexEntry), canEdit (optional bool)
  function fmtDate(iso) {
    try {
      return new Date(iso + 'T12:00:00').toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
    } catch(e) { return iso; }
  }
%>
<div class="journal-card">
  <div class="journal-card-date"><%= fmtDate(entry.journalDate) %></div>
  <div class="journal-card-title">
    <a href="/journal/<%= encodeURIComponent(entry.slug) %>"><%= entry.title %></a>
  </div>
  <% if (entry.mood) { %>
    <span class="journal-mood"><%= entry.mood %></span>
  <% } %>
  <% if (entry.tags && entry.tags.length > 0) { %>
    <div class="journal-tags">
      <% entry.tags.forEach(function(t) { %>
        <a href="/journal/tag/<%= encodeURIComponent(t) %>" class="journal-tag">#<%= t %></a>
      <% }); %>
    </div>
  <% } %>
  <% if (typeof canEdit !== 'undefined' && canEdit) { %>
    <div class="journal-card-actions mt-2">
      <a href="/journal/<%= encodeURIComponent(entry.slug) %>/edit" class="btn btn-xs btn-outline-secondary btn-sm">
        <i class="fas fa-pencil-alt"></i> Edit
      </a>
    </div>
  <% } %>
</div>
