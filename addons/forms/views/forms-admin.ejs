<%- include('header', { title: 'Forms Admin', currentUser }) %>

<div class="container-fluid mt-4">
  <div class="row">
    <div class="col-12 d-flex align-items-center justify-content-between mb-2">
      <h2 class="mb-0"><i class="fas fa-wpforms me-2"></i>Forms</h2>
      <a href="/addons/forms/builder/new" class="btn btn-success btn-sm">
        <i class="fas fa-plus me-1"></i>New Form
      </a>
    </div>
    <div class="col-12">
      <p class="text-muted">Manage form definitions and view submissions.</p>
    </div>
  </div>

  <% var flash = typeof query !== 'undefined' && query ? query.flash : undefined; %>
  <% if (flash === 'saved') { %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <i class="fas fa-check-circle me-1"></i>Form definition saved.
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } else if (flash === 'deleted') { %>
    <div class="alert alert-info alert-dismissible fade show" role="alert">
      <i class="fas fa-trash me-1"></i>Form definition deleted.
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>

  <% if (forms.length === 0) { %>
    <div class="alert alert-info">
      No form definitions found. Click <strong>New Form</strong> to create one.
    </div>
  <% } else { %>
    <div class="row">
      <% forms.forEach(function(form) { %>
        <div class="col-md-4 mb-4">
          <div class="card shadow-sm h-100">
            <div class="card-body">
              <h5 class="card-title"><%= form.title %></h5>
              <p class="text-muted small mb-1"><code><%= form.id %></code></p>
              <% if (form.description) { %>
                <p class="card-text small"><%= form.description %></p>
              <% } %>
              <div class="d-flex gap-2 flex-wrap mt-2">
                <span class="badge bg-secondary"><%= form.fields.length %> fields</span>
                <span class="badge bg-<%= form.submissionCount > 0 ? 'primary' : 'light text-dark' %>">
                  <%= form.submissionCount %> submission<%= form.submissionCount !== 1 ? 's' : '' %>
                </span>
                <% if (form.handler) { %>
                  <span class="badge bg-info text-dark">handler: <%= form.handler %></span>
                <% } %>
                <% if (form.proxySubmission) { %>
                  <span class="badge bg-warning text-dark">proxy</span>
                <% } %>
              </div>
            </div>
            <div class="card-footer bg-transparent d-flex gap-2 flex-wrap">
              <a href="/addons/forms/<%= encodeURIComponent(form.id) %>/submissions" class="btn btn-sm btn-outline-primary">
                View Submissions
              </a>
              <a href="/addons/forms/builder/<%= encodeURIComponent(form.id) %>" class="btn btn-sm btn-outline-secondary">
                <i class="fas fa-edit me-1"></i>Edit
              </a>
              <form method="POST" action="/addons/forms/builder/<%= encodeURIComponent(form.id) %>/delete" style="display:inline"
                onsubmit="return confirm('Delete form &quot;<%= form.id %>&quot;?\n\nDeletion is blocked if submissions exist.')">
                <button type="submit" class="btn btn-sm btn-outline-danger">
                  <i class="fas fa-trash me-1"></i>Delete
                </button>
              </form>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<%- include('footer') %>
