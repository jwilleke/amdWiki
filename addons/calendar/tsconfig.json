{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "../..",
    "outDir": "./dist",
    "tsBuildInfoFile": "./.tsbuildinfo",
    "skipLibCheck": true
  },
  "include": [
    "index.ts",
    "managers/**/*.ts",
    "routes/**/*.ts",
    "plugins/**/*.ts",
    "../../src/types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/__tests__/**"
  ]
}
