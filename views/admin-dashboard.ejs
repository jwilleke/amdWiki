<%- include('header', { pageName: '' }) %>

<div class="container mt-4">
    <% if (typeof successMessage !== 'undefined' && successMessage) { %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> <%= successMessage %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>

    <% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle"></i> <%= errorMessage %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>

    <div class="row">
        <div class="col-12 d-flex justify-content-between align-items-start flex-wrap gap-2">
            <div>
                <h1><i class="fas fa-cogs"></i> Admin Dashboard</h1>
                <p class="lead">Welcome to the administration panel, <%= currentUser.displayName %>!</p>
            </div>
            <div class="text-end">
                <span class="badge bg-secondary fs-6" id="version-badge">v<%= stats.version %></span>
                <div id="update-check-result" class="mt-1 small"></div>
            </div>
        </div>
    </div>

    <!-- Row 1: Three management panels -->
    <div class="row mt-4">

        <!-- User Management -->
        <div class="col-lg-4 mb-4">
            <div class="card h-100">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-users-cog"></i> User Management
                        <a href="/view/user-roles-and-permissions" class="ms-1 text-muted" title="Documentation" target="_blank"><i class="fas fa-question-circle fa-sm"></i></a>
                    </h5>
                </div>
                <div class="card-body">
                    <div class="d-flex flex-wrap gap-2">
                        <span class="d-inline-flex align-items-center gap-1">
                            <a href="/admin/users" class="btn btn-info btn-sm">
                                <i class="fas fa-users"></i> Manage Users
                            </a>
                            <a href="/view/manage-users" class="text-muted small" title="Documentation" target="_blank"><i class="fas fa-question-circle"></i></a>
                        </span>
                        <span class="d-inline-flex align-items-center gap-1">
                            <a href="/admin/roles" class="btn btn-secondary btn-sm">
                                <i class="fas fa-shield-alt"></i> Roles
                            </a>
                            <a href="/view/roles" class="text-muted small" title="Documentation" target="_blank"><i class="fas fa-question-circle"></i></a>
                        </span>
                        <span class="d-inline-flex align-items-center gap-1">
                            <a href="/admin/organizations" class="btn btn-secondary btn-sm">
                                <i class="fas fa-building"></i> Organizations
                            </a>
                            <a href="/view/organizations" class="text-muted small" title="Documentation" target="_blank"><i class="fas fa-question-circle"></i></a>
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Administrative Tools -->
        <div class="col-lg-4 mb-4">
            <div class="card h-100">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-tools"></i> Administrative Tools
                        <a href="/view/administrative-tools" class="ms-1 text-muted" title="Documentation" target="_blank"><i class="fas fa-question-circle fa-sm"></i></a>
                    </h5>
                </div>
                <div class="card-body">
                    <% if (currentUser.roles.includes('admin')) { %>
                    <div class="d-flex flex-wrap gap-2">
                        <span class="d-inline-flex align-items-center gap-1">
                            <button class="btn btn-outline-danger btn-sm" onclick="confirmRestart()">
                                <i class="fas fa-sync-alt"></i> Restart
                            </button>
                            <a href="/view/server-management" class="text-muted small" title="Documentation" target="_blank"><i class="fas fa-question-circle"></i></a>
                        </span>

                        <span class="d-inline-flex align-items-center gap-1">
                            <a href="/admin/backup" class="btn btn-outline-info btn-sm">
                                <i class="fas fa-database"></i> Backup
                            </a>
                            <a href="/view/backup" class="text-muted small" title="Documentation" target="_blank"><i class="fas fa-question-circle"></i></a>
                        </span>

                        <span class="d-inline-flex align-items-center gap-1">
                            <a href="/admin/logs" class="btn btn-outline-secondary btn-sm">
                                <i class="fas fa-file-alt"></i> Logs
                            </a>
                            <a href="/view/logs" class="text-muted small" title="Documentation" target="_blank"><i class="fas fa-question-circle"></i></a>
                        </span>

                        <span class="d-inline-flex align-items-center gap-1">
                            <button class="btn btn-outline-success btn-sm" onclick="clearCache()">
                                <i class="fas fa-broom"></i> Clear Cache
                            </button>
                            <a href="/view/clear-cache" class="text-muted small" title="Documentation" target="_blank"><i class="fas fa-question-circle"></i></a>
                        </span>

                        <span class="d-inline-flex align-items-center gap-1">
                            <a href="/export" class="btn btn-success btn-sm">
                                <i class="fas fa-download"></i> Export Data
                            </a>
                            <a href="/view/export-data" class="text-muted small" title="Documentation" target="_blank"><i class="fas fa-question-circle"></i></a>
                        </span>

                        <span class="d-inline-flex align-items-center gap-1">
                            <form method="POST" action="/admin/maintenance/toggle" class="d-inline">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <% if (maintenanceMode) { %>
                                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Disable maintenance mode? Users will be able to access the system again.')">
                                        <i class="fas fa-play"></i> Disable Maintenance
                                    </button>
                                <% } else { %>
                                    <button type="submit" class="btn btn-warning btn-sm" onclick="return confirm('Enable maintenance mode? This will restrict access for regular users.')">
                                        <i class="fas fa-pause"></i> Enable Maintenance
                                    </button>
                                <% } %>
                            </form>
                            <a href="/view/maintenance-mode" class="text-muted small" title="Documentation" target="_blank"><i class="fas fa-question-circle"></i></a>
                        </span>
                    </div>
                    <% if (maintenanceMode) { %>
                        <div class="mt-2">
                            <small class="text-danger">
                                <i class="fas fa-exclamation-triangle"></i> Maintenance mode is currently <strong>ACTIVE</strong>
                            </small>
                        </div>
                    <% } %>
                    <% } else { %>
                        <p class="text-muted">Admin role required for these tools.</p>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- System Settings -->
        <div class="col-lg-4 mb-4">
            <div class="card h-100">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-cog"></i> System Settings
                        <a href="/view/configuration-system" class="ms-1 text-muted" title="Documentation" target="_blank"><i class="fas fa-question-circle fa-sm"></i></a>
                    </h5>
                </div>
                <div class="card-body">
                    <div class="d-flex flex-wrap gap-2">
                        <span class="d-inline-flex align-items-center gap-1">
                            <a href="/admin/keywords" class="btn btn-secondary btn-sm">
                                <i class="fas fa-tags"></i> Keywords
                            </a>
                            <a href="/view/keywords-and-categories" class="text-muted small" title="Documentation" target="_blank"><i class="fas fa-question-circle"></i></a>
                        </span>
                        <span class="d-inline-flex align-items-center gap-1">
                            <a href="/admin/configuration" class="btn btn-secondary btn-sm">
                                <i class="fas fa-sliders-h"></i> Configuration
                            </a>
                            <a href="/view/configuration-system" class="text-muted small" title="Documentation" target="_blank"><i class="fas fa-question-circle"></i></a>
                        </span>
                        <span class="d-inline-flex align-items-center gap-1">
                            <a href="/admin/variables" class="btn btn-secondary btn-sm">
                                <i class="fas fa-code"></i> Variables
                            </a>
                            <a href="/view/system-variables" class="text-muted small" title="Documentation" target="_blank"><i class="fas fa-question-circle"></i></a>
                        </span>
                        <span class="d-inline-flex align-items-center gap-1">
                            <a href="/admin/attachments" class="btn btn-secondary btn-sm">
                                <i class="fas fa-paperclip"></i> Attachments
                            </a>
                            <a href="/view/attachments" class="text-muted small" title="Documentation" target="_blank"><i class="fas fa-question-circle"></i></a>
                        </span>
                        <span class="d-inline-flex align-items-center gap-1">
                            <a href="/admin/interwiki" class="btn btn-secondary btn-sm">
                                <i class="fas fa-external-link-alt"></i> InterWiki
                            </a>
                            <a href="/view/interwiki" class="text-muted small" title="Documentation" target="_blank"><i class="fas fa-question-circle"></i></a>
                        </span>
                        <span class="d-inline-flex align-items-center gap-1">
                            <a href="/admin/settings" class="btn btn-secondary btn-sm">
                                <i class="fas fa-cogs"></i> Settings
                            </a>
                            <a href="/view/system-settings" class="text-muted small" title="Documentation" target="_blank"><i class="fas fa-question-circle"></i></a>
                        </span>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- Row 2: Page Management & Media Management -->
    <div class="row">

        <!-- Page Management -->
        <div class="col-lg-6 mb-4">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="fas fa-file-alt"></i> Page Management
                        <a href="/view/page-management" class="ms-1 text-muted" title="Documentation" target="_blank"><i class="fas fa-question-circle fa-sm"></i></a>
                    </h5>
                    <% if (typeof requiredPagesSyncNeeded !== 'undefined' && requiredPagesSyncNeeded > 0) { %>
                        <span class="badge bg-warning text-dark">
                            <i class="fas fa-exclamation-triangle me-1"></i><%= requiredPagesSyncNeeded %> need attention
                        </span>
                    <% } %>
                </div>
                <div class="card-body">
                    <% if (currentUser.roles.includes('admin')) { %>
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <span class="d-inline-flex align-items-center gap-1">
                            <button class="btn btn-outline-primary btn-sm" onclick="reindexPages()">
                                <i class="fas fa-sync"></i> Reindex Pages
                            </button>
                            <a href="/view/reindex-pages" class="text-muted small" title="Documentation" target="_blank"><i class="fas fa-question-circle"></i></a>
                        </span>

                        <span class="d-inline-flex align-items-center gap-1">
                            <a href="/admin/import" class="btn btn-info btn-sm">
                                <i class="fas fa-file-import"></i> Import Pages
                            </a>
                            <a href="/view/import-pages" class="text-muted small" title="Documentation" target="_blank"><i class="fas fa-question-circle"></i></a>
                        </span>

                        <span class="d-inline-flex align-items-center gap-1">
                            <a href="/admin/required-pages" class="btn btn-outline-primary btn-sm">
                                <i class="fas fa-lock me-1"></i> Required Pages
                                <% if (typeof requiredPagesSyncNeeded !== 'undefined' && requiredPagesSyncNeeded > 0) { %>
                                    <span class="badge bg-warning text-dark ms-1"><%= requiredPagesSyncNeeded %></span>
                                <% } %>
                            </a>
                            <a href="/view/required-pages" class="text-muted small" title="Documentation" target="_blank"><i class="fas fa-question-circle"></i></a>
                        </span>
                    </div>
                    <% if (requiredPages && requiredPages.length > 0) { %>
                        <details>
                            <summary class="text-muted" style="cursor: pointer;">
                                <small><i class="fas fa-list me-1"></i>View <%= requiredPages.length %> installed required pages</small>
                            </summary>
                            <div class="d-flex flex-wrap gap-2 mt-2">
                            <% requiredPages.forEach(page => { %>
                                <a href="/edit/<%= encodeURIComponent(page.name) %>" class="btn btn-outline-secondary btn-sm">
                                    <i class="fas fa-edit"></i> <%= page.name %>
                                    <% if (page.userModified) { %>
                                        <span class="badge bg-warning text-dark ms-1" title="Modified by admin">modified</span>
                                    <% } %>
                                </a>
                            <% }); %>
                            </div>
                        </details>
                    <% } %>
                    <% } else { %>
                        <p class="text-muted">Admin role required for these tools.</p>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Media Management — only shown when MediaManager is enabled -->
        <% if (capabilities && capabilities.media) { %>
        <div class="col-lg-6 mb-4">
            <div class="card h-100">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-photo-video"></i> Media Management
                        <a href="/view/media-management" class="ms-1 text-muted" title="Documentation" target="_blank"><i class="fas fa-question-circle fa-sm"></i></a>
                    </h5>
                </div>
                <div class="card-body">
                    <% if (currentUser.roles.includes('admin')) { %>
                    <div class="d-flex flex-wrap gap-2">
                        <span class="d-inline-flex align-items-center gap-1">
                            <button id="dashboard-rescan-btn" class="btn btn-outline-secondary btn-sm" onclick="dashboardMediaRescan()">
                                <i class="fas fa-sync"></i> Reindex Media
                            </button>
                            <a href="/view/media" class="text-muted small" title="Documentation" target="_blank"><i class="fas fa-question-circle"></i></a>
                        </span>

                        <span class="d-inline-flex align-items-center gap-1">
                            <button id="dashboard-rebuild-btn" class="btn btn-warning btn-sm" onclick="dashboardMediaRebuild()">
                                <i class="fas fa-database"></i> Rebuild Media
                            </button>
                            <a href="/view/media" class="text-muted small" title="Documentation" target="_blank"><i class="fas fa-question-circle"></i></a>
                        </span>

                        <span class="d-inline-flex align-items-center gap-1">
                            <a href="/admin/media" class="btn btn-secondary btn-sm">
                                <i class="fas fa-photo-video"></i> Media Manager
                            </a>
                        </span>
                    </div>
                    <div id="dashboard-media-status" class="mt-2" style="display:none;"></div>
                    <% } else { %>
                        <p class="text-muted">Admin role required for these tools.</p>
                    <% } %>
                </div>
            </div>
        </div>
        <% } %>

    </div>

    <!-- Row 3: Recent Activity -->
    <div class="row">
        <div class="col-12">
            <div class="card mb-4">
                <div class="card-header">
                    <h5><i class="fas fa-history"></i> Recent Activity</h5>
                </div>
                <div class="card-body">
                    <% if (recentActivity && recentActivity.length > 0) { %>
                        <% recentActivity.slice(0, 5).forEach(activity => { %>
                            <div class="mb-2">
                                <small class="text-muted"><%= activity.timestamp %></small><br>
                                <%= activity.description %>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <p class="text-muted">No recent activity to display.</p>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Row 4: System Notifications (bottom) -->
    <div class="row">
        <div class="col-12">
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5><i class="fas fa-bell"></i> System Notifications</h5>
                    <span class="badge bg-primary"><%= notifications ? notifications.length : 0 %></span>
                </div>
                <div class="card-body">
                    <% if (notifications && notifications.length > 0) { %>
                        <% notifications.slice(0, 5).forEach(notification => { %>
                            <div class="alert alert-<%= notification.level === 'warning' ? 'warning' : notification.level === 'error' ? 'danger' : notification.level === 'success' ? 'success' : 'info' %> border-0 mb-3">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div class="flex-grow-1">
                                        <h6 class="alert-heading mb-1"><%= notification.title %></h6>
                                        <p class="mb-1"><%= notification.message %></p>
                                        <small class="text-muted">
                                            <i class="fas fa-clock"></i> <%= new Date(notification.createdAt).toLocaleString() %>
                                            <% if (notification.type) { %>
                                                <span class="badge bg-secondary ms-2"><%= notification.type %></span>
                                            <% } %>
                                        </small>
                                    </div>
                                    <div class="ms-3">
                                        <form method="POST" action="/admin/notifications/<%= notification.id %>/dismiss" class="d-inline">
                                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                            <button type="submit" class="btn btn-sm btn-outline-secondary" title="Dismiss notification">
                                                <i class="fas fa-times"></i>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        <% }); %>

                        <% if (totalNotificationCount > 5) { %>
                            <div class="text-center">
                                <a href="/admin/notifications" class="btn btn-outline-primary btn-sm">
                                    <i class="fas fa-list"></i> View All Notifications (<%= totalNotificationCount %>)
                                </a>
                            </div>
                        <% } %>
                    <% } else { %>
                        <div class="text-center py-4">
                            <i class="fas fa-bell-slash fa-3x text-muted mb-3"></i>
                            <p class="text-muted">No system notifications at this time.</p>
                            <small class="text-muted">Notifications will appear here when system events occur.</small>
                        </div>
                    <% } %>
                </div>
                <div class="card-footer">
                    <div class="row">
                        <div class="col-md-6">
                            <form method="POST" action="/admin/notifications/clear-all" class="d-inline">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('Clear all notifications? This action cannot be undone.')">
                                    <i class="fas fa-trash"></i> Clear All
                                </button>
                            </form>
                        </div>
                        <div class="col-md-6 text-end">
                            <a href="/admin/notifications" class="btn btn-outline-primary btn-sm">
                                <i class="fas fa-cog"></i> Manage Notifications
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
async function confirmRestart() {
    if (!confirm('Are you sure you want to restart the system? This will temporarily interrupt service.')) {
        return;
    }

    try {
        const response = await fetch('/admin/restart', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        });

        const result = await response.json();

        if (result.success) {
            alert('System is restarting. The page will reload in a few seconds...');
            setTimeout(() => window.location.reload(), 5000);
        } else {
            alert('Error restarting system: ' + (result.error || 'Unknown error'));
        }
    } catch (error) {
        alert('Error restarting system: ' + error.message);
    }
}

async function clearCache() {
    if (!confirm('Are you sure you want to clear all cache data? This action cannot be undone.')) {
        return;
    }

    const button = document.querySelector('button[onclick="clearCache()"]');
    const originalHTML = button.innerHTML;

    try {
        button.disabled = true;
        button.textContent = 'Clearing...';

        const response = await fetch('/api/admin/cache/clear', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        });

        const result = await response.json();

        if (response.ok && result.success) {
            button.classList.remove('btn-outline-success');
            button.classList.add('btn-success');
            button.textContent = '✓ Cache Cleared';
            showMessage('All caches cleared successfully', 'success');
            setTimeout(() => {
                button.disabled = false;
                button.classList.remove('btn-success');
                button.classList.add('btn-outline-success');
                button.innerHTML = originalHTML;
            }, 3000);
        } else {
            throw new Error(result.error || 'Failed to clear cache');
        }
    } catch (error) {
        button.disabled = false;
        button.innerHTML = originalHTML;
        showMessage('Failed to clear cache: ' + error.message, 'error');
    }
}

async function reindexPages() {
    if (!confirm('Are you sure you want to reindex all pages? This will refresh the page cache and rebuild the search index.')) {
        return;
    }

    const button = document.querySelector('button[onclick="reindexPages()"]');
    const originalHTML = button.innerHTML;

    try {
        button.disabled = true;
        button.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Starting…';

        const csrfToken = document.querySelector('input[name="_csrf"]')?.value || '<%= csrfToken %>';

        const enqueueRes = await fetch('/api/admin/jobs/pages.reindex/enqueue', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'CSRF-Token': csrfToken }
        });
        const { runId } = await enqueueRes.json();
        if (!runId) throw new Error('Failed to start reindex job');

        button.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Reindexing…';

        // Poll until complete
        const run = await pollJobStatus(runId);
        if (run.status === 'completed') {
            button.classList.remove('btn-outline-primary');
            button.classList.add('btn-primary');
            button.innerHTML = '<i class="fas fa-check"></i> Reindexed';
            showMessage(`Reindex complete — ${run.result?.summary || ''}`, 'success');
            setTimeout(() => {
                button.disabled = false;
                button.classList.remove('btn-primary');
                button.classList.add('btn-outline-primary');
                button.innerHTML = originalHTML;
            }, 3000);
        } else {
            throw new Error(run.result?.error || 'Reindex failed');
        }
    } catch (error) {
        button.disabled = false;
        button.innerHTML = originalHTML;
        showMessage('Failed to reindex: ' + error.message, 'error');
    }
}

/** Poll /api/admin/jobs/:runId/status until status is completed or failed. */
async function pollJobStatus(runId, intervalMs = 1500, maxWaitMs = 600000) {
    const deadline = Date.now() + maxWaitMs;
    while (Date.now() < deadline) {
        await new Promise(r => setTimeout(r, intervalMs));
        const res = await fetch(`/api/admin/jobs/${runId}/status`);
        if (!res.ok) throw new Error('Status check failed');
        const run = await res.json();
        if (run.status === 'completed' || run.status === 'failed') return run;
    }
    throw new Error('Job timed out');
}

function showMessage(message, type) {
    let messageEl = document.querySelector('#admin-message');
    if (!messageEl) {
        messageEl = document.createElement('div');
        messageEl.id = 'admin-message';
        messageEl.style.cssText = 'position:fixed;top:80px;right:20px;z-index:9999;min-width:350px;max-width:500px;box-shadow:0 4px 6px rgba(0,0,0,0.1)';
        document.body.appendChild(messageEl);
    }

    const icon = type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle';
    const bgClass = type === 'success' ? 'bg-success' : 'bg-danger';

    messageEl.innerHTML = `
        <div class="card">
            <div class="card-header ${bgClass} text-white">
                <h6 class="mb-0"><i class="fas ${icon}"></i> ${type === 'success' ? 'Success' : 'Error'}</h6>
            </div>
            <div class="card-body">${message}</div>
        </div>`;
    messageEl.style.display = 'block';
    messageEl.style.opacity = '0';
    messageEl.style.transition = 'opacity 0.3s ease-in-out';
    setTimeout(() => messageEl.style.opacity = '1', 10);
    setTimeout(() => {
        messageEl.style.opacity = '0';
        setTimeout(() => messageEl.style.display = 'none', 300);
    }, 5000);
}

async function dashboardMediaRescan() {
    const btn = document.getElementById('dashboard-rescan-btn');
    const status = document.getElementById('dashboard-media-status');
    const originalHTML = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Scanning…';
    status.style.display = 'none';
    try {
        const csrfToken = document.querySelector('input[name="_csrf"]')?.value || '<%= csrfToken %>';
        const enqueueRes = await fetch('/api/admin/jobs/media.rescan/enqueue', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'CSRF-Token': csrfToken }
        });
        const { runId } = await enqueueRes.json();
        if (!runId) throw new Error('Failed to start rescan job');
        const run = await pollJobStatus(runId);
        status.className = run.status === 'completed' ? 'alert alert-success' : 'alert alert-danger';
        status.innerHTML = run.status === 'completed'
            ? `<i class="fas fa-check-circle"></i> ${run.result?.summary || 'Reindex complete'}`
            : `<i class="fas fa-exclamation-triangle"></i> ${run.result?.error || 'Scan failed'}`;
        status.style.display = 'block';
    } catch (e) {
        status.className = 'alert alert-danger';
        status.innerHTML = `<i class="fas fa-exclamation-triangle"></i> ${e.message || 'Request failed'}`;
        status.style.display = 'block';
    } finally {
        btn.disabled = false;
        btn.innerHTML = originalHTML;
    }
}

async function dashboardMediaRebuild() {
    if (!confirm('Delete the existing media index and rebuild from scratch? This may take several minutes.')) return;
    const btn = document.getElementById('dashboard-rebuild-btn');
    const status = document.getElementById('dashboard-media-status');
    const originalHTML = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Rebuilding…';
    status.style.display = 'none';
    try {
        const csrfToken = document.querySelector('input[name="_csrf"]')?.value || '<%= csrfToken %>';
        const enqueueRes = await fetch('/api/admin/jobs/media.rebuild/enqueue', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'CSRF-Token': csrfToken }
        });
        const { runId } = await enqueueRes.json();
        if (!runId) throw new Error('Failed to start rebuild job');
        const run = await pollJobStatus(runId, 1500, 3600000);
        status.className = run.status === 'completed' ? 'alert alert-success' : 'alert alert-danger';
        status.innerHTML = run.status === 'completed'
            ? `<i class="fas fa-check-circle"></i> ${run.result?.summary || 'Rebuild complete'}`
            : `<i class="fas fa-exclamation-triangle"></i> ${run.result?.error || 'Rebuild failed'}`;
        status.style.display = 'block';
    } catch (e) {
        status.className = 'alert alert-danger';
        status.innerHTML = `<i class="fas fa-exclamation-triangle"></i> ${e.message || 'Request failed'}`;
        status.style.display = 'block';
    } finally {
        btn.disabled = false;
        btn.innerHTML = originalHTML;
    }
}

// Check for updates on page load (non-blocking)
(async function() {
    try {
        const resp = await fetch('/api/check-updates');
        if (!resp.ok) return;
        const data = await resp.json();
        const el = document.getElementById('update-check-result');
        if (!el) return;
        if (data.updateAvailable && data.latestVersion) {
            el.innerHTML = `<a href="${data.releaseUrl || '#'}" target="_blank" class="badge bg-warning text-dark text-decoration-none">
                <i class="fas fa-arrow-up"></i> v${data.latestVersion} available</a>`;
        } else if (data.latestVersion) {
            el.innerHTML = '<span class="text-muted"><i class="fas fa-check"></i> Up to date</span>';
        }
    } catch {
        // Silently ignore — network may be offline
    }
})();
</script>

