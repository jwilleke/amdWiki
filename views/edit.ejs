<%- include('header', { pageName: pageName }) %>

<div class="container-fluid">
    <% if (typeof isRequiredPage !== 'undefined' && isRequiredPage) { %>
    <div class="alert alert-warning d-flex align-items-center mb-3" role="alert">
        <i class="fas fa-exclamation-triangle me-2 flex-shrink-0"></i>
        <div>
            <strong>Required page:</strong> This page is managed in the <code>required-pages/</code> source.
            Your changes will be overwritten the next time an admin runs a Required Pages Sync.
            To make edits permanent, push them back to the source from
            <a href="/admin/required-pages" class="alert-link">Admin &rsaquo; Required Pages Sync</a>.
        </div>
    </div>
    <% } %>
    <div class="row">
        <div class="col-md-12">
            <h1>Edit <%= pageName %></h1>

            <form id="editForm" action="/save/<%= pageName %>" method="POST">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <% if (typeof sectionIndex !== 'undefined' && sectionIndex !== null) { %>
                <input type="hidden" name="section" value="<%= sectionIndex %>">
                <div class="alert alert-info d-flex align-items-center mb-3" role="alert">
                    <i class="fas fa-cut me-2"></i>
                    <span>Editing <strong>section <%= sectionIndex + 1 %></strong> only.
                    <a href="/edit/<%= pageName %>" class="alert-link ms-2">Edit full page</a></span>
                </div>
                <% } %>
                <!-- Page Title on its own row -->
                <div class="form-group mb-3">
                    <label for="title" style="font-weight:bold;">Page Title: <%- include('_help-icon', { slug: 'page-title', label: 'Page Title' }) %></label>
                    <input type="text" id="title" name="title" class="form-control" value="<%= metadata.title || pageName %>" required>
                </div>
                
                <!-- System Category (Admin only) and User Keywords (Editable by any editor) -->
                <div class="row mb-3">
                    <% if (user && user.roles && user.roles.includes('admin')) { %>
                    <div class="col-md-4">
                        <label style="font-weight:bold;">System Category (Admin Only): <%- include('_help-icon', { slug: 'system-category', label: 'System Category' }) %></label>
                        <select class="form-control" id="systemCategory" name="system-category" required>
                            <% systemCategories.forEach(category => {
                                const currentCategory = (metadata['system-category'] || defaultCategory || '').toLowerCase();
                                const isSelected = currentCategory === category.toLowerCase();
                            %>
                                <option value="<%= category %>" <%= isSelected ? 'selected' : '' %>><%= category %></option>
                            <% }); %>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label style="font-weight:bold;">Author Lock: <%- include('_help-icon', { slug: 'author-lock', label: 'Author Lock' }) %></label>
                        <div class="form-check mt-2">
                            <input class="form-check-input" type="checkbox" name="author-lock" id="authorLock" value="true" <%= metadata['author-lock'] ? 'checked' : '' %>>
                            <label class="form-check-label" for="authorLock" title="Only the page author and admins can edit this page">
                                <i class="fas fa-lock"></i> Locked
                            </label>
                        </div>
                        <input type="hidden" name="author-lock-present" value="1">
                    </div>
                    <% } else { %>
                    <div class="col-md-6">
                        <label style="font-weight:bold;">System Category: <%- include('_help-icon', { slug: 'system-category', label: 'System Category' }) %></label>
                        <input type="hidden" id="systemCategory" name="system-category" value="<%= metadata['system-category'] %>">
                        <input type="text" class="form-control" value="<%= metadata['system-category'] %>" readonly>
                    </div>
                    <% } %>
                    <% if (metadata['author-lock']) { %>
                    <div class="col-12 mt-1">
                        <small class="text-warning"><i class="fas fa-lock"></i> <strong>Author Lock</strong> — only the page author (<%= metadata.author %>) and admins can edit this page.</small>
                    </div>
                    <% } %>
                    <div class="col-md-6">
                        <label style="font-weight:bold;">User Keywords (Optional, Max <%= maxUserKeywords %>): <%- include('_help-icon', { slug: 'user-keywords', label: 'User Keywords' }) %></label>
                        <div class="dropdown">
                            <button class="btn btn-outline-secondary dropdown-toggle w-100 text-start" type="button" id="userKeywordsDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                <span id="selectedUserKeywordsText">Select user keywords...</span>
                            </button>
                            <ul class="dropdown-menu w-100" aria-labelledby="userKeywordsDropdown">
                                <% userKeywords.forEach(kw => {
                                    const id = typeof kw === 'object' ? kw.id : kw;
                                    const label = typeof kw === 'object' ? kw.label : kw;
                                    const description = typeof kw === 'object' ? kw.description : '';
                                %>
                                    <li>
                                        <div class="dropdown-item-checkbox px-3 py-2">
                                            <div class="form-check">
                                                <input class="form-check-input user-keyword-checkbox" type="checkbox" name="user-keywords[]" value="<%= id %>" data-label="<%= label %>" id="user-keyword-<%= id %>" <%= (selectedUserKeywords.includes(id) || selectedUserKeywords.includes(label)) ? 'checked' : '' %>>
                                                <label class="form-check-label ms-2" for="user-keyword-<%= id %>"<% if (description) { %> title="<%= description %>"<% } %>><%= label %><% if (description) { %> <small class="text-muted">- <%= description %></small><% } %></label>
                                            </div>
                                        </div>
                                    </li>
                                <% }); %>
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- Audience (view access) -->
                <% if (typeof availableRoles !== 'undefined' && availableRoles && availableRoles.length > 0) { %>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label style="font-weight:bold;"><i class="fas fa-lock"></i> Audience (view access): <%- include('_help-icon', { slug: 'page-audience', label: 'Page Audience' }) %></label>
                        <div class="dropdown">
                            <button class="btn btn-outline-secondary dropdown-toggle w-100 text-start" type="button" id="audienceDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                <span id="selectedAudienceText">Select audience...</span>
                            </button>
                            <ul class="dropdown-menu w-100" aria-labelledby="audienceDropdown">
                                <% availableRoles.forEach(function(role) { %>
                                    <li>
                                        <div class="dropdown-item-checkbox px-3 py-2">
                                            <div class="form-check">
                                                <input class="form-check-input audience-checkbox" type="checkbox"
                                                       name="audience" value="<%= role.name %>"
                                                       data-label="<%= role.displayname %>"
                                                       id="aud-<%= role.name %>"
                                                       <%= (pageData && pageData.metadata && pageData.metadata.audience &&
                                                            pageData.metadata.audience.includes(role.name)) ? 'checked' : '' %>>
                                                <label class="form-check-label ms-2" for="aud-<%= role.name %>"><%= role.displayname %></label>
                                            </div>
                                        </div>
                                    </li>
                                <% }); %>
                            </ul>
                        </div>
                        <small class="text-muted">
                            Leave all unchecked = open access (global policies apply).
                            The <strong>private</strong> keyword overrides all audience settings.
                        </small>
                    </div>
                </div>
                <% } %>

                <!-- Content -->
                <div class="form-group mb-3">
                    <label for="content" style="font-weight:bold;">Content: <%- include('_help-icon', { slug: 'page-content', label: 'Page Content' }) %></label>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="card h-100">
                                <div class="card-header d-flex align-items-center justify-content-between">
                                    <span>Edit Content</span>
                                    <button type="button" class="btn btn-outline-secondary btn-sm"
                                            title="Insert emoji (:shortcode: or type : in editor)"
                                            onclick="openEmojiPicker()">
                                        <i class="fas fa-smile"></i>
                                    </button>
                                </div>
                                <div class="card-body p-0 d-flex flex-column" style="min-height: 400px;">
                                    <textarea id="content" name="content" class="form-control border-0 rounded-0 flex-grow-1" style="resize: vertical; min-height: 100%;" required><%= content %></textarea>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card h-100">
                                <div class="card-header">Preview</div>
                                <div class="card-body markdown-body d-flex flex-column" style="min-height: 400px;">
                                    <div id="preview" class="flex-grow-1"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Attachments Section -->
                <div class="form-group mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <label style="font-weight:bold;" class="mb-0">
                            <i class="fas fa-paperclip"></i> Page Attachments <%- include('_help-icon', { slug: 'page-attachments', label: 'Page Attachments' }) %>
                            <span class="badge bg-secondary"><%= typeof pageAttachments !== 'undefined' ? pageAttachments.length : 0 %></span>
                        </label>
                        <div class="btn-group btn-group-sm">
                            <button type="button" class="btn btn-outline-primary" onclick="showUploadAttachment()">
                                <i class="fas fa-upload"></i> Upload
                            </button>
                            <button type="button" class="btn btn-outline-secondary" onclick="openBrowseAttachments(); return false;">
                                <i class="fas fa-photo-video"></i> Browse Assets
                            </button>
                        </div>
                    </div>
                    <div id="pageAttachments">
                        <% if (typeof pageAttachments !== 'undefined' && pageAttachments.length > 0) { %>
                            <div class="table-responsive">
                                <table class="table table-sm">
                                    <thead>
                                        <tr>
                                            <th>File</th>
                                            <th>Type</th>
                                            <th>Size</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody id="attachmentTableBody">
                                        <% pageAttachments.forEach(att => { %>
                                            <tr>
                                                <td><code><%= att.name %></code></td>
                                                <td><small><%= att.encodingFormat %></small></td>
                                                <td><small><%= Math.round((att.contentSize || 0) / 1024) %> KB</small></td>
                                                <td>
                                                    <button type="button" class="btn btn-sm btn-outline-primary"
                                                        onclick="insertAttachmentMarkup('<%= att.url %>', '<%= att.name %>', '<%= att.encodingFormat %>')">
                                                        <i class="fas fa-code"></i> Insert
                                                    </button>
                                                    <button type="button" class="btn btn-sm btn-outline-secondary"
                                                        onclick="copyToClipboard('<%= att.url %>')">
                                                        <i class="fas fa-copy"></i> URL
                                                    </button>
                                                </td>
                                            </tr>
                                        <% }); %>
                                    </tbody>
                                </table>
                            </div>
                        <% } else { %>
                            <p class="text-muted"><small>No attachments yet. Click "Upload" to add files or "Browse Assets" to insert from attachments or the media library.</small></p>
                        <% } %>
                    </div>
                </div>

                <!-- Form Submit Buttons -->
                <div class="form-group mt-4">
                    <button type="submit" class="btn btn-primary btn-lg">Save Page</button>
                    <a href="/view/<%= encodeURIComponent(pageName) %>" class="btn btn-secondary btn-lg ms-2">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    // Update preview function
    function updatePreview() {
        const content = document.getElementById('content');
        const preview = document.getElementById('preview');
        let text = content.value;
        
        // Make an API call to get properly rendered content with user variables
        fetch('/api/preview', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRF-Token': '<%= csrfToken %>'
            },
            body: JSON.stringify({
                content: text,
                pageName: '<%= pageName %>'
            })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success && data.html) {
                preview.innerHTML = data.html;
            } else {
                // Fallback to simple markdown conversion if API fails
                text = text.replace(/^# (.*$)/gim, '<h1>$1</h1>');
                text = text.replace(/^## (.*$)/gim, '<h2>$1</h2>');
                text = text.replace(/^### (.*$)/gim, '<h3>$1</h3>');
                text = text.replace(/\*\*(.*)\*\*/g, '<strong>$1</strong>');
                text = text.replace(/\*(.*)\*/g, '<em>$1</em>');
                text = text.replace(/\n/g, '<br>');
                preview.innerHTML = text;
            }
        })
        .catch(error => {
            console.error('Preview API error:', error);
            // Fallback to simple markdown conversion
            text = text.replace(/^# (.*$)/gim, '<h1>$1</h1>');
            text = text.replace(/^## (.*$)/gim, '<h2>$1</h2>');
            text = text.replace(/^### (.*$)/gim, '<h3>$1</h3>');
            text = text.replace(/\*\*(.*)\*\*/g, '<strong>$1</strong>');
            text = text.replace(/\*(.*)\*/g, '<em>$1</em>');
            text = text.replace(/\n/g, '<br>');
            preview.innerHTML = text;
        });
    }
    
    // Update preview on input
    document.getElementById('content').addEventListener('input', updatePreview);
    updatePreview();
    // Form submission validation for system-category and user-keywords
    document.querySelector('form').addEventListener('submit', function(e) {
        console.log('Form submit triggered');

        // Validate system-category (only if field exists - admin users only)
        const systemCategoryElement = document.getElementById('systemCategory');
        if (systemCategoryElement) {
            const systemCategory = systemCategoryElement.value;
            if (!systemCategory) {
                console.log('Validation failed: no system category');
                e.preventDefault();
                alert('System category is required');
                return false;
            }
            console.log('System category:', systemCategory);
        } else {
            console.log('System category field not found (non-admin user)');
        }

        // Validate title — reject special characters that break URLs
        const titleField = document.getElementById('title');
        if (titleField) {
            const titleVal = titleField.value;
            if (/[\/\\#?%"'<>|*]/.test(titleVal)) {
                e.preventDefault();
                alert('Page title contains invalid characters.\nThe following are not allowed: / \\ # ? % " \' < > | *');
                titleField.focus();
                return false;
            }
        }

        // Validate user-keywords (max <%= maxUserKeywords %>, optional)
        const checkedKeywords = document.querySelectorAll('.user-keyword-checkbox:checked').length;
        if (checkedKeywords > <%= maxUserKeywords %>) {
            console.log('Validation failed: too many keywords');
            e.preventDefault();
            alert('Maximum <%= maxUserKeywords %> user keywords allowed');
            return false;
        }

        console.log('Form validation passed, submitting...');
    });
    function updateSelectedUserKeywordsText() {
        const checkedKeywords = Array.from(document.querySelectorAll('.user-keyword-checkbox:checked')).map(cb => cb.dataset.label || cb.value);
        const text = checkedKeywords.length > 0 ? checkedKeywords.join(', ') : 'Select user keywords...';
        document.getElementById('selectedUserKeywordsText').textContent = text;
    }
    function updateSelectedAudienceText() {
        const checked = Array.from(document.querySelectorAll('.audience-checkbox:checked')).map(cb => cb.dataset.label || cb.value);
        const el = document.getElementById('selectedAudienceText');
        if (el) el.textContent = checked.length > 0 ? checked.join(', ') : 'Select audience...';
    }
    // Initialize dropdowns
    updateSelectedUserKeywordsText();
    updateSelectedAudienceText();
    // Keep dropdown button text in sync as checkboxes change
    document.addEventListener('change', function(e) {
        if (e.target.classList.contains('user-keyword-checkbox')) updateSelectedUserKeywordsText();
        if (e.target.classList.contains('audience-checkbox')) updateSelectedAudienceText();
    });

    // Insert attachment markup at cursor position
    function insertAttachmentMarkup(url, name, mimeType) {
        const textarea = document.getElementById('content');
        let markup;

        markup = `[{ATTACH src='${name}'}]`;

        const start = textarea.selectionStart;
        const end = textarea.selectionEnd;
        const text = textarea.value;
        textarea.value = text.substring(0, start) + markup + text.substring(end);
        textarea.focus();
        textarea.setSelectionRange(start + markup.length, start + markup.length);
        updatePreview();
    }

    // Expose for Browse Attachments popup
    window.insertAttachmentMarkup = insertAttachmentMarkup;

    function copyToClipboard(text) {
        navigator.clipboard.writeText(text).then(function() {
            // Brief visual feedback could be added here
        }).catch(function(err) {
            // Fallback for older browsers
            const textarea = document.createElement('textarea');
            textarea.value = text;
            document.body.appendChild(textarea);
            textarea.select();
            document.execCommand('copy');
            document.body.removeChild(textarea);
        });
    }

    function addAttachmentRow(att) {
        const container = document.getElementById('pageAttachments');
        let tbody = document.getElementById('attachmentTableBody');

        // If table doesn't exist yet (was "No attachments" message), create it
        if (!tbody) {
            container.innerHTML = `
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>File</th>
                                <th>Type</th>
                                <th>Size</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="attachmentTableBody"></tbody>
                    </table>
                </div>`;
            tbody = document.getElementById('attachmentTableBody');
        }

        const row = document.createElement('tr');
        const sizeKB = Math.round((att.contentSize || 0) / 1024);
        row.innerHTML = `
            <td><code>${att.name}</code></td>
            <td><small>${att.encodingFormat}</small></td>
            <td><small>${sizeKB} KB</small></td>
            <td>
                <button type="button" class="btn btn-sm btn-outline-primary"
                    onclick="insertAttachmentMarkup('${att.url}', '${att.name}', '${att.encodingFormat}')">
                    <i class="fas fa-code"></i> Insert
                </button>
                <button type="button" class="btn btn-sm btn-outline-secondary"
                    onclick="copyToClipboard('${att.url}')">
                    <i class="fas fa-copy"></i> URL
                </button>
            </td>`;
        tbody.appendChild(row);

        // Update badge count
        const badge = container.closest('.form-group').querySelector('.badge');
        if (badge) {
            badge.textContent = tbody.querySelectorAll('tr').length;
        }
    }

    // Initialize User Preferences for Smart Typing
    document.addEventListener('DOMContentLoaded', function() {
        <% if (typeof user !== 'undefined' && user && user.preferences) { %>
            const userPrefs = new UserPreferences(<%- JSON.stringify(user.preferences) %>);
            const contentTextarea = document.getElementById('content');
            if (contentTextarea) {
                userPrefs.applyEditorPreferences(contentTextarea);
            }
        <% } %>
    });
</script>

<!-- Page Link Autocomplete - Issue #90 / Emoji Autocomplete - Issue #512 -->
<script>
    // Wait for PageAutocomplete and EmojiAutocomplete to load (both in footer.ejs)
    function initEditPageAutocomplete() {
        const contentTextarea = document.getElementById('content');
        if (!contentTextarea) {
            console.error('Autocomplete: content textarea not found');
            return;
        }

        // Check if autocomplete classes are loaded
        if (typeof PageAutocomplete === 'undefined' || typeof EmojiAutocomplete === 'undefined') {
            setTimeout(initEditPageAutocomplete, 100);
            return;
        }

        // Track the bracket position for proper insertion
        let currentBracketPos = -1;

        // ── Page link autocomplete (triggers on '[') ────────────────────────────
        const autocomplete = new PageAutocomplete({
            minChars: 2,
            maxSuggestions: 10,
            onSelect: function(suggestion) {
                // Replace partial text with full page name
                const cursorPos = contentTextarea.selectionStart;
                const text = contentTextarea.value;

                // Find the opening bracket position
                const bracketPos = currentBracketPos >= 0 ? currentBracketPos : text.lastIndexOf('[', cursorPos - 1);

                if (bracketPos >= 0) {
                    // Check if there's already a closing bracket after cursor
                    const textAfter = text.substring(cursorPos);
                    const hasClosingBracket = textAfter.trimStart().startsWith(']');

                    // Replace from bracket to cursor with [PageName]
                    const before = text.substring(0, bracketPos);
                    const replacement = '[' + suggestion.name + (hasClosingBracket ? '' : ']');
                    const after = text.substring(cursorPos);

                    contentTextarea.value = before + replacement + after;

                    // Position cursor after the closing bracket
                    const newCursorPos = before.length + replacement.length;
                    contentTextarea.setSelectionRange(newCursorPos, newCursorPos);
                    contentTextarea.focus();
                    updatePreview();
                }
            }
        });

        // ── Emoji autocomplete (triggers on ':' + 2+ chars) ────────────────────
        const emojiAutocomplete = new EmojiAutocomplete({
            minChars: 2,
            maxSuggestions: 12,
            onSelect: function(suggestion) {
                const cursorPos = contentTextarea.selectionStart;
                const text = contentTextarea.value;
                // Find the colon that opened this search
                const lastColon = text.lastIndexOf(':', cursorPos - 1);
                if (lastColon >= 0) {
                    const before = text.substring(0, lastColon);
                    const after = text.substring(cursorPos);
                    const shortcode = ':' + suggestion.name + ':';
                    contentTextarea.value = before + shortcode + after;
                    const newPos = before.length + shortcode.length;
                    contentTextarea.setSelectionRange(newPos, newPos);
                    contentTextarea.focus();
                    updatePreview();
                }
            }
        });

        // Helper function to insert text at cursor
        function insertTextAtCursor(textarea, text) {
            const start = textarea.selectionStart;
            const end = textarea.selectionEnd;
            const value = textarea.value;

            textarea.value = value.substring(0, start) + text + value.substring(end);
            textarea.focus();
            textarea.setSelectionRange(start + text.length, start + text.length);
        }

        // Detect typing and show appropriate autocomplete
        contentTextarea.addEventListener('input', function(e) {
            const cursorPos = contentTextarea.selectionStart;
            const text = contentTextarea.value;

            // ── Page link: trigger on '[' ─────────────────────────────────────
            const lastBracket = text.lastIndexOf('[', cursorPos - 1);

            if (lastBracket >= 0) {
                currentBracketPos = lastBracket;
                const query = text.substring(lastBracket + 1, cursorPos);
                const textAfterBracket = text.substring(lastBracket);
                const closingBracket = textAfterBracket.indexOf(']');

                if (closingBracket === -1 || closingBracket >= (cursorPos - lastBracket)) {
                    if (!query.startsWith('{')) {
                        if (query.length >= 2) {
                            autocomplete.search(query, contentTextarea, cursorPos);
                        } else {
                            autocomplete.hideDropdown();
                        }
                    } else {
                        autocomplete.hideDropdown();
                    }
                } else {
                    currentBracketPos = -1;
                    autocomplete.hideDropdown();
                }
            } else {
                currentBracketPos = -1;
                autocomplete.hideDropdown();
            }

            // ── Emoji: trigger on ':' + 2+ non-space chars ───────────────────
            const lastColon = text.lastIndexOf(':', cursorPos - 1);
            if (lastColon >= 0) {
                const emojiQuery = text.substring(lastColon + 1, cursorPos);
                if (emojiQuery.length >= 2 && !/\s/.test(emojiQuery)) {
                    emojiAutocomplete.search(emojiQuery, contentTextarea, cursorPos);
                } else {
                    emojiAutocomplete.hideDropdown();
                }
            } else {
                emojiAutocomplete.hideDropdown();
            }
        });

        // Handle keyboard navigation — page autocomplete takes priority
        contentTextarea.addEventListener('keydown', function(e) {
            if (autocomplete.handleKeydown(e)) {
                e.preventDefault();
                return;
            }
            if (emojiAutocomplete.handleKeydown(e)) {
                e.preventDefault();
            }
        });

        // Hide both dropdowns when clicking outside
        document.addEventListener('click', function(e) {
            if (e.target !== contentTextarea) {
                autocomplete.hideDropdown();
                emojiAutocomplete.hideDropdown();
            }
        });
    }

    // Start initialization when DOM is ready
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initEditPageAutocomplete);
    } else {
        initEditPageAutocomplete();
    }
</script>

<!-- Emoji Picker Modal (Issue #512) -->
<div class="modal fade" id="emojiPickerModal" tabindex="-1"
     aria-labelledby="emojiPickerModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="emojiPickerModalLabel">
                    <i class="fas fa-smile"></i> Insert Emoji
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <%- include('_emoji-picker') %>
            </div>
        </div>
    </div>
</div>

<script>
// Emoji picker modal — lazy grid rendering (Issue #512)
function initEmojiPicker() {
    const modal = document.getElementById('emojiPickerModal');
    if (!modal) return;

    // Populate grid on first open
    modal.addEventListener('shown.bs.modal', function() {
        const grid = document.getElementById('emojiGrid');
        if (!grid || grid.dataset.populated) return;

        function renderCategory(category) {
            grid.innerHTML = '';
            const data = (category === 'all')
                ? EMOJI_CLIENT_DATA
                : EMOJI_CLIENT_DATA.filter(([, , cat]) => cat === category);
            data.forEach(([name, char]) => {
                const btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'btn btn-outline-secondary btn-sm p-1';
                btn.title = ':' + name + ':';
                btn.style.cssText = 'font-size:1.4rem;line-height:1;min-width:2.4rem;';
                btn.textContent = char;
                btn.addEventListener('click', function() { insertEmoji(name); });
                grid.appendChild(btn);
            });
        }

        // Wire category tabs
        document.querySelectorAll('[data-emoji-category]').forEach(function(tab) {
            tab.addEventListener('click', function() {
                document.querySelectorAll('[data-emoji-category]').forEach(t => t.classList.remove('active'));
                tab.classList.add('active');
                renderCategory(tab.dataset.emojiCategory);
            });
        });

        renderCategory('smileys');
        grid.dataset.populated = '1';
    });
}

window.openEmojiPicker = function() {
    new bootstrap.Modal(document.getElementById('emojiPickerModal')).show();
};

window.insertEmoji = function(shortcode) {
    const textarea = document.getElementById('content');
    if (!textarea) return;
    const markup = ':' + shortcode + ':';
    const start = textarea.selectionStart;
    const end = textarea.selectionEnd;
    textarea.value = textarea.value.substring(0, start) + markup + textarea.value.substring(end);
    textarea.focus();
    textarea.setSelectionRange(start + markup.length, start + markup.length);
    if (typeof updatePreview === 'function') updatePreview();
    const modalEl = document.getElementById('emojiPickerModal');
    const modalInstance = bootstrap.Modal.getInstance(modalEl);
    if (modalInstance) modalInstance.hide();
};

if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initEmojiPicker);
} else {
    initEmojiPicker();
}
</script>

