<%- include('header', { pageName: '' }) %>

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1><i class="fas fa-photo-video"></i> Media Manager</h1>
                <a href="/admin" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Back to Dashboard
                </a>
            </div>

            <!-- Status badge -->
            <div class="mb-4">
                <% if (mediaEnabled) { %>
                    <span class="badge bg-success fs-6"><i class="fas fa-check-circle"></i> Media Manager Enabled</span>
                <% } else { %>
                    <span class="badge bg-secondary fs-6"><i class="fas fa-times-circle"></i> Media Manager Disabled</span>
                    <p class="mt-2 text-muted">Set <code>ngdpbase.media.enabled = true</code> in configuration and restart to enable.</p>
                <% } %>
            </div>

            <% if (mediaEnabled) { %>

            <!-- Index statistics -->
            <div class="card mb-4">
                <div class="card-header"><i class="fas fa-database"></i> Index Statistics</div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4 text-center">
                            <h3 id="stat-years" class="mb-0"><%= years ? years.length : 0 %></h3>
                            <small class="text-muted">Years indexed</small>
                        </div>
                        <div class="col-md-4 text-center">
                            <h3 class="mb-0">
                                <% if (years && years.length > 0) { %>
                                    <%= years[years.length - 1] %> – <%= years[0] %>
                                <% } else { %>
                                    —
                                <% } %>
                            </h3>
                            <small class="text-muted">Year range</small>
                        </div>
                        <div class="col-md-4 text-center">
                            <a href="/media" class="btn btn-sm btn-secondary">
                                <i class="fas fa-eye"></i> Browse Media
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Years list -->
            <% if (years && years.length > 0) { %>
            <div class="card mb-4">
                <div class="card-header"><i class="fas fa-calendar-alt"></i> Indexed Years</div>
                <div class="card-body">
                    <% years.forEach(function(year) { %>
                        <a href="/media/year/<%= year %>" class="badge bg-secondary text-decoration-none me-1 mb-1 fs-6"><%= year %></a>
                    <% }); %>
                </div>
            </div>
            <% } %>

            <!-- Rescan / Rebuild -->
            <div class="card mb-4">
                <div class="card-header"><i class="fas fa-sync-alt"></i> Index Operations</div>
                <div class="card-body">
                    <div class="mb-4">
                        <h6>Reindex Media
                            <a href="/view/media" class="ms-1 text-muted" title="Documentation" target="_blank"><i class="fas fa-question-circle fa-sm"></i></a>
                        </h6>
                        <p class="text-muted small">Re-scans all configured media folders and updates the index. New, changed, and excluded files are processed. Previously indexed files that no longer exist on disk are <strong>not</strong> removed — use Rebuild for that.</p>
                        <button id="rescan-btn" class="btn btn-primary">
                            <i class="fas fa-sync-alt"></i> Reindex Media
                        </button>
                        <div id="rescan-status" class="mt-3" style="display:none;"></div>
                    </div>

                    <hr>

                    <div>
                        <h6>Rebuild Media Index
                            <a href="/view/media" class="ms-1 text-muted" title="Documentation" target="_blank"><i class="fas fa-question-circle fa-sm"></i></a>
                        </h6>
                        <p class="text-muted small">Deletes the existing index and rebuilds it from scratch by scanning all configured folders. Stale entries for deleted or moved files are removed. This may take several minutes for large libraries.</p>
                        <button id="rebuild-btn" class="btn btn-warning">
                            <i class="fas fa-database"></i> Rebuild Media Index
                        </button>
                        <div id="rebuild-status" class="mt-3" style="display:none;"></div>
                    </div>
                </div>
            </div>

            <% } %> <!-- end mediaEnabled -->
        </div>
    </div>
</div>

<script>
/** Poll /api/admin/jobs/:runId/status until completed or failed. */
async function pollJobStatus(runId, intervalMs = 1500, maxWaitMs = 600000) {
    const deadline = Date.now() + maxWaitMs;
    while (Date.now() < deadline) {
        await new Promise(r => setTimeout(r, intervalMs));
        const res = await fetch(`/api/admin/jobs/${runId}/status`);
        if (!res.ok) throw new Error('Status check failed');
        const run = await res.json();
        if (run.status === 'completed' || run.status === 'failed') return run;
    }
    throw new Error('Job timed out');
}

document.getElementById('rescan-btn')?.addEventListener('click', async function () {
    const btn = this;
    const status = document.getElementById('rescan-status');
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Starting…';
    status.style.display = 'none';
    try {
        const enqueueRes = await fetch('/api/admin/jobs/media.rescan/enqueue', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
        const { runId } = await enqueueRes.json();
        if (!runId) throw new Error('Failed to start rescan job');
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Scanning…';
        const run = await pollJobStatus(runId);
        status.className = run.status === 'completed' ? 'alert alert-success' : 'alert alert-danger';
        status.innerHTML = run.status === 'completed'
            ? `<i class="fas fa-check-circle"></i> ${run.result?.summary || 'Reindex complete'}`
            : `<i class="fas fa-exclamation-triangle"></i> ${run.result?.error || 'Scan failed'}`;
    } catch (e) {
        status.className = 'alert alert-danger';
        status.innerHTML = `<i class="fas fa-exclamation-triangle"></i> ${e.message || 'Request failed'}`;
    } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-sync-alt"></i> Reindex Media';
        status.style.display = 'block';
    }
});

document.getElementById('rebuild-btn')?.addEventListener('click', async function () {
    if (!confirm('This will delete the existing media index and rebuild it from scratch by scanning all configured folders.\n\nStale entries for deleted or moved files will be removed. This may take several minutes for large libraries.\n\nContinue?')) return;
    const btn = this;
    const status = document.getElementById('rebuild-status');
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Starting…';
    status.style.display = 'none';
    try {
        const enqueueRes = await fetch('/api/admin/jobs/media.rebuild/enqueue', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
        const { runId } = await enqueueRes.json();
        if (!runId) throw new Error('Failed to start rebuild job');
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Rebuilding…';
        const run = await pollJobStatus(runId);
        status.className = run.status === 'completed' ? 'alert alert-success' : 'alert alert-danger';
        status.innerHTML = run.status === 'completed'
            ? `<i class="fas fa-check-circle"></i> ${run.result?.summary || 'Rebuild complete'}`
            : `<i class="fas fa-exclamation-triangle"></i> ${run.result?.error || 'Rebuild failed'}`;
    } catch (e) {
        status.className = 'alert alert-danger';
        status.innerHTML = `<i class="fas fa-exclamation-triangle"></i> ${e.message || 'Request failed'}`;
    } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-database"></i> Rebuild Media Index';
        status.style.display = 'block';
    }
});
</script>

<%- include('footer') %>
