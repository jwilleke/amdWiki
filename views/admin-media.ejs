<%- include('header', { pageName: '' }) %>

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1><i class="fas fa-photo-video"></i> Media Manager</h1>
                <a href="/admin" class="btn" style="background-color: var(--btn-secondary-bg); color: var(--btn-secondary-text); border-color: var(--btn-secondary-border);">
                    <i class="fas fa-arrow-left"></i> Back to Dashboard
                </a>
            </div>

            <!-- Status badge -->
            <div class="mb-4">
                <% if (mediaEnabled) { %>
                    <span class="badge bg-success fs-6"><i class="fas fa-check-circle"></i> Media Manager Enabled</span>
                <% } else { %>
                    <span class="badge bg-secondary fs-6"><i class="fas fa-times-circle"></i> Media Manager Disabled</span>
                    <p class="mt-2 text-muted">Set <code>amdwiki.media.enabled = true</code> in configuration and restart to enable.</p>
                <% } %>
            </div>

            <% if (mediaEnabled) { %>

            <!-- Index statistics -->
            <div class="card mb-4">
                <div class="card-header"><i class="fas fa-database"></i> Index Statistics</div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4 text-center">
                            <h3 id="stat-years" class="mb-0"><%= years ? years.length : 0 %></h3>
                            <small class="text-muted">Years indexed</small>
                        </div>
                        <div class="col-md-4 text-center">
                            <h3 class="mb-0">
                                <% if (years && years.length > 0) { %>
                                    <%= years[years.length - 1] %> – <%= years[0] %>
                                <% } else { %>
                                    —
                                <% } %>
                            </h3>
                            <small class="text-muted">Year range</small>
                        </div>
                        <div class="col-md-4 text-center">
                            <a href="/media" class="btn btn-sm" style="background-color: var(--btn-secondary-bg); color: var(--btn-secondary-text); border-color: var(--btn-secondary-border);">
                                <i class="fas fa-eye"></i> Browse Media
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Years list -->
            <% if (years && years.length > 0) { %>
            <div class="card mb-4">
                <div class="card-header"><i class="fas fa-calendar-alt"></i> Indexed Years</div>
                <div class="card-body">
                    <% years.forEach(function(year) { %>
                        <a href="/media/year/<%= year %>" class="badge bg-secondary text-decoration-none me-1 mb-1 fs-6"><%= year %></a>
                    <% }); %>
                </div>
            </div>
            <% } %>

            <!-- Rescan -->
            <div class="card mb-4">
                <div class="card-header"><i class="fas fa-sync-alt"></i> Scan</div>
                <div class="card-body">
                    <p class="text-muted">Trigger a full rescan of all configured media folders. This may take a while for large libraries.</p>
                    <button id="rescan-btn" class="btn" style="background-color: var(--btn-primary-bg); color: var(--btn-primary-text); border-color: var(--btn-primary-border);">
                        <i class="fas fa-sync-alt"></i> Trigger Rescan
                    </button>
                    <div id="rescan-status" class="mt-3" style="display:none;"></div>
                </div>
            </div>

            <% } %> <!-- end mediaEnabled -->
        </div>
    </div>
</div>

<script>
document.getElementById('rescan-btn')?.addEventListener('click', async function () {
    const btn = this;
    const status = document.getElementById('rescan-status');
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Scanning…';
    status.style.display = 'none';

    try {
        const res = await fetch('/admin/media/rescan', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
        const data = await res.json();
        if (data.success) {
            const r = data.result;
            status.className = 'alert alert-success';
            status.innerHTML = `<i class="fas fa-check-circle"></i> Scan complete — scanned: ${r.scanned}, added: ${r.added}, updated: ${r.updated}, errors: ${r.errors}`;
        } else {
            status.className = 'alert alert-danger';
            status.innerHTML = `<i class="fas fa-exclamation-triangle"></i> ${data.error || 'Scan failed'}`;
        }
    } catch (e) {
        status.className = 'alert alert-danger';
        status.innerHTML = '<i class="fas fa-exclamation-triangle"></i> Request failed';
    } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-sync-alt"></i> Trigger Rescan';
        status.style.display = 'block';
        // Refresh year count after scan
        setTimeout(() => location.reload(), 2000);
    }
});
</script>

<%- include('footer') %>
