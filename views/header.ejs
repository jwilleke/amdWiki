
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><% if (typeof pageName !== 'undefined' && pageName) { %><%= pageName %> | <% } %><%= typeof applicationName !== 'undefined' ? applicationName : 'ngdpbase' %></title>
    <link rel="icon" href="<%= typeof faviconPath !== 'undefined' ? faviconPath : '/favicon.ico' %>">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <!-- Theme fonts (optional, defined in theme.json) -->
    <% if (typeof themeFontUrls !== 'undefined' && themeFontUrls && themeFontUrls.length) { %>
    <% themeFontUrls.forEach(function(url) { %><link rel="stylesheet" href="<%= url %>">
    <% }); %><% } %>
    <!-- Theme: variables must load before core so selectors can resolve them -->
    <link rel="stylesheet" href="<%= typeof variablesCssPath !== 'undefined' ? variablesCssPath : '/themes/default/css/variables.css' %>">
    <link rel="stylesheet" href="<%= typeof coreCssPath !== 'undefined' ? coreCssPath : '/themes/core.css' %>">
    <link rel="stylesheet" href="<%= typeof locationCssPath !== 'undefined' ? locationCssPath : '/themes/plugins/location.css' %>">
    <!-- Add-on stylesheets (registered via AddonsManager.registerStylesheet()) -->
    <% if (typeof addonStylesheets !== 'undefined' && addonStylesheets && addonStylesheets.length) { %>
    <% addonStylesheets.forEach(function(url) { %><link rel="stylesheet" href="<%= url %>">
    <% }); %><% } %>

    <!-- User Preferences Script -->
    <script src="/js/user-preferences.js"></script>

    <!-- Table Enhancement Scripts -->
    <script src="/js/zebraTable.js"></script>
    <script src="/js/tableSort.js"></script>
    <script src="/js/tableFilter.js"></script>

    <!-- Schema.org JSON-LD structured data -->
    <% if (typeof pageSchema !== 'undefined' && pageSchema) { %>
        <%- pageSchema %>
    <% } %>
    
    <% if (typeof siteSchema !== 'undefined' && siteSchema) { %>
        <%- siteSchema %>
    <% } %>
</head>
<body>
    <!-- JSPWiki-style header (#371, #375) -->
    <nav class="navbar navbar-expand-md jspwiki-header border-bottom py-1 py-md-2">
        <div class="container-fluid">
            <!-- Logo: always visible -->
            <a class="navbar-brand" href="/">
                <img src="<%= typeof logoPath !== 'undefined' ? logoPath : (typeof faviconPath !== 'undefined' ? faviconPath : '/favicon.ico') %>" alt="Logo" style="height: 24px; width: 24px; margin-right: 8px;"><strong><%= typeof applicationName !== 'undefined' ? applicationName : 'ngdpbase' %></strong>
            </a>

            <!-- Mobile: compact user icon (no dropdown, just link to profile/login) -->
            <div class="d-flex d-md-none align-items-center">
                <% if (typeof currentUser !== 'undefined' && currentUser && currentUser.isAuthenticated) { %>
                <a class="btn btn-outline-secondary btn-sm" href="/profile" title="<%= currentUser.displayName || currentUser.username %>">
                    <i class="fas fa-user"></i>
                </a>
                <% } else { %>
                <a class="btn btn-outline-primary btn-sm me-1" href="/login?redirect=<%= encodeURIComponent(typeof pageName !== 'undefined' && pageName ? `/view/${pageName}` : '/') %>">
                    <i class="fas fa-sign-in-alt"></i>
                </a>
                <% } %>
            </div>

            <!-- Desktop: search + user dropdown (collapse on mobile) -->
            <div class="collapse navbar-collapse justify-content-center" id="headerNavCollapse">
                <!-- Search (desktop center) -->
                <form class="d-flex mx-auto" action="/search" method="GET" style="max-width: 400px; width: 100%;">
                    <div class="input-group">
                        <input class="form-control" type="search" id="headerSearchInput" placeholder="Search pages..." aria-label="Search" name="q">
                        <button class="btn" style="background-color: var(--btn-primary-bg); color: var(--btn-primary-text); border-color: var(--btn-primary-border);" type="submit">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                </form>
            </div>

            <!-- Desktop user dropdown -->
            <div class="d-none d-md-flex align-items-center">
                <% if (typeof currentUser !== 'undefined' && currentUser && currentUser.isAuthenticated) { %>
                    <div class="dropdown d-inline">
                        <button class="btn btn-outline-secondary dropdown-toggle" type="button" id="userDropdown" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                            <i class="fas fa-user"></i> <%= currentUser.displayName || currentUser.username %>
                            <% if (currentUser.roles && currentUser.roles.includes('admin')) { %><span class="badge bg-warning ms-1" style="color: var(--text-dark);">Admin</span><% } %>
                        </button>
                        <div class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                            <a class="dropdown-item" href="/profile"><i class="fas fa-user-cog"></i> Profile</a>
                            <% if (currentUser.roles && (currentUser.roles.includes('admin') || currentUser.roles.includes('editor'))) { %>
                                <div class="dropdown-divider"></div>
                                <h6 class="dropdown-header">Management</h6>
                                <a class="dropdown-item" href="/admin/attachments"><i class="fas fa-paperclip"></i> Attachments</a>
                                <% if (currentUser.roles.includes('admin')) { %>
                                    <a class="dropdown-item" href="/admin"><i class="fas fa-cogs"></i> Admin Dashboard</a>
                                    <a class="dropdown-item" href="/admin/users"><i class="fas fa-users"></i> User Management</a>
                                    <a class="dropdown-item" href="/admin/organizations"><i class="fas fa-building"></i> Organizations</a>
                                <% } %>
                            <% } %>
                            <div class="dropdown-divider"></div>
                            <a class="dropdown-item" href="/logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
                        </div>
                    </div>
                <% } else { %>
                    <a class="btn btn-outline-primary btn-sm me-2" href="/login?redirect=<%= encodeURIComponent(typeof pageName !== 'undefined' && pageName ? `/view/${pageName}` : '/') %>"><i class="fas fa-sign-in-alt"></i> Login</a>
                    <a class="btn btn-primary btn-sm" href="/register"><i class="fas fa-user-plus"></i> Register</a>
                <% } %>
            </div>
        </div>
    </nav>

    <!-- JSPWiki-style navigation -->
    <div class="navigation" role="navigation">
        <div class="container-fluid">
            <!-- Flex row: left controls | title fills remaining | right actions desktop-only -->
            <div class="d-flex align-items-center">
                <!-- Left: hamburger + trail -->
                <div class="flex-shrink-0">
                    <ul class="nav nav-pills mb-0">
                        <li class="nav-item" id="menu">
                            <!-- Desktop: toggle sidebar in document flow -->
                            <button class="btn btn-outline-secondary btn-sm me-2 d-none d-md-inline-flex" onclick="toggleLeftMenu()" title="Show/Hide Sidebar">
                                <i class="fas fa-bars"></i>
                            </button>
                            <!-- Mobile: Bootstrap offcanvas -->
                            <button class="btn btn-outline-secondary btn-sm me-2 d-md-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#mobileNavOffcanvas" aria-controls="mobileNavOffcanvas" title="Show Navigation">
                                <i class="fas fa-bars"></i>
                            </button>
                        </li>
                    <% if (typeof pageName !== 'undefined' && pageName) { %>
                        <!-- Breadcrumb trail dropdown (desktop only) -->
                        <li class="nav-item dropdown d-none d-md-block" id="trail">
                            <button class="btn btn-outline-secondary btn-sm dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false" title="Navigation Trail">
                                Trail
                            </button>
                            <ul class="dropdown-menu" data-hover-parent="li" id="breadcrumbTrail">
                                <!-- Breadcrumbs will be populated by JavaScript -->
                                <li><span class="dropdown-item-text text-muted">No trail available</span></li>
                            </ul>
                        </li>
                    <% } %>
                    </ul>
                </div>

                <!-- Center: page title — flex-grow fills all remaining space -->
                <div class="flex-grow-1 text-center navigation-title px-2">
                    <% if (typeof title !== 'undefined' && title) { %>
                        <h5 class="mb-0 text-truncate"><%= title %></h5>
                    <% } else if (typeof pageName !== 'undefined' && pageName) { %>
                        <h5 class="mb-0 text-truncate"><%= pageName %></h5>
                    <% } %>
                </div>

                <!-- Right: action buttons — desktop only -->
                <div class="flex-shrink-0 d-none d-md-block">
                    <div class="btn-group float-end" role="group">
                        <!-- Edit Page Actions (only show in edit mode) -->
                        <% if (typeof title !== 'undefined' && title && title.startsWith('Edit ')) { %>
                            <button type="button" class="btn btn-outline-success btn-sm me-2" onclick="saveEditForm()">
                                <i class="fas fa-save"></i> Save Page
                            </button>
                            <a href="/view/<%= encodeURIComponent(pageName) %>" class="btn btn-outline-secondary btn-sm me-2">
                                <i class="fas fa-times"></i> Cancel
                            </a>
                            <button type="button" class="btn btn-outline-danger btn-sm me-2" onclick="deletePageFromNavbar()">
                                <i class="fas fa-trash"></i> Delete Page
                            </button>
                        <% } %>
                        
                        <!-- Info Dropdown -->
                        <div class="btn-group me-2" role="group">
                            <button type="button" class="btn btn-outline-secondary btn-sm dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="fas fa-info-circle"></i> Info
                            </button>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="#" onclick="showPageInfo()">
                                    <i class="fas fa-info"></i> Page Information
                                </a></li>
                                <li><a class="dropdown-item" href="#" onclick="showPageHistory()">
                                    <i class="fas fa-history"></i> Page History
                                </a></li>
                                <li><a class="dropdown-item" href="#" onclick="showPageSource()">
                                    <i class="fas fa-code"></i> View Page Source
                                </a></li>
                                <li><a class="dropdown-item" href="#" onclick="showPageStats(); return false;">
                                    <i class="fas fa-chart-bar"></i> Page Statistics
                                </a></li>
                                <li><a class="dropdown-item" href="/view/Recent%20Changes">
                                    <i class="fas fa-clock"></i> Recent Changes
                                </a></li>
                            </ul>
                        </div>

                        <!-- Edit Button -->
                        <% if (typeof pageName !== 'undefined' && pageName && typeof canEdit !== 'undefined' && canEdit) { %>
                            <div class="btn-group me-2" role="group">
                                <a href="/edit/<%= encodeURIComponent(pageName) %>" class="btn btn-sm" style="background-color: var(--btn-outline-primary-bg); color: var(--btn-outline-primary-text); border-color: var(--btn-outline-primary-border);">
                                    <i class="fas fa-edit"></i> Edit
                                </a>
                            </div>
                        <% } %>

                        <!-- More Dropdown -->
                        <div class="btn-group" role="group">
                            <button type="button" class="btn btn-outline-secondary btn-sm dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="fas fa-ellipsis-h"></i> More
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <% if (typeof currentUser !== 'undefined' && currentUser && currentUser.isAuthenticated && currentUser.roles && (currentUser.roles.includes('admin') || currentUser.roles.includes('editor') || currentUser.roles.includes('contributor'))) { %>
                                    <li><a class="dropdown-item" href="/create">
                                        <i class="fas fa-plus"></i> Create New Page
                                    </a></li>
                                    <li><a class="dropdown-item" href="#" onclick="showUploadAttachment()">
                                        <i class="fas fa-paperclip"></i> Upload Attachment
                                    </a></li>
                                    <li><a class="dropdown-item" href="#" onclick="openBrowseAttachments(); return false;">
                                        <i class="fas fa-folder-open"></i> Browse Attachments
                                    </a></li>
                                    <li><hr class="dropdown-divider"></li>
                                <% } %>
                                <% if (typeof pageName !== 'undefined' && pageName) { %>
                                    <li><a class="dropdown-item" href="/view/<%= encodeURIComponent(pageName) %>?view=reader">
                                        <i class="fas fa-book-reader"></i> Show Reader View
                                    </a></li>
                                <% } %>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="/export">
                                    <i class="fas fa-download"></i> Export
                                </a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Mobile navigation offcanvas (Bootstrap 5) -->
    <div class="offcanvas offcanvas-start" tabindex="-1" id="mobileNavOffcanvas" aria-labelledby="mobileNavOffcanvasLabel">
        <div class="offcanvas-header">
            <h5 class="offcanvas-title" id="mobileNavOffcanvasLabel"><%= typeof applicationName !== 'undefined' ? applicationName : 'Navigation' %></h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body">
            <!-- Search bar for mobile -->
            <form action="/search" method="GET" class="mb-3">
                <div class="input-group">
                    <input class="form-control" type="search" name="q" placeholder="Search pages...">
                    <button class="btn btn-outline-secondary" type="submit"><i class="fas fa-search"></i></button>
                </div>
            </form>
            <hr class="mt-0">

            <!-- Sidebar navigation links (populated from desktop sidebar by JS) -->
            <div id="mobile-nav-body"></div>

            <!-- Page actions (only when on a page) -->
            <% if (typeof pageName !== 'undefined' && pageName) { %>
            <hr class="my-3">
            <p class="text-muted small text-uppercase fw-semibold ps-1 mb-2">Page Actions</p>
            <nav class="nav flex-column">
                <% if (typeof canEdit !== 'undefined' && canEdit) { %>
                <a class="nav-link py-2" href="/edit/<%= encodeURIComponent(pageName) %>">
                    <i class="fas fa-edit me-2"></i> Edit Page
                </a>
                <% } %>
                <a class="nav-link py-2" href="#" onclick="showPageInfo(); bootstrap.Offcanvas.getInstance(this.closest('.offcanvas')).hide(); return false;">
                    <i class="fas fa-info me-2"></i> Page Information
                </a>
                <a class="nav-link py-2" href="#" onclick="showPageHistory(); bootstrap.Offcanvas.getInstance(this.closest('.offcanvas')).hide(); return false;">
                    <i class="fas fa-history me-2"></i> Page History
                </a>
                <a class="nav-link py-2" href="/view/<%= encodeURIComponent(pageName) %>?view=reader">
                    <i class="fas fa-book-reader me-2"></i> Reader View
                </a>
                <% if (typeof currentUser !== 'undefined' && currentUser && currentUser.isAuthenticated && currentUser.roles && (currentUser.roles.includes('admin') || currentUser.roles.includes('editor') || currentUser.roles.includes('contributor'))) { %>
                <a class="nav-link py-2" href="#" onclick="showUploadAttachment(); bootstrap.Offcanvas.getInstance(this.closest('.offcanvas')).hide(); return false;">
                    <i class="fas fa-paperclip me-2"></i> Upload Attachment
                </a>
                <a class="nav-link py-2" href="#" onclick="openBrowseAttachments(); bootstrap.Offcanvas.getInstance(this.closest('.offcanvas')).hide(); return false;">
                    <i class="fas fa-folder-open me-2"></i> Browse Attachments
                </a>
                <% } %>
            </nav>
            <% } %>

            <!-- Theme toggle at bottom of offcanvas (#377) -->
            <hr class="mt-auto mb-2">
            <button type="button"
                    class="btn btn-sm w-100 d-flex align-items-center gap-2 text-start theme-toggle-btn"
                    onclick="window.themeManager && window.themeManager.cycleTheme()"
                    title="Toggle theme">
                <i class="fas fa-adjust"></i>
                <span class="theme-label">Theme: System</span>
            </button>
        </div>
    </div>

    <div class="container-fluid">
        <div class="row">
            <nav class="col-md-2 sidebar jspwiki-sidebar">
                <div class="sidebar-sticky px-3 pt-3">
                    <% if (typeof leftMenu !== 'undefined' && leftMenu) { %>
                        <div class="leftmenu-content">
                            <%- leftMenu %>
                        </div>
                    <% } else { %>
                        <!-- Fallback if LeftMenu.md not available -->
                        <h6 class="sidebar-heading text-muted mb-3">Navigation</h6>
                        <ul class="nav flex-column">
                            <li class="nav-item">
                                <a class="nav-link" href="/">
                                    <i class="fas fa-home text-muted me-2"></i> Home
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/search">
                                    <i class="fas fa-search text-muted me-2"></i> Search
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/create">
                                    <i class="fas fa-plus text-muted me-2"></i> Create
                                </a>
                            </li>
                        </ul>
                    <% } %>

                    <!-- Theme toggle — below LeftMenu entries (#377) -->
                    <div class="border-top mt-3 pt-2">
                        <button type="button"
                                class="btn btn-sm w-100 d-flex align-items-center gap-2 text-start theme-toggle-btn"
                                onclick="window.themeManager && window.themeManager.cycleTheme()"
                                title="Toggle theme">
                            <i class="fas fa-adjust"></i>
                            <span class="theme-label">Theme: System</span>
                        </button>
                    </div>
                </div>
            </nav>

            <main role="main" class="col-12 col-md-9 col-lg-10 px-md-4 px-2 jspwiki-content main-content">

<script>
    /**
     * Copy text to clipboard. Uses the async Clipboard API where available,
     * falls back to execCommand for HTTP (non-secure) contexts.
     * Returns a Promise that resolves on success and rejects on failure.
     */
    function copyText(text) {
        if (navigator.clipboard) {
            return navigator.clipboard.writeText(text).catch(() => execCommandCopy(text));
        }
        return new Promise((resolve, reject) => {
            try { execCommandCopy(text); resolve(); } catch(e) { reject(e); }
        });
    }

    function execCommandCopy(text) {
        const el = document.createElement('textarea');
        el.value = text;
        el.style.cssText = 'position:fixed;left:-9999px;top:-9999px;opacity:0;';
        // Append inside an open modal if present, so Bootstrap's focus trap doesn't block selection
        const container = document.querySelector('.modal.show') || document.body;
        container.appendChild(el);
        el.focus();
        el.select();
        el.setSelectionRange(0, 99999);
        try {
            if (!document.execCommand('copy')) throw new Error('execCommand copy failed');
        } finally {
            container.removeChild(el);
        }
    }

    function createNewPage() {
        const pageName = prompt('Enter the name for the new page:');
        if (pageName) {
            window.location.href = `/edit/${pageName}`;
        }
    }
    
    // Holds the most recently loaded page info for use by copyPageInfo()
    let _currentPageInfo = null;

    // JSPWiki-style Info dropdown functions
    function showPageInfo() {
        // Media item page: show media info modal instead
        if (window.ngdpbaseMediaItem) {
            showMediaInfoModal(window.ngdpbaseMediaItem);
            return;
        }

        const currentPage = window.location.pathname.split('/view/')[1];
        if (!currentPage) {
            alert('No page selected for information');
            return;
        }

        const decodedPage = decodeURIComponent(currentPage);

        // Show loading modal first and wait for it to be fully rendered
        showPageInfoModal(decodedPage, null, true);

        // Fetch data immediately after modal is shown (no artificial delay)
        // Use requestAnimationFrame to ensure DOM is fully updated before fetching
        requestAnimationFrame(() => {
            // Fetch page metadata from the API
            fetch(`/api/page-metadata/${encodeURIComponent(currentPage)}`)
                .then(response => {
                    if (!response.ok) {
                        throw new Error('API not available');
                    }
                    return response.json();
                })
                .then(metadata => {
                    // Replace loading modal with actual data
                    showPageInfoModal(decodedPage, metadata, false);
                })
                .catch(error => {
                    console.warn('API fetch failed, using client-side data:', error.message);
                    // Fallback to client-side metadata extraction
                    const clientMetadata = extractClientSideMetadata(decodedPage);
                    showPageInfoModal(decodedPage, clientMetadata, false);
                });
        });
    }

    function extractClientSideMetadata(pageName) {
        // Extract basic metadata from the current page
        const content = document.querySelector('.wiki-content, .page-content, main');
        const contentText = content ? content.textContent || content.innerText || '' : '';

        // Calculate basic stats
        const wordCount = contentText.replace(/[^\w\s]/g, '').split(/\s+/).filter(word => word.length > 0).length;
        const characterCount = contentText.length;
        const lineCount = contentText.split('\n').length;

        // Try to extract title from the page
        const titleElement = document.querySelector('h1, .page-title, title');
        const title = titleElement ? titleElement.textContent.replace(' | AMD Wiki', '') : pageName;

        return {
            title: title || pageName,
            slug: pageName,
            uuid: 'Not available (client-side)',
            filesystemName: 'Not available (client-side)',
            category: 'general',
            keywords: [],
            tags: [],
            created: null,
            lastModified: null,
            lastAccessed: null,
            stats: {
                wordCount: wordCount,
                characterCount: characterCount,
                lineCount: lineCount,
                fileSize: null
            },
            author: null,
            description: null,
            version: null,
            status: 'published',
            schemaType: null,
            schemaData: null,
            custom: {}
        };
    }

    function showPageInfoModal(pageName, metadata, isLoading, errorMessage) {
        // Store for use by copyPageInfo()
        if (!isLoading && !errorMessage && metadata) {
            _currentPageInfo = { pageName, metadata };
        }

        // Clean up any existing modal completely before creating new one
        cleanupExistingModal();

        const modalContent = generatePageInfoModalContent(pageName, metadata, isLoading, errorMessage);

        // Add modal to DOM
        document.body.insertAdjacentHTML('beforeend', modalContent);

        // Show modal immediately using requestAnimationFrame for proper timing
        requestAnimationFrame(() => {
            const modalElement = document.getElementById('pageInfoModal');
            if (!modalElement) {
                console.error('Modal element not found after insertion');
                return;
            }

            const modal = new bootstrap.Modal(modalElement);

            // Clean up when modal is hidden
            modalElement.addEventListener('hidden.bs.modal', function () {
                modal.dispose();
                if (modalElement && modalElement.parentNode) {
                    modalElement.remove();
                }
            });

            modal.show();
        });
    }

    function cleanupExistingModal() {
        const existingModal = document.getElementById('pageInfoModal');
        if (existingModal) {
            // Properly dispose of Bootstrap modal instance
            const existingModalInstance = bootstrap.Modal.getInstance(existingModal);
            if (existingModalInstance) {
                existingModalInstance.dispose();
            }
            
            // Remove from DOM
            existingModal.remove();
            
            // Remove any backdrop that might be lingering
            const backdrop = document.querySelector('.modal-backdrop');
            if (backdrop) {
                backdrop.remove();
            }
            
            // Ensure body classes are cleaned up
            document.body.classList.remove('modal-open');
            document.body.style.paddingRight = '';
        }
    }

    function generatePageInfoModalContent(pageName, metadata, isLoading, errorMessage) {
        if (isLoading) {
            return `
                <div class="modal fade" id="pageInfoModal" tabindex="-1">
                    <div class="modal-dialog modal-lg">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">
                                    <i class="fas fa-info-circle"></i> Page Information: ${pageName}
                                </h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body text-center">
                                <div class="spinner-border" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                                <p class="mt-2">Loading page information...</p>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn" style="background-color: var(--btn-secondary-bg); color: var(--btn-secondary-text); border-color: var(--btn-secondary-border);" data-bs-dismiss="modal">Close</button>
                            </div>
                        </div>
                    </div>
                </div>
            `;
        }

        if (errorMessage) {
            return `
                <div class="modal fade" id="pageInfoModal" tabindex="-1">
                    <div class="modal-dialog modal-lg">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">
                                    <i class="fas fa-info-circle"></i> Page Information: ${pageName}
                                </h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <div class="alert alert-danger">
                                    <i class="fas fa-exclamation-triangle"></i>
                                    Failed to load page information: ${errorMessage}
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn" style="background-color: var(--btn-secondary-bg); color: var(--btn-secondary-text); border-color: var(--btn-secondary-border);" data-bs-dismiss="modal">Close</button>
                            </div>
                        </div>
                    </div>
                </div>
            `;
        }

        // Format dates for display
        function formatDate(dateStr) {
            if (!dateStr) return 'Not available';
            try {
                return new Date(dateStr).toLocaleString();
            } catch (e) {
                return dateStr;
            }
        }

        // Format file size for display
        function formatFileSize(bytes) {
            if (!bytes) return 'Not available';
            const sizes = ['Bytes', 'KB', 'MB', 'GB'];
            if (bytes === 0) return '0 Bytes';
            const i = Math.floor(Math.log(bytes) / Math.log(1024));
            return Math.round(bytes / Math.pow(1024, i) * 100) / 100 + ' ' + sizes[i];
        }

        // Generate keywords display
        function formatKeywords(keywords) {
            if (!keywords || keywords.length === 0) return 'None';
            return keywords.map(keyword => `<span class="badge bg-secondary me-1">${keyword}</span>`).join('');
        }

        // Generate custom metadata display
        function formatCustomMetadata(customData) {
            if (!customData || Object.keys(customData).length === 0) return '';

            let customRows = '';
            for (const [key, value] of Object.entries(customData)) {
                customRows += `<tr><td><strong>${key}:</strong></td><td>${value}</td></tr>`;
            }

            return customRows ? `
                <tr><td colspan="2" class="table-warning"><strong>Custom Metadata</strong></td></tr>
                ${customRows}
            ` : '';
        }

        return `
            <div class="modal fade" id="pageInfoModal" tabindex="-1">
                <div class="modal-dialog modal-xl">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">
                                <i class="fas fa-info-circle"></i> Page Information: ${metadata.title || pageName}
                            </h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <h6><i class="fas fa-file-alt"></i> Basic Information</h6>
                                    <table class="table table-bordered table-sm">
                                        <tr><td><strong>Title:</strong></td><td>${metadata.title || 'Untitled'}</td></tr>
                                        <tr><td><strong>Page Name:</strong></td><td>${pageName}</td></tr>
                                        <tr><td><strong>Slug:</strong></td><td>${metadata.slug || 'Not set'}</td></tr>
                                        <tr><td><strong>UUID:</strong></td><td><code class="small">${metadata.uuid || 'Not available'}</code></td></tr>
                                        <tr><td><strong>Filesystem Name:</strong></td><td><code class="small">${metadata.filesystemName || 'Not available'}</code></td></tr>
                                        <tr><td><strong>System Category:</strong></td><td><span class="badge bg-primary">${metadata.category}</span></td></tr>
                                        <tr><td><strong>Status:</strong></td><td><span class="badge bg-success">${metadata.status}</span></td></tr>
                                        <tr><td><strong>URL:</strong></td><td><small>${window.location.href}</small></td></tr>
                                    </table>

                                    <h6><i class="fas fa-tags"></i> Classification</h6>
                                    <table class="table table-bordered table-sm">
                                        <tr><td><strong>User Keywords:</strong></td><td>${formatKeywords(metadata.keywords)}</td></tr>
                                        <tr><td><strong>Author:</strong></td><td>${metadata.author || 'Not specified'}</td></tr>
                                        <tr><td><strong>Editor:</strong></td><td>${metadata.editor || 'Not specified'}</td></tr>
                                        <tr><td><strong>Description:</strong></td><td>${metadata.description || 'No description available'}</td></tr>
                                        <tr><td><strong>Version:</strong></td><td>${metadata.version || 'Not versioned'}</td></tr>
                                    </table>
                                </div>

                                <div class="col-md-6">
                                    <h6><i class="fas fa-clock"></i> Timestamps</h6>
                                    <table class="table table-bordered table-sm">
                                        <tr><td><strong>Created:</strong></td><td>${formatDate(metadata.created)}</td></tr>
                                        <tr><td><strong>Last Modified:</strong></td><td>${formatDate(metadata.lastModified)}</td></tr>
                                        <tr><td><strong>Last Accessed:</strong></td><td>${formatDate(metadata.lastAccessed)}</td></tr>
                                    </table>

                                    <h6><i class="fas fa-chart-bar"></i> Content Statistics</h6>
                                    <table class="table table-bordered table-sm">
                                        <tr><td><strong>Word Count:</strong></td><td>${metadata.stats.wordCount || 0} words</td></tr>
                                        <tr><td><strong>Character Count:</strong></td><td>${metadata.stats.characterCount || 0} characters</td></tr>
                                        <tr><td><strong>Line Count:</strong></td><td>${metadata.stats.lineCount || 0} lines</td></tr>
                                        <tr><td><strong>File Size:</strong></td><td>${formatFileSize(metadata.stats.fileSize)}</td></tr>
                                    </table>

                                    ${metadata.schemaType ? `
                                        <h6><i class="fas fa-code"></i> Schema.org Data</h6>
                                        <table class="table table-bordered table-sm">
                                            <tr><td><strong>Schema Type:</strong></td><td><code>${metadata.schemaType}</code></td></tr>
                                            <tr><td><strong>Structured Data:</strong></td><td>${metadata.schemaData ? 'Available' : 'None'}</td></tr>
                                        </table>
                                    ` : ''}
                                </div>
                            </div>

                            ${Object.keys(metadata.custom).length > 0 ? `
                                <div class="row mt-3">
                                    <div class="col-12">
                                        <h6><i class="fas fa-cogs"></i> Additional Metadata</h6>
                                        <table class="table table-bordered table-sm">
                                            ${formatCustomMetadata(metadata.custom)}
                                        </table>
                                    </div>
                                </div>
                            ` : ''}
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-outline-primary btn-sm" onclick="copyPageInfo()">
                                <i class="fas fa-copy"></i> Copy Information
                            </button>
                            <button type="button" class="btn" style="background-color: var(--btn-secondary-bg); color: var(--btn-secondary-text); border-color: var(--btn-secondary-border);" data-bs-dismiss="modal">Close</button>
                        </div>
                    </div>
                </div>
            </div>
        `;
    }

    function copyPageInfo() {
        if (!_currentPageInfo) {
            showTemporaryMessage('No page information available', 'error');
            return;
        }
        const { pageName, metadata } = _currentPageInfo;

        function fmtDate(d) {
            if (!d) return 'Not available';
            try { return new Date(d).toLocaleString(); } catch(e) { return d; }
        }

        const lines = [
            `Title:         ${metadata.title || pageName}`,
            `Page Name:     ${pageName}`,
            `Slug:          ${metadata.slug || 'Not set'}`,
            `UUID:          ${metadata.uuid || 'Not available'}`,
            `Version:       ${metadata.version || 'Not versioned'}`,
            `URL:           ${window.location.href}`,
            `Created:       ${fmtDate(metadata.created)}`,
            `Last Modified: ${fmtDate(metadata.lastModified)}`,
            `Last Accessed: ${fmtDate(metadata.lastAccessed)}`,
        ];
        if (metadata.author) lines.push(`Author:        ${metadata.author}`);
        if (metadata.editor) lines.push(`Editor:        ${metadata.editor}`);
        if (metadata.category) lines.push(`Category:      ${metadata.category}`);
        if (metadata.keywords?.length) lines.push(`User Keywords: ${metadata.keywords.join(', ')}`);

        const text = lines.join('\n');

        copyText(text)
            .then(() => showTemporaryMessage('Page information copied to clipboard!', 'success'))
            .catch(() => showTemporaryMessage('Failed to copy information', 'error'));
    }

    function showMediaInfoModal(item) {
        cleanupExistingModal();

        function fmtSize(bytes) {
            if (!bytes) return 'Not available';
            const kb = Math.round(Number(bytes) / 1024);
            return kb >= 1024 ? (kb / 1024).toFixed(2) + ' MB' : kb + ' KB';
        }

        const itemUrl = `/media/item/${item.id}`;
        const keywords = Array.isArray(item.keywords) ? item.keywords : [];
        function kwSyntax(kw) {
            const q = String(kw).includes("'") ? '"' : "'";
            return `[{MediaPlugin format='list' keyword=${q}${kw}${q}}]`;
        }
        const pluginSyntaxRows = keywords.length > 0
            ? keywords.map(kw => {
                const syn = kwSyntax(kw);
                const safeKw = String(kw).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/"/g,'&quot;');
                const safeSyn = syn.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/"/g,'&quot;');
                return `<tr><td><strong>Plugin Syntax</strong><br><small class="text-white-50">${safeKw}</small></td><td><code class="small">${safeSyn}</code> <button class="btn btn-sm btn-outline-secondary py-0 px-1" title="Copy" data-syn="${safeSyn}" onclick="copyText(this.dataset.syn)"><i class="fas fa-copy"></i></button></td></tr>`;
              }).join('')
            : `<tr><td><strong>Plugin Syntax</strong></td><td><code class="small">[{MediaPlugin format='list' keyword='current'}]</code> <button class="btn btn-sm btn-outline-secondary py-0 px-1" title="Copy" onclick="copyText(&quot;[{MediaPlugin format=&apos;list&apos; keyword=&apos;current&apos;}]&quot;)"><i class="fas fa-copy"></i></button></td></tr>`;

        const modalHtml = `
            <div class="modal fade" id="pageInfoModal" tabindex="-1">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title"><i class="fas fa-info-circle"></i> Media Information: ${item.filename}</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <table class="table table-bordered table-sm">
                                <tr>
                                    <td style="width:35%"><strong>Item ID</strong></td>
                                    <td><code class="small">${item.id}</code>
                                        <button class="btn btn-sm btn-outline-secondary ms-1 py-0 px-1" title="Copy" onclick="copyText('${item.id}')"><i class="fas fa-copy"></i></button>
                                    </td>
                                </tr>
                                <tr>
                                    <td><strong>URL</strong></td>
                                    <td><code class="small">${itemUrl}</code>
                                        <button class="btn btn-sm btn-outline-secondary ms-1 py-0 px-1" title="Copy" onclick="copyText(window.location.origin + '${itemUrl}')"><i class="fas fa-copy"></i></button>
                                    </td>
                                </tr>
                                ${pluginSyntaxRows}
                                ${item.filePath ? `
                                <tr>
                                    <td><strong>File Path</strong></td>
                                    <td><code class="small" style="word-break:break-all">${item.filePath}</code>
                                        <button class="btn btn-sm btn-outline-secondary ms-1 py-0 px-1" title="Copy" data-copy="${item.filePath.replace(/"/g, '&quot;')}" onclick="copyText(this.dataset.copy)"><i class="fas fa-copy"></i></button>
                                    </td>
                                </tr>` : ''}
                                ${(item.imageWidth && item.imageHeight) ? `
                                <tr>
                                    <td><strong>Dimensions</strong></td>
                                    <td>${item.imageWidth} &times; ${item.imageHeight}</td>
                                </tr>` : ''}
                                ${item.fileSize ? `
                                <tr>
                                    <td><strong>File Size</strong></td>
                                    <td>${fmtSize(item.fileSize)}</td>
                                </tr>` : ''}
                            </table>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
                        </div>
                    </div>
                </div>
            </div>`;

        document.body.insertAdjacentHTML('beforeend', modalHtml);
        requestAnimationFrame(() => {
            const el = document.getElementById('pageInfoModal');
            if (!el) return;
            const modal = new bootstrap.Modal(el);
            el.addEventListener('hidden.bs.modal', function () {
                modal.dispose();
                if (el.parentNode) el.remove();
            });
            modal.show();
        });
    }

    function showTemporaryMessage(message, type) {
        const alertClass = type === 'success' ? 'alert-success' : 'alert-danger';
        const iconClass = type === 'success' ? 'fas fa-check-circle' : 'fas fa-exclamation-circle';

        const alertDiv = document.createElement('div');
        alertDiv.className = `alert ${alertClass} alert-dismissible fade show position-fixed`;
        alertDiv.style.cssText = 'top: 20px; right: 20px; z-index: 9999; min-width: 300px;';
        alertDiv.innerHTML = `
            <i class="${iconClass}"></i> ${message}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        `;

        document.body.appendChild(alertDiv);

        // Auto-remove after 3 seconds
        setTimeout(() => {
            if (alertDiv.parentNode) {
                alertDiv.remove();
            }
        }, 3000);
    }
    
    function showPageHistory() {
        const currentPage = window.location.pathname.split('/view/')[1] || window.location.pathname.split('/edit/')[1];
        if (!currentPage) {
            alert('No page selected for history view');
            return;
        }
        window.location.href = `/history/${encodeURIComponent(currentPage)}`;
    }
    
    function showPageStats() {
        const currentPage = window.location.pathname.split('/view/')[1];
        if (!currentPage) {
            alert('No page selected for statistics');
            return;
        }
        const decodedPage = decodeURIComponent(currentPage);

        // Show loading modal first
        showPageStatsModal(decodedPage, null, true);

        requestAnimationFrame(() => {
            fetch(`/api/page-metadata/${encodeURIComponent(currentPage)}`)
                .then(response => {
                    if (!response.ok) throw new Error('API not available');
                    return response.json();
                })
                .then(metadata => {
                    showPageStatsModal(decodedPage, metadata, false);
                })
                .catch(error => {
                    console.warn('Stats fetch failed:', error.message);
                    showPageStatsModal(decodedPage, null, false, error.message);
                });
        });
    }

    function showPageStatsModal(pageName, metadata, isLoading, errorMessage) {
        // Clean up existing stats modal
        const existing = document.getElementById('pageStatsModal');
        if (existing) {
            const inst = bootstrap.Modal.getInstance(existing);
            if (inst) inst.dispose();
            existing.remove();
            const backdrop = document.querySelector('.modal-backdrop');
            if (backdrop) backdrop.remove();
            document.body.classList.remove('modal-open');
            document.body.style.paddingRight = '';
        }

        let bodyHtml;
        if (isLoading) {
            bodyHtml = `<div class="text-center py-4">
                <div class="spinner-border" role="status"><span class="visually-hidden">Loading...</span></div>
                <p class="mt-2">Loading statistics...</p></div>`;
        } else if (errorMessage || !metadata) {
            bodyHtml = `<div class="alert alert-danger"><i class="fas fa-exclamation-triangle"></i> Failed to load statistics: ${errorMessage || 'Unknown error'}</div>`;
        } else {
            const s = metadata.stats || {};
            const vi = metadata.versionInfo || {};
            const contributors = metadata.contributors || [];

            function fmtNum(n) { return (n != null) ? n.toLocaleString() : '—'; }
            function fmtDate(d) { return d ? new Date(d).toLocaleString() : '—'; }
            function fmtSize(b) {
                if (!b) return '—';
                const units = ['B','KB','MB','GB'];
                const i = Math.floor(Math.log(b) / Math.log(1024));
                return (b / Math.pow(1024, i)).toFixed(1) + ' ' + units[i];
            }

            const contributorRows = contributors.length
                ? contributors.map(c => `<tr><td>${c.author}</td><td class="text-end">${c.editCount}</td></tr>`).join('')
                : '<tr><td colspan="2" class="text-muted">No version history</td></tr>';

            const avgFreq = metadata.avgDaysBetweenEdits != null
                ? `${metadata.avgDaysBetweenEdits} days/edit`
                : '—';

            bodyHtml = `
                <div class="row g-3">
                    <div class="col-md-6">
                        <h6><i class="fas fa-align-left"></i> Content</h6>
                        <table class="table table-bordered table-sm">
                            <tr><td>Words</td><td class="text-end fw-bold">${fmtNum(s.wordCount)}</td></tr>
                            <tr><td>Characters</td><td class="text-end">${fmtNum(s.characterCount)}</td></tr>
                            <tr><td>Lines</td><td class="text-end">${fmtNum(s.lineCount)}</td></tr>
                            <tr><td>File size</td><td class="text-end">${fmtSize(s.fileSize)}</td></tr>
                        </table>
                        <h6 class="mt-3"><i class="fas fa-link"></i> Links &amp; References</h6>
                        <table class="table table-bordered table-sm">
                            <tr><td>Internal links</td><td class="text-end fw-bold">${fmtNum(s.internalLinks)}</td></tr>
                            <tr><td>External links</td><td class="text-end">${fmtNum(s.externalLinks)}</td></tr>
                            <tr><td>Attachment refs</td><td class="text-end">${fmtNum(s.attachmentRefs)}</td></tr>
                        </table>
                    </div>
                    <div class="col-md-6">
                        <h6><i class="fas fa-history"></i> Revisions</h6>
                        <table class="table table-bordered table-sm">
                            <tr><td>Total revisions</td><td class="text-end fw-bold">${fmtNum(vi.totalVersions)}</td></tr>
                            <tr><td>Last modified</td><td class="text-end">${fmtDate(metadata.lastModified)}</td></tr>
                            <tr><td>Last editor</td><td class="text-end">${metadata.editor || '—'}</td></tr>
                            <tr><td>Avg frequency</td><td class="text-end">${avgFreq}</td></tr>
                        </table>
                        <h6 class="mt-3"><i class="fas fa-users"></i> Top Contributors</h6>
                        <table class="table table-bordered table-sm">
                            <thead><tr><th>Author</th><th class="text-end">Edits</th></tr></thead>
                            <tbody>${contributorRows}</tbody>
                        </table>
                    </div>
                </div>`;
        }

        const modalHtml = `
            <div class="modal fade" id="pageStatsModal" tabindex="-1">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title"><i class="fas fa-chart-bar"></i> Page Statistics: ${pageName}</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">${bodyHtml}</div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
                        </div>
                    </div>
                </div>
            </div>`;

        document.body.insertAdjacentHTML('beforeend', modalHtml);
        requestAnimationFrame(() => {
            const el = document.getElementById('pageStatsModal');
            if (!el) return;
            const modal = new bootstrap.Modal(el);
            el.addEventListener('hidden.bs.modal', () => { modal.dispose(); el.remove(); });
            modal.show();
        });
    }
    
    // View Page Source functionality
    function showPageSource() {
        const currentPage = window.location.pathname.split('/view/')[1];
        if (!currentPage) {
            alert('No page selected for source view');
            return;
        }
        
        // Fetch the raw markdown content
        fetch(`/api/page-source/${encodeURIComponent(currentPage)}`)
            .then(response => {
                if (!response.ok) {
                    throw new Error('Failed to fetch page source');
                }
                return response.text();
            })
            .then(sourceContent => {
                showSourceModal(sourceContent, decodeURIComponent(currentPage));
            })
            .catch(error => {
                console.error('Error:', error);
                // Fallback - try to get content from current page
                const contentElement = document.querySelector('.page-content, .wiki-content, main');
                const fallbackContent = contentElement ? contentElement.textContent : 'Could not retrieve page source';
                showSourceModal(fallbackContent, decodeURIComponent(currentPage || 'Unknown'));
            });
    }
    
    function showSourceModal(sourceContent, pageName) {
        const sourceModal = `
            <div class="modal fade" id="pageSourceModal" tabindex="-1">
                <div class="modal-dialog modal-xl">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">
                                <i class="fas fa-code"></i> Page Source: ${pageName}
                            </h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <div class="mb-3">
                                <button id="copyButton" class="btn btn-sm" style="background-color: var(--btn-outline-primary-bg); color: var(--btn-outline-primary-text); border-color: var(--btn-outline-primary-border);">
                                    <i class="fas fa-copy"></i> Copy to Clipboard
                                </button>
                            </div>
                            <pre id="sourceContent" class="p-3 border rounded" style="max-height: 500px; overflow-y: auto; white-space: pre-wrap; background-color: var(--code-bg); color: var(--style="color: var(--text-primary);");">${escapeHtml(sourceContent)}</pre>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn" style="background-color: var(--btn-secondary-bg); color: var(--btn-secondary-text); border-color: var(--btn-secondary-border);" data-bs-dismiss="modal">Close</button>
                        </div>
                    </div>
                </div>
            </div>
        `;
        
        // Remove existing modal if any
        const existingModal = document.getElementById('pageSourceModal');
        if (existingModal) existingModal.remove();
        
        // Add modal to DOM
        document.body.insertAdjacentHTML('beforeend', sourceModal);
        
        // Add event listener for copy button
        const copyButton = document.getElementById('copyButton');
        if (copyButton) {
            copyButton.addEventListener('click', copySourceToClipboard);
        }
        
        // Show modal
        const modal = new bootstrap.Modal(document.getElementById('pageSourceModal'));
        modal.show();
    }
    
    function copySourceToClipboard(event) {
        const sourceContent = document.getElementById('sourceContent').textContent;
        const btn = event ? event.target.closest('button') : document.getElementById('copyButton');
        
        if (!btn) {
            console.error('Copy button not found');
            return;
        }
        
        const originalText = btn.innerHTML;
        
        // Function to show success feedback
        function showSuccess() {
            btn.innerHTML = '<i class="fas fa-check"></i> Copied!';
            btn.classList.remove('btn-outline-primary');
            btn.classList.add('btn-success');
            
            setTimeout(() => {
                btn.innerHTML = originalText;
                btn.classList.remove('btn-success');
                btn.classList.add('btn-outline-primary');
            }, 2000);
        }
        
        // Function to show error feedback
        function showError(errorMsg) {
            console.error('Failed to copy: ', errorMsg);
            btn.innerHTML = '<i class="fas fa-times"></i> Failed';
            btn.classList.remove('btn-outline-primary');
            btn.classList.add('btn-danger');
            
            setTimeout(() => {
                btn.innerHTML = originalText;
                btn.classList.remove('btn-danger');
                btn.classList.add('btn-outline-primary');
            }, 2000);
        }
        
        copyText(sourceContent).then(showSuccess).catch(err => {
            showError(err.message);
            showManualCopyInstructions();
        });
        
        function showManualCopyInstructions() {
            const modal = document.createElement('div');
            modal.innerHTML = `
                <div class="modal fade" id="copyInstructionsModal" tabindex="-1">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">Manual Copy Required</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <p><strong>Automatic copy failed.</strong> Please manually copy the content:</p>
                                <ol>
                                    <li>Click in the source code area above</li>
                                    <li>Select all text (<kbd>Ctrl+A</kbd> or <kbd>Cmd+A</kbd>)</li>
                                    <li>Copy the selected text (<kbd>Ctrl+C</kbd> or <kbd>Cmd+C</kbd>)</li>
                                </ol>
                                <p class="text-muted">This may happen in some browsers due to security restrictions.</p>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn" style="background-color: var(--btn-secondary-bg); color: var(--btn-secondary-text); border-color: var(--btn-secondary-border);" data-bs-dismiss="modal">Close</button>
                            </div>
                        </div>
                    </div>
                </div>
            `;
            document.body.appendChild(modal);
            const instructionsModal = new bootstrap.Modal(document.getElementById('copyInstructionsModal'));
            instructionsModal.show();
            
            // Remove modal when closed
            document.getElementById('copyInstructionsModal').addEventListener('hidden.bs.modal', function () {
                document.body.removeChild(modal);
            });
        }
    }
    
    function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }
    
    // Highlight active navigation links
    document.addEventListener('DOMContentLoaded', function() {
        const currentPath = window.location.pathname;
        const navLinks = document.querySelectorAll('.navigation .nav-link');
        
        navLinks.forEach(link => {
            const href = link.getAttribute('href');
            if (href && currentPath.includes(href) && href !== '/') {
                link.classList.add('active');
            }
        });
    });
</script>

<!-- Theme Manager -->
<script>
// Theme manager — uses Bootstrap-native data-bs-theme on <html>
class SimpleThemeManager {
    constructor() {
        this.themes = ['light', 'dark', 'system'];
        this.currentTheme = localStorage.getItem('theme-preference') || 'system';
        this.systemTheme = this.getSystemTheme();

        this.applyTheme();
        this.updateButtons();

        // Listen for OS theme changes
        if (window.matchMedia) {
            window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
                this.systemTheme = e.matches ? 'dark' : 'light';
                if (this.currentTheme === 'system') {
                    this.applyTheme();
                    this.updateButtons();
                }
            });
        }
    }
    
    getSystemTheme() {
        if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
            return 'dark';
        }
        return 'light';
    }
    
    getEffectiveTheme() {
        if (this.currentTheme === 'system') {
            return this.systemTheme;
        }
        return this.currentTheme;
    }
    
    applyTheme() {
        const effectiveTheme = this.getEffectiveTheme();
        const html = document.documentElement;
        // Bootstrap-native: data-bs-theme drives Bootstrap components AND our CSS vars
        html.setAttribute('data-bs-theme', effectiveTheme);
    }
    
    cycleTheme() {
        const currentIndex = this.themes.indexOf(this.currentTheme);
        this.currentTheme = this.themes[(currentIndex + 1) % this.themes.length];
        localStorage.setItem('theme-preference', this.currentTheme);
        this.applyTheme();
        this.updateButtons();
    }

    updateButtons() {
        const effectiveTheme = this.getEffectiveTheme();
        let iconClass, title;
        switch (this.currentTheme) {
            case 'light':
                iconClass = 'fas fa-sun';
                title = 'Theme: Light — click for Dark';
                break;
            case 'dark':
                iconClass = 'fas fa-moon';
                title = 'Theme: Dark — click for System';
                break;
            default:
                iconClass = 'fas fa-adjust';
                title = `Theme: System (${effectiveTheme}) — click for Light`;
        }
        // Update all theme toggle buttons (sidebar + offcanvas)
        document.querySelectorAll('.theme-toggle-btn').forEach(btn => {
            const icon = btn.querySelector('i');
            const label = btn.querySelector('.theme-label');
            if (icon) icon.className = iconClass;
            if (label) label.textContent = title.split(' — ')[0];
            btn.title = title;
        });
    }
}

// Initialize when DOM is ready
document.addEventListener('DOMContentLoaded', () => {
    window.themeManager = new SimpleThemeManager();
    // updateButtons runs after DOM is ready so sidebar/offcanvas buttons exist
    window.themeManager.updateButtons();
    
    // Check for user changes and server restarts
    checkUserChange();
    checkServerRestart();
    
    // Initialize left menu state
    initializeLeftMenuState();
    
    // Initialize breadcrumb trail
    initializeTrail();
});

// Left menu toggle (desktop only — mobile uses Bootstrap offcanvas via data-bs-toggle)
function toggleLeftMenu() {
    var sidebar = document.querySelector('.sidebar');
    var mainContent = document.querySelector('main');
    if (!sidebar) return;

    var isHidden = sidebar.style.display === 'none';
    if (isHidden) {
        sidebar.style.display = '';
        if (mainContent) {
            // Restore responsive column classes — col-12 base stays, col-md-9 overrides at md+
            mainContent.classList.add('col-md-9', 'col-lg-10');
        }
        localStorage.setItem('leftMenuVisible', 'true');
    } else {
        sidebar.style.display = 'none';
        if (mainContent) {
            // Remove responsive overrides — col-12 base gives 100% width
            mainContent.classList.remove('col-md-9', 'col-lg-10');
        }
        localStorage.setItem('leftMenuVisible', 'false');
    }
}

// Initialize left menu state from localStorage
// Populate mobile offcanvas with sidebar content, then apply desktop preference
function initializeLeftMenuState() {
    // Copy sidebar content into offcanvas for mobile use
    var sidebarBody = document.querySelector('.sidebar .sidebar-sticky');
    var offcanvasBody = document.getElementById('mobile-nav-body');
    if (sidebarBody && offcanvasBody) {
        offcanvasBody.innerHTML = sidebarBody.innerHTML;
    }

    // Desktop: restore saved preference (sidebar visible by default)
    if (window.innerWidth >= 768) {
        var isVisible = localStorage.getItem('leftMenuVisible');
        if (isVisible === 'false') {
            var sidebar = document.querySelector('.sidebar');
            var mainContent = document.querySelector('main');
            if (sidebar) sidebar.style.display = 'none';
            if (mainContent) {
                // col-12 is the base class — just remove responsive overrides
                mainContent.classList.remove('col-md-9', 'col-lg-10');
            }
        }
    }
}

// Breadcrumb trail management
let navigationTrail = JSON.parse(localStorage.getItem('navigationTrail') || '[]');

// Clear trail function
function clearTrail() {
    navigationTrail = [];
    localStorage.removeItem('navigationTrail');
    updateTrailDropdown();
}

// Check if user has changed (for clearing trail on user switch)
function checkUserChange() {
    const currentUserInfo = '<%= typeof currentUser !== "undefined" && currentUser ? currentUser.username || "anonymous" : "anonymous" %>';
    const lastUser = localStorage.getItem('lastUser');
    
    if (lastUser && lastUser !== currentUserInfo) {
        // User has changed, clear the trail
        clearTrail();
    }
    
    // Store current user
    localStorage.setItem('lastUser', currentUserInfo);
}

// Check if server has restarted (simple timestamp check)
function checkServerRestart() {
    const serverStartTime = '<%= Date.now() %>';
    const lastServerTime = localStorage.getItem('lastServerTime');
    
    if (lastServerTime && Math.abs(serverStartTime - lastServerTime) > 300000) { // 5 minutes difference
        // Server likely restarted, clear trail
        clearTrail();
    }
    
    localStorage.setItem('lastServerTime', serverStartTime);
}

function addToTrail(pageName, pageTitle) {
    // Don't add the same page consecutively 
    if (navigationTrail.length > 0 && navigationTrail[0].page === pageName) {
        return;
    }
    
    // Remove any existing entry for this page from anywhere in the trail
    navigationTrail = navigationTrail.filter(item => item.page !== pageName);
    
    // Use pageName if pageTitle is not provided or is generic
    const displayTitle = (pageTitle && pageTitle !== 'Markdown Wiki' && pageTitle !== pageName) ? pageTitle : pageName;
    
    // Add to beginning of trail
    navigationTrail.unshift({
        page: pageName,
        title: displayTitle,
        timestamp: Date.now()
    });
    
    // Keep only last 10 entries
    navigationTrail = navigationTrail.slice(0, 10);
    
    // Save to localStorage
    localStorage.setItem('navigationTrail', JSON.stringify(navigationTrail));
    
    // Debug log
    console.log('Added to trail:', pageName, 'as', displayTitle);
    
    // Update dropdown
    updateTrailDropdown();
}

function updateTrailDropdown() {
    const dropdown = document.getElementById('breadcrumbTrail');
    if (!dropdown) return;
    
    dropdown.innerHTML = '';
    
    // Get current page to exclude it from trail
    const currentPage = window.location.pathname.split('/view/')[1];
    const currentPageDecoded = currentPage ? decodeURIComponent(currentPage) : null;
    
    // Show only trail items (excluding current page)
    const trailItemsToShow = navigationTrail.filter(item => 
        !currentPageDecoded || item.page !== currentPageDecoded
    );
    
    if (trailItemsToShow.length === 0) {
        dropdown.innerHTML = '<li><span class="dropdown-item-text text-muted">No trail available</span></li>';
        return;
    }
    
    trailItemsToShow.forEach((item, index) => {
        const li = document.createElement('li');
        const a = document.createElement('a');
        a.className = 'dropdown-item';
        a.href = `/view/${encodeURIComponent(item.page)}`;
        
        // Use the page name from the URL, not a potentially generic title
        const displayName = item.page; // Always use the actual page name
        a.innerHTML = `<i class="fas fa-file-alt me-2"></i>${displayName}`;
        
        // Add time indicator for recent items
        const timeDiff = Date.now() - item.timestamp;
        if (timeDiff < 300000) { // Less than 5 minutes
            a.innerHTML += ' <small class="text-muted">(recent)</small>';
        }
        
        li.appendChild(a);
        dropdown.appendChild(li);
    });
    
    // Add separator and clear option if there are items
    if (trailItemsToShow.length > 0) {
        const separator = document.createElement('li');
        separator.innerHTML = '<hr class="dropdown-divider">';
        dropdown.appendChild(separator);
        
        const clearLi = document.createElement('li');
        const clearA = document.createElement('a');
        clearA.className = 'dropdown-item style="color: var(--text-danger);"';
        clearA.href = '#';
        clearA.innerHTML = '<i class="fas fa-trash me-2"></i>Clear Trail';
        clearA.onclick = (e) => {
            e.preventDefault();
            clearTrail();
        };
        clearLi.appendChild(clearA);
        dropdown.appendChild(clearLi);
    }
}

// Initialize trail on page load
function initializeTrail() {
    const currentPage = window.location.pathname.split('/view/')[1];
    if (!currentPage) {
        updateTrailDropdown();
        return;
    }
    
    const currentPageDecoded = decodeURIComponent(currentPage);
    // Use the page name from URL, not the document title
    const pageName = currentPageDecoded;
    
    // Only add to trail if it's a different page than the last one visited
    if (navigationTrail.length === 0 || navigationTrail[0].page !== currentPageDecoded) {
        addToTrail(currentPageDecoded, pageName);
    } else {
        // Just update the dropdown without adding
        updateTrailDropdown();
    }
}

// Edit form functions for navbar buttons
function saveEditForm() {
    console.log('saveEditForm() called from navbar');
    const editForm = document.getElementById('editForm');
    if (editForm) {
        console.log('Edit form found, triggering validation and submission...');

        // Validate system-category (only if field exists - admin users only)
        const systemCategoryElement = document.getElementById('systemCategory');
        if (systemCategoryElement) {
            const systemCategory = systemCategoryElement.value;
            if (!systemCategory) {
                console.log('Validation failed: no system category');
                alert('System category is required');
                return false;
            }
            console.log('System category:', systemCategory);
        } else {
            console.log('System category field not found (non-admin user)');
        }

        // Validate user-keywords (get max from form or use default)
        const maxUserKeywords = 5; // Default value, should match server-side
        const checkedKeywords = document.querySelectorAll('.user-keyword-checkbox:checked').length;
        if (checkedKeywords > maxUserKeywords) {
            console.log('Validation failed: too many keywords');
            alert('Maximum ' + maxUserKeywords + ' user keywords allowed');
            return false;
        }

        console.log('Validation passed, submitting form...');
        console.log('Form action:', editForm.action);
        console.log('Form method:', editForm.method);
        console.log('Form elements:', editForm.elements.length);
        editForm.submit();
    } else {
        console.error('Edit form not found!');
    }
}

function deletePageFromNavbar() {
    if (confirm('Are you sure you want to delete this page? This action cannot be undone.')) {
        // Check if we're on an edit page by looking at the URL path
        const path = window.location.pathname;

        if (path.startsWith('/edit/')) {
            const pageName = decodeURIComponent(path.replace('/edit/', ''));

            // Use POST request as required by the route
            fetch('/delete/' + encodeURIComponent(pageName), {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Accept': 'application/json'
                }
            }).then(response => response.json())
            .then(data => {
                if (data.success) {
                    // Redirect to home page after successful deletion
                    window.location.href = data.redirect || '/';
                } else {
                    alert('Error deleting page: ' + (data.error || 'Unknown error'));
                }
            }).catch(error => {
                alert('Error deleting page: ' + error.message);
            });
        } else {
            alert('Can only delete from edit page');
        }
    }
}

function openBrowseAttachments() {
    // Check if we're on the edit page
    const isEditPage = window.location.pathname.startsWith('/edit/');

    if (isEditPage) {
        // Open as popup so we can insert into editor
        const popup = window.open(
            '/attachments/browse?mode=insert',
            'browseAttachments',
            'width=900,height=700,scrollbars=yes,resizable=yes'
        );
        if (popup) popup.focus();
    } else {
        // Normal navigation
        window.location.href = '/attachments/browse';
    }
}

function showUploadAttachment() {
    const currentPage = window.location.pathname.split('/view/')[1];
    if (!currentPage) {
        alert('Please navigate to a page first before uploading attachments');
        return;
    }

    const decodedPage = decodeURIComponent(currentPage);

    // Create upload modal
    const modalHTML = `
        <div class="modal fade" id="uploadAttachmentModal" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title"><i class="fas fa-paperclip"></i> Upload Attachment to ${decodedPage}</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="attachmentFile" class="form-label">Select File:</label>
                            <input type="file" class="form-control" id="attachmentFile">
                        </div>
                        <div class="mb-3">
                            <label for="attachmentDescription" class="form-label">Description:</label>
                            <input type="text" class="form-control" id="attachmentDescription" placeholder="Brief description of the file">
                        </div>
                        <div id="uploadStatus"></div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-primary" onclick="uploadAttachmentFile('${decodedPage}')">
                            <i class="fas fa-upload"></i> Upload
                        </button>
                    </div>
                </div>
            </div>
        </div>
    `;

    // Remove existing modal if present
    const existing = document.getElementById('uploadAttachmentModal');
    if (existing) {
        existing.remove();
    }

    // Add modal to page
    document.body.insertAdjacentHTML('beforeend', modalHTML);

    // Show modal
    const modal = new bootstrap.Modal(document.getElementById('uploadAttachmentModal'));
    modal.show();

    // Auto-populate description with filename when file is selected
    document.getElementById('attachmentFile').addEventListener('change', function() {
        const descInput = document.getElementById('attachmentDescription');
        if (this.files[0] && !descInput.value) {
            descInput.value = this.files[0].name;
        }
    });

    // Clean up when closed
    document.getElementById('uploadAttachmentModal').addEventListener('hidden.bs.modal', function () {
        this.remove();
    });
}

async function uploadAttachmentFile(pageName) {
    const fileInput = document.getElementById('attachmentFile');
    const description = document.getElementById('attachmentDescription').value;
    const statusDiv = document.getElementById('uploadStatus');

    if (!fileInput.files[0]) {
        statusDiv.innerHTML = '<div class="alert alert-warning">Please select a file first.</div>';
        return;
    }

    const formData = new FormData();
    formData.append('file', fileInput.files[0]);
    formData.append('description', description);

    statusDiv.innerHTML = '<div class="alert alert-info">Uploading...</div>';

    try {
        const response = await fetch(`/attachments/upload/${encodeURIComponent(pageName)}`, {
            method: 'POST',
            body: formData
        });

        const result = await response.json();

        if (result.success) {
            statusDiv.innerHTML = `
                <div class="alert alert-success">
                    <strong>Upload successful!</strong><br>
                    <small>Attachment ID: ${result.attachmentId}</small><br>
                    <small>URL: <code>${result.url}</code></small><br>
                    <button type="button" class="btn btn-sm btn-primary mt-2" onclick="copyToClipboard('${result.url}')">
                        Copy URL
                    </button>
                </div>
            `;

            // Reload page after 2 seconds to show the attachment
            setTimeout(() => {
                location.reload();
            }, 2000);
        } else {
            statusDiv.innerHTML = `<div class="alert alert-danger">Upload failed: ${result.error}</div>`;
        }
    } catch (error) {
        statusDiv.innerHTML = `<div class="alert alert-danger">Upload failed: ${error.message}</div>`;
    }
}

function copyToClipboard(text) {
    copyText(text)
        .then(() => alert('URL copied to clipboard!'))
        .catch(() => alert('Could not copy URL. Please copy manually: ' + text));
}

// Page autocomplete for header search - Issue #90
function initHeaderAutocomplete() {
    if (typeof PageAutocomplete === 'undefined') {
        setTimeout(initHeaderAutocomplete, 100);
        return;
    }

    const headerSearchInput = document.getElementById('headerSearchInput');
    if (!headerSearchInput) {
        return;
    }

        // Initialize page autocomplete
        const autocomplete = new PageAutocomplete({
            minChars: 2,
            maxSuggestions: 10,
            onSelect: function(suggestion) {
                // Navigate directly to the selected page
                window.location.href = `/view/${encodeURIComponent(suggestion.name)}`;
            }
        });

        // Show autocomplete as user types
        headerSearchInput.addEventListener('input', function(e) {
            const query = headerSearchInput.value.trim();

            if (query.length >= 2) {
                autocomplete.search(query, headerSearchInput);
            } else {
                autocomplete.hideDropdown();
            }
        });

        // Handle keyboard navigation in autocomplete
        headerSearchInput.addEventListener('keydown', function(e) {
            if (autocomplete.handleKeydown(e)) {
                // Autocomplete handled the key, prevent default
                e.preventDefault();
            }
        });

        // Hide autocomplete when clicking outside
        document.addEventListener('click', function(e) {
            if (e.target !== headerSearchInput) {
                autocomplete.hideDropdown();
            }
        });
}

// Initialize after DOM is ready
if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHeaderAutocomplete);
} else {
    initHeaderAutocomplete();
}
</script>

