<%- include('header', { pageName: '' }) %>

<div class="container mt-4">
    <% if (typeof message !== 'undefined' && message) { %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> <%= message %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>

    <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle"></i> <%= error %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>

    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h1><i class="fas fa-external-link-alt"></i> InterWiki Management</h1>
                    <p class="lead">Manage InterWiki sites and link parsing options</p>
                </div>
                <a href="/admin" class="btn" style="background-color: var(--btn-secondary-bg); color: var(--btn-secondary-text); border-color: var(--btn-secondary-border);">
                    <i class="fas fa-arrow-left"></i> Back to Dashboard
                </a>
            </div>
        </div>
    </div>

    <div class="row mt-2">
        <div class="col-12">
            <nav>
                <div class="nav nav-tabs" id="nav-tab" role="tablist">
                    <button class="nav-link active" id="nav-sites-tab" data-bs-toggle="tab" data-bs-target="#nav-sites" type="button" role="tab">
                        <i class="fas fa-list"></i> Sites
                        <span class="badge bg-secondary ms-1"><%= Object.keys(sites).length %></span>
                    </button>
                    <button class="nav-link" id="nav-add-tab" data-bs-toggle="tab" data-bs-target="#nav-add" type="button" role="tab">
                        <i class="fas fa-plus"></i> Add Site
                    </button>
                    <button class="nav-link" id="nav-options-tab" data-bs-toggle="tab" data-bs-target="#nav-options" type="button" role="tab">
                        <i class="fas fa-cog"></i> Global Options
                    </button>
                </div>
            </nav>

            <div class="tab-content" id="nav-tabContent">

                <!-- Sites Tab -->
                <div class="tab-pane fade show active" id="nav-sites" role="tabpanel">
                    <div class="card mt-3">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <div>
                                <h5 class="mb-0"><i class="fas fa-external-link-alt"></i> Configured InterWiki Sites</h5>
                                <small class="text-muted">Changes require a server restart to take effect in the link parser.</small>
                            </div>
                            <% if (!enabled) { %>
                                <span class="badge bg-warning text-dark">
                                    <i class="fas fa-exclamation-triangle"></i> InterWiki globally disabled
                                </span>
                            <% } else { %>
                                <span class="badge bg-success">
                                    <i class="fas fa-check"></i> InterWiki enabled
                                </span>
                            <% } %>
                        </div>
                        <div class="card-body">
                            <% if (Object.keys(sites).length === 0) { %>
                                <div class="alert alert-info">
                                    <i class="fas fa-info-circle"></i> No InterWiki sites configured.
                                    Use the <strong>Add Site</strong> tab to add your first site.
                                </div>
                            <% } else { %>
                                <div class="table-responsive">
                                    <table class="table table-sm align-middle">
                                        <thead>
                                            <tr>
                                                <th style="width: 12%;">Name</th>
                                                <th style="width: 30%;">URL Pattern</th>
                                                <th style="width: 22%;">Description</th>
                                                <th style="width: 10%;">Icon</th>
                                                <th style="width: 7%;">Enabled</th>
                                                <th style="width: 7%;">New Window</th>
                                                <th style="width: 12%;">Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% Object.entries(sites).forEach(function([name, site]) { %>
                                            <tr id="row-<%= encodeURIComponent(name) %>">
                                                <td class="view-mode"><code><%= name %></code></td>
                                                <td class="view-mode"><code class="text-break" style="font-size: 0.8em;"><%= site.url %></code></td>
                                                <td class="view-mode"><%= site.description || '' %></td>
                                                <td class="view-mode"><%= site.icon || '' %></td>
                                                <td class="view-mode">
                                                    <% if (site.enabled !== false) { %>
                                                        <span class="badge bg-success">Yes</span>
                                                    <% } else { %>
                                                        <span class="badge bg-secondary">No</span>
                                                    <% } %>
                                                </td>
                                                <td class="view-mode">
                                                    <% if (site.openInNewWindow !== false) { %>
                                                        <span class="badge bg-info">Yes</span>
                                                    <% } else { %>
                                                        <span class="badge bg-secondary">No</span>
                                                    <% } %>
                                                </td>
                                                <td class="view-mode">
                                                    <button type="button" class="btn btn-sm btn-outline-primary me-1"
                                                        onclick="startEdit('<%= encodeURIComponent(name) %>')" title="Edit">
                                                        <i class="fas fa-edit"></i>
                                                    </button>
                                                    <form method="POST" action="/admin/interwiki/sites/<%= encodeURIComponent(name) %>/delete"
                                                        class="d-inline"
                                                        onsubmit="return confirm('Delete site \'<%= name %>\'? This cannot be undone.');">
                                                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                                            <i class="fas fa-trash"></i>
                                                        </button>
                                                    </form>
                                                </td>
                                                <td colspan="7" class="edit-mode p-0" style="display:none;">
                                                    <form method="POST" action="/admin/interwiki/sites" class="p-2 bg-light border-top">
                                                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                        <input type="hidden" name="originalName" value="<%= name %>">
                                                        <div class="row g-2 align-items-end">
                                                            <div class="col-md-2">
                                                                <label class="form-label form-label-sm mb-1">Name</label>
                                                                <input type="text" class="form-control form-control-sm" name="siteName" value="<%= name %>" required>
                                                            </div>
                                                            <div class="col-md-3">
                                                                <label class="form-label form-label-sm mb-1">URL <small class="text-muted">(%s = page)</small></label>
                                                                <input type="text" class="form-control form-control-sm" name="url" value="<%= site.url %>" required>
                                                            </div>
                                                            <div class="col-md-3">
                                                                <label class="form-label form-label-sm mb-1">Description</label>
                                                                <input type="text" class="form-control form-control-sm" name="description" value="<%= site.description || '' %>">
                                                            </div>
                                                            <div class="col-md-1">
                                                                <label class="form-label form-label-sm mb-1">Icon</label>
                                                                <input type="text" class="form-control form-control-sm" name="icon" value="<%= site.icon || '' %>">
                                                            </div>
                                                            <div class="col-md-1">
                                                                <div class="form-check mt-3">
                                                                    <input class="form-check-input" type="checkbox" name="enabled"
                                                                        id="edit-enabled-<%= encodeURIComponent(name) %>"
                                                                        <%= site.enabled !== false ? 'checked' : '' %>>
                                                                    <label class="form-check-label form-label-sm"
                                                                        for="edit-enabled-<%= encodeURIComponent(name) %>">Enabled</label>
                                                                </div>
                                                            </div>
                                                            <div class="col-md-1">
                                                                <div class="form-check mt-3">
                                                                    <input class="form-check-input" type="checkbox" name="openInNewWindow"
                                                                        id="edit-newtab-<%= encodeURIComponent(name) %>"
                                                                        <%= site.openInNewWindow !== false ? 'checked' : '' %>>
                                                                    <label class="form-check-label form-label-sm"
                                                                        for="edit-newtab-<%= encodeURIComponent(name) %>">New Window</label>
                                                                </div>
                                                            </div>
                                                            <div class="col-md-1 d-flex gap-1">
                                                                <button type="submit" class="btn btn-sm btn-primary" title="Save">
                                                                    <i class="fas fa-save"></i>
                                                                </button>
                                                                <button type="button" class="btn btn-sm btn-secondary"
                                                                    onclick="cancelEdit('<%= encodeURIComponent(name) %>')" title="Cancel">
                                                                    <i class="fas fa-times"></i>
                                                                </button>
                                                            </div>
                                                        </div>
                                                    </form>
                                                </td>
                                            </tr>
                                            <% }); %>
                                        </tbody>
                                    </table>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>

                <!-- Add Site Tab -->
                <div class="tab-pane fade" id="nav-add" role="tabpanel">
                    <div class="card mt-3">
                        <div class="card-header">
                            <h5 class="mb-0"><i class="fas fa-plus"></i> Add InterWiki Site</h5>
                            <small class="text-muted">Use <code>%s</code> in the URL as the page name placeholder.</small>
                        </div>
                        <div class="card-body">
                            <form method="POST" action="/admin/interwiki/sites">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <input type="hidden" name="originalName" value="">

                                <div class="row g-3">
                                    <div class="col-md-3">
                                        <label for="newSiteName" class="form-label">Site Name <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" id="newSiteName" name="siteName"
                                            placeholder="e.g. Wikipedia" required>
                                        <div class="form-text">Used in markup: <code>[SiteName:PageName]</code></div>
                                    </div>
                                    <div class="col-md-5">
                                        <label for="newUrl" class="form-label">URL Pattern <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" id="newUrl" name="url"
                                            placeholder="https://en.wikipedia.org/wiki/%s" required>
                                        <div class="form-text"><code>%s</code> is replaced with the page name.</div>
                                    </div>
                                    <div class="col-md-4">
                                        <label for="newDescription" class="form-label">Description</label>
                                        <input type="text" class="form-control" id="newDescription" name="description"
                                            placeholder="Optional human-readable description">
                                    </div>
                                    <div class="col-md-3">
                                        <label for="newIcon" class="form-label">Icon Filename</label>
                                        <input type="text" class="form-control" id="newIcon" name="icon"
                                            placeholder="e.g. wikipedia.png">
                                    </div>
                                    <div class="col-md-2">
                                        <div class="form-check mt-4">
                                            <input class="form-check-input" type="checkbox" name="enabled" id="newEnabled" checked>
                                            <label class="form-check-label" for="newEnabled">Enabled</label>
                                        </div>
                                    </div>
                                    <div class="col-md-2">
                                        <div class="form-check mt-4">
                                            <input class="form-check-input" type="checkbox" name="openInNewWindow" id="newOpenInNewWindow" checked>
                                            <label class="form-check-label" for="newOpenInNewWindow">Open in new window</label>
                                        </div>
                                    </div>
                                </div>

                                <div class="mt-3">
                                    <button type="submit" class="btn btn-primary">
                                        <i class="fas fa-plus"></i> Add Site
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- Global Options Tab -->
                <div class="tab-pane fade" id="nav-options" role="tabpanel">
                    <div class="card mt-3">
                        <div class="card-header">
                            <h5 class="mb-0"><i class="fas fa-cog"></i> Global InterWiki Options</h5>
                            <small class="text-muted">These settings apply to all InterWiki links unless overridden per-site.</small>
                        </div>
                        <div class="card-body">
                            <form method="POST" action="/admin/interwiki/options">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                                <div class="mb-3">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" role="switch"
                                            name="globalEnabled" id="globalEnabled" <%= enabled ? 'checked' : '' %>>
                                        <label class="form-check-label" for="globalEnabled">
                                            <strong>InterWiki links enabled</strong>
                                            <div class="form-text">When disabled, all InterWiki link syntax is rendered as plain text.</div>
                                        </label>
                                    </div>
                                </div>

                                <hr>

                                <div class="mb-3">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" role="switch"
                                            name="openInNewWindow" id="optOpenInNewWindow"
                                            <%= options.openInNewWindow !== false ? 'checked' : '' %>>
                                        <label class="form-check-label" for="optOpenInNewWindow">
                                            <strong>Open in new window (default)</strong>
                                            <div class="form-text">Default for all sites. Individual sites can override this.</div>
                                        </label>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" role="switch"
                                            name="addIconIndicator" id="optAddIconIndicator"
                                            <%= options.addIconIndicator !== false ? 'checked' : '' %>>
                                        <label class="form-check-label" for="optAddIconIndicator">
                                            <strong>Add icon indicator</strong>
                                            <div class="form-text">Show site icon next to InterWiki links (when an icon is configured).</div>
                                        </label>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" role="switch"
                                            name="caseSensitive" id="optCaseSensitive"
                                            <%= options.caseSensitive ? 'checked' : '' %>>
                                        <label class="form-check-label" for="optCaseSensitive">
                                            <strong>Case-sensitive site name matching</strong>
                                            <div class="form-text">When enabled, <code>Wikipedia:</code> and <code>wikipedia:</code> are treated as different sites.</div>
                                        </label>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" role="switch"
                                            name="showTooltips" id="optShowTooltips"
                                            <%= options.showTooltips !== false ? 'checked' : '' %>>
                                        <label class="form-check-label" for="optShowTooltips">
                                            <strong>Show tooltips</strong>
                                            <div class="form-text">Display site description as a tooltip on hover.</div>
                                        </label>
                                    </div>
                                </div>

                                <div class="alert alert-warning">
                                    <i class="fas fa-info-circle"></i>
                                    <strong>Note:</strong> A server restart is required for these changes to take effect in the link parser.
                                </div>

                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-save"></i> Save Options
                                </button>
                            </form>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<script>
function startEdit(encodedName) {
    var row = document.getElementById('row-' + encodedName);
    if (!row) return;
    row.querySelectorAll('.view-mode').forEach(function(el) { el.style.display = 'none'; });
    row.querySelectorAll('.edit-mode').forEach(function(el) { el.style.display = ''; });
}

function cancelEdit(encodedName) {
    var row = document.getElementById('row-' + encodedName);
    if (!row) return;
    row.querySelectorAll('.view-mode').forEach(function(el) { el.style.display = ''; });
    row.querySelectorAll('.edit-mode').forEach(function(el) { el.style.display = 'none'; });
}
</script>

<%- include('footer') %>
