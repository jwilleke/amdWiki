<%- include('header', { pageName: '' }) %>

<div class="search-page">
<h1 class="h2"><i class="fas fa-search"></i> Search</h1>

<!-- Search Tabs -->
<ul class="nav nav-tabs mb-3" id="searchTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link <%= (!searchTab || searchTab === 'pages') ? 'active' : '' %>" id="pages-tab" data-bs-toggle="tab"
                data-bs-target="#pages-search" type="button" role="tab">
            <i class="fas fa-file-alt me-1"></i>Pages
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link <%= searchTab === 'attachments' ? 'active' : '' %>" id="attachments-tab" data-bs-toggle="tab"
                data-bs-target="#attachments-search" type="button" role="tab">
            <i class="fas fa-paperclip me-1"></i>Attachments
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link <%= searchTab === 'media' ? 'active' : '' %>" id="media-tab" data-bs-toggle="tab"
                data-bs-target="#media-search" type="button" role="tab">
            <i class="fas fa-photo-video me-1"></i>Media
        </button>
    </li>
</ul>

<div class="tab-content" id="searchTabsContent">
    <!-- Pages Search Tab -->
    <div class="tab-pane fade <%= (!searchTab || searchTab === 'pages') ? 'show active' : '' %>" id="pages-search" role="tabpanel">
        <!-- Simplified Search Form -->
        <div class="card mb-4 shadow-sm">
            <div class="card-body" style="background-color: var(--card-bg);">
                <form id="advancedSearchForm" action="/search" method="GET">
                    <div class="row g-3">
                        <!-- Search Input -->
                        <div class="col-md-8">
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-search"></i></span>
                                <input type="text" class="form-control form-control-lg" id="query" name="q"
                                       value="<%= query %>" placeholder="Search pages...">
                                <button class="btn btn-primary" type="submit">Search</button>
                            </div>
                        </div>

                        <!-- Search In Dropdown -->
                        <div class="col-md-4">
                            <select class="form-select form-select-lg" name="searchIn" id="searchIn">
                                <option value="all" <%= (!searchIn || searchIn === 'all' || (Array.isArray(searchIn) && searchIn.includes('all'))) ? 'selected' : '' %>>All Fields</option>
                                <option value="title" <%= (searchIn === 'title' || (Array.isArray(searchIn) && searchIn.includes('title'))) ? 'selected' : '' %>>Titles Only</option>
                                <option value="content" <%= (searchIn === 'content' || (Array.isArray(searchIn) && searchIn.includes('content'))) ? 'selected' : '' %>>Content Only</option>
                            </select>
                        </div>
                    </div>

                    <!-- Collapsible Filters -->
                    <div class="mt-3">
                        <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="collapse"
                                data-bs-target="#filterOptions" aria-expanded="<%= (categories && categories.length > 0) || (userKeywords && userKeywords.length > 0) || (systemKeywords && systemKeywords.length > 0) ? 'true' : 'false' %>">
                            <i class="fas fa-filter me-1"></i>Filters
                            <% if ((categories && categories.length > 0) || (userKeywords && userKeywords.length > 0) || (systemKeywords && systemKeywords.length > 0)) { %>
                                <span class="badge bg-primary ms-1"><%= (categories?.length || 0) + (userKeywords?.length || 0) + (systemKeywords?.length || 0) %></span>
                            <% } %>
                        </button>
                    </div>

                    <div class="collapse <%= (categories && categories.length > 0) || (userKeywords && userKeywords.length > 0) || (systemKeywords && systemKeywords.length > 0) ? 'show' : '' %>" id="filterOptions">
                        <div class="row mt-3 g-3">
                            <!-- Categories -->
                            <div class="col-md-4">
                                <label class="form-label fw-bold"><i class="fas fa-folder me-1"></i>Categories</label>
                                <div class="border rounded p-2" style="max-height: 150px; overflow-y: auto;">
                                    <% availableCategories.forEach(cat => { %>
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox"
                                                   id="cat_<%= cat.replace(/[^a-zA-Z0-9]/g, '_') %>"
                                                   name="category" value="<%= cat %>"
                                                   <%= (Array.isArray(categories) ? categories.includes(cat) : category === cat) ? 'checked' : '' %>>
                                            <label class="form-check-label" for="cat_<%= cat.replace(/[^a-zA-Z0-9]/g, '_') %>"><%= cat %></label>
                                        </div>
                                    <% }); %>
                                </div>
                            </div>

                            <!-- System Keywords -->
                            <div class="col-md-4">
                                <label class="form-label fw-bold"><i class="fas fa-tag me-1"></i>System Keywords</label>
                                <div class="border rounded p-2" style="max-height: 150px; overflow-y: auto;">
                                    <% (typeof availableSystemKeywords !== 'undefined' ? availableSystemKeywords : []).forEach(kw => { %>
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox"
                                                   id="skw_<%= kw.replace(/[^a-zA-Z0-9]/g, '_') %>"
                                                   name="systemKeywords" value="<%= kw %>"
                                                   <%= (Array.isArray(systemKeywords) ? systemKeywords.includes(kw) : systemKeywords === kw) ? 'checked' : '' %>>
                                            <label class="form-check-label" for="skw_<%= kw.replace(/[^a-zA-Z0-9]/g, '_') %>"><%= kw %></label>
                                        </div>
                                    <% }); %>
                                </div>
                            </div>

                            <!-- User Keywords -->
                            <div class="col-md-4">
                                <label class="form-label fw-bold"><i class="fas fa-tags me-1"></i>Keywords</label>
                                <div class="border rounded p-2" style="max-height: 150px; overflow-y: auto;">
                                    <% availableKeywords.forEach(kw => {
                                        const kwLabel = typeof kw === 'object' ? kw.label : kw;
                                        const kwDesc = typeof kw === 'object' ? kw.description : '';
                                    %>
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox"
                                                   id="kw_<%= kwLabel.replace(/[^a-zA-Z0-9]/g, '_') %>"
                                                   name="keywords" value="<%= kwLabel %>"
                                                   <%= (Array.isArray(userKeywords) ? userKeywords.includes(kwLabel) : userKeywords === kwLabel) ? 'checked' : '' %>>
                                            <label class="form-check-label" for="kw_<%= kwLabel.replace(/[^a-zA-Z0-9]/g, '_') %>"
                                                   <% if (kwDesc) { %>title="<%= kwDesc %>"<% } %>>
                                                <%= kwLabel %><% if (kwDesc) { %> <small class="text-muted">- <%= kwDesc %></small><% } %>
                                            </label>
                                        </div>
                                    <% }); %>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <!-- Page Search Results -->
        <% if (submitted) { %>
            <%
              const pageStart = (currentPage - 1) * pageSize + 1;
              const pageEnd = (currentPage - 1) * pageSize + results.length;
            %>
            <div id="pages-results">

                <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
                    <div>
                        <span class="badge bg-info">
                            <%= totalCount %> result<%= totalCount === 1 ? '' : 's' %>
                            <% if (totalPages > 1) { %>&middot; showing <%= pageStart %>–<%= pageEnd %><% } %>
                        </span>
                        <% if (query) { %><span class="ms-2">for "<strong><%= query %></strong>"</span><% } %>
                        <% if (categories && categories.length > 0) { %>
                            <span class="ms-2">in <%- categories.map(c => `<span class="badge bg-primary">${c}</span>`).join(' ') %></span>
                        <% } %>
                        <% if (systemKeywords && systemKeywords.length > 0) { %>
                            <span class="ms-2">tagged <%- systemKeywords.map(k => `<span class="badge bg-secondary">${k}</span>`).join(' ') %></span>
                        <% } %>
                        <% if (userKeywords && userKeywords.length > 0) { %>
                            <span class="ms-2">with <%- userKeywords.map(k => `<span class="badge bg-info">${k}</span>`).join(' ') %></span>
                        <% } %>
                    </div>
                    <div id="pages-pagination-top"></div>
                </div>

                <% if (results.length > 0) { %>
                    <div class="list-group">
                        <% results.forEach(result => { %>
                            <a href="/view/<%= encodeURIComponent(result.name) %>" class="list-group-item list-group-item-action">
                                <div class="d-flex w-100 justify-content-between align-items-start">
                                    <div>
                                        <h6 class="mb-0"><i class="fas fa-file-alt me-2 text-primary"></i><%= result.title %></h6>
                                        <% if (result.metadata.category) { %>
                                            <small class="text-muted"><%= result.metadata.category %></small>
                                        <% } %>
                                    </div>
                                    <span class="badge bg-secondary"><%= result.score.toFixed(1) %></span>
                                </div>
                                <% if (result.snippet) { %>
                                    <p class="mb-1 mt-2 small"><%- result.snippet %></p>
                                <% } %>
                                <% if ((result.metadata.systemKeywords && result.metadata.systemKeywords.length > 0) || (result.metadata.userKeywords && result.metadata.userKeywords.length > 0)) { %>
                                    <div class="mt-1">
                                        <% const skws = Array.isArray(result.metadata.systemKeywords) ? result.metadata.systemKeywords : []; %>
                                        <% skws.slice(0, 3).forEach(kw => { %>
                                            <span class="badge bg-secondary me-1"><i class="fas fa-tag me-1"></i><%= kw %></span>
                                        <% }); %>
                                        <% if (skws.length > 3) { %><span class="badge bg-secondary">+<%= skws.length - 3 %></span><% } %>
                                        <% const kws = Array.isArray(result.metadata.userKeywords) ? result.metadata.userKeywords : []; %>
                                        <% kws.slice(0, 3).forEach(kw => { %>
                                            <span class="badge bg-info me-1"><%= kw %></span>
                                        <% }); %>
                                        <% if (kws.length > 3) { %><span class="badge bg-secondary">+<%= kws.length - 3 %></span><% } %>
                                    </div>
                                <% } %>
                            </a>
                        <% }); %>
                    </div>
                    <div id="pages-pagination-bottom" class="mt-3 d-flex justify-content-center"></div>
                <% } else { %>
                    <div class="alert alert-info">
                        <i class="fas fa-info-circle me-2"></i>No pages found matching your search.
                    </div>
                <% } %>
            </div>
        <% } else { %>
            <!-- Quick Browse -->
            <div class="row">
                <div class="col-md-4 mb-4">
                    <div class="card h-100">
                        <div class="card-header"><i class="fas fa-folder me-2"></i>Browse by Category</div>
                        <div class="card-body">
                            <div class="d-flex flex-wrap gap-2">
                                <% availableCategories.slice(0, 12).forEach(cat => { %>
                                    <a href="/search?category=<%= encodeURIComponent(cat) %>" class="btn btn-sm btn-outline-primary">
                                        <%= cat %>
                                    </a>
                                <% }); %>
                                <% if (availableCategories.length > 12) { %>
                                    <span class="btn btn-sm btn-outline-secondary disabled">+<%= availableCategories.length - 12 %> more</span>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 mb-4">
                    <div class="card h-100">
                        <div class="card-header"><i class="fas fa-tag me-2"></i>Browse by System Keyword</div>
                        <div class="card-body">
                            <div class="d-flex flex-wrap gap-2">
                                <% (typeof availableSystemKeywords !== 'undefined' ? availableSystemKeywords : []).slice(0, 12).forEach(kw => { %>
                                    <a href="/search?systemKeywords=<%= encodeURIComponent(kw) %>" class="btn btn-sm btn-outline-secondary">
                                        <%= kw %>
                                    </a>
                                <% }); %>
                                <% if ((typeof availableSystemKeywords !== 'undefined' ? availableSystemKeywords : []).length > 12) { %>
                                    <span class="btn btn-sm btn-outline-secondary disabled">+<%= availableSystemKeywords.length - 12 %> more</span>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 mb-4">
                    <div class="card h-100">
                        <div class="card-header"><i class="fas fa-tags me-2"></i>Browse by Keyword</div>
                        <div class="card-body">
                            <div class="d-flex flex-wrap gap-2">
                                <% availableKeywords.slice(0, 12).forEach(kw => {
                                    const kwLabel = typeof kw === 'object' ? kw.label : kw;
                                %>
                                    <a href="/search?keywords=<%= encodeURIComponent(kwLabel) %>" class="btn btn-sm btn-outline-info">
                                        <%= kwLabel %>
                                    </a>
                                <% }); %>
                                <% if (availableKeywords.length > 12) { %>
                                    <span class="btn btn-sm btn-outline-secondary disabled">+<%= availableKeywords.length - 12 %> more</span>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Search Tips -->
            <div class="card">
                <div class="card-header"><i class="fas fa-lightbulb me-2"></i>Search Tips</div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4">
                            <code>"exact phrase"</code> - Exact match
                        </div>
                        <div class="col-md-4">
                            <code>+required -excluded</code> - Include/exclude
                        </div>
                        <div class="col-md-4">
                            <code>word*</code> - Wildcard
                        </div>
                    </div>
                </div>
            </div>
        <% } %>
    </div>

    <!-- Attachments Search Tab -->
    <div class="tab-pane fade <%= searchTab === 'attachments' ? 'show active' : '' %>" id="attachments-search" role="tabpanel">
        <% if (typeof currentUser !== 'undefined' && currentUser && currentUser.roles &&
               (currentUser.roles.includes('admin') || currentUser.roles.includes('editor') || currentUser.roles.includes('contributor'))) { %>
            <%- include('_asset-picker', {
                assetPickerMode:       'page',
                assetPickerInsert:     false,
                assetPickerPageName:   undefined,
                assetPickerInitQuery:  attachmentQuery || '',
                assetPickerInitSource: 'attachment'
            }) %>
        <% } else { %>
            <div class="text-center py-4 text-muted">
                <i class="fas fa-lock fa-3x mb-3"></i>
                <p>Sign in as a contributor or editor to browse attachments.</p>
            </div>
        <% } %>
    </div>

    <!-- Media Search Tab -->
    <div class="tab-pane fade <%= searchTab === 'media' ? 'show active' : '' %>" id="media-search" role="tabpanel">
        <div class="card mb-4 shadow-sm">
            <div class="card-body" style="background-color: var(--card-bg);">
                <form id="mediaSearchForm" action="/search" method="GET">
                    <input type="hidden" name="tab" value="media">
                    <input type="hidden" name="mediaOffset" value="0">
                    <div class="row g-3">
                        <div class="col">
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-photo-video"></i></span>
                                <input type="text" class="form-control" id="mediaQuery" name="mediaQuery"
                                       value="<%= mediaQuery || '' %>" placeholder="Search by filename, caption, keyword, year…">
                            </div>
                        </div>
                        <div class="col-auto">
                            <button class="btn btn-primary" type="submit">
                                <i class="fas fa-search me-1"></i>Search
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <% if (searchTab === 'media' && mediaPage && mediaPage.results && mediaPage.results.length > 0) { %>
            <%
              const mediaTotalPages = Math.ceil(mediaPage.total / mediaPageSize);
              const mediaStart = mediaOffset + 1;
              const mediaEnd = mediaOffset + mediaPage.results.length;
              const mediaPrevUrl = mediaCurrentPage > 1
                ? '/search?tab=media&mediaQuery=' + encodeURIComponent(mediaQuery || '') + '&mediaPage=' + (mediaCurrentPage - 1)
                : '';
              const mediaNextUrl = mediaPage.hasMore
                ? '/search?tab=media&mediaQuery=' + encodeURIComponent(mediaQuery || '') + '&mediaPage=' + (mediaCurrentPage + 1)
                : '';
            %>
            <!-- data-pagination carries prev/next URLs for keyboard+swipe -->
            <div data-pagination
                 data-prev-url="<%= mediaPrevUrl %>"
                 data-next-url="<%= mediaNextUrl %>">

                <!-- Top count + pagination -->
                <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
                    <span class="badge bg-info">
                        <%= mediaPage.total.toLocaleString() %> result<%= mediaPage.total !== 1 ? 's' : '' %>
                        <% if (mediaPage.total > mediaPageSize) { %> &middot; showing <%= mediaStart %>–<%= mediaEnd %><% } %>
                    </span>
                    <% if (mediaTotalPages > 1) { %>
                    <nav aria-label="Media results pages">
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item <%= !mediaPrevUrl ? 'disabled' : '' %>">
                                <a class="page-link" href="<%= mediaPrevUrl || '#' %>" aria-label="Previous">
                                    <i class="fas fa-chevron-left"></i>
                                </a>
                            </li>
                            <li class="page-item disabled">
                                <span class="page-link">Page <%= mediaCurrentPage %> of <%= mediaTotalPages %></span>
                            </li>
                            <li class="page-item <%= !mediaNextUrl ? 'disabled' : '' %>">
                                <a class="page-link" href="<%= mediaNextUrl || '#' %>" aria-label="Next">
                                    <i class="fas fa-chevron-right"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                    <% } %>
                </div>

                <!-- Thumbnail grid -->
                <div id="media-results-grid" class="row g-2">
                    <% mediaPage.results.forEach(item => { %>
                        <div class="col-6 col-md-3 col-lg-2">
                            <%- include('_media-card', { item, linkUrl: item.url, imgHeight: 120 }) %>
                        </div>
                    <% }); %>
                </div>

                <!-- Bottom pagination (repeat for long pages) -->
                <% if (mediaTotalPages > 1) { %>
                <nav aria-label="Media results pages" class="mt-3 d-flex justify-content-center">
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item <%= !mediaPrevUrl ? 'disabled' : '' %>">
                            <a class="page-link" href="<%= mediaPrevUrl || '#' %>" aria-label="Previous">
                                <i class="fas fa-chevron-left"></i>
                            </a>
                        </li>
                        <li class="page-item disabled">
                            <span class="page-link">Page <%= mediaCurrentPage %> of <%= mediaTotalPages %></span>
                        </li>
                        <li class="page-item <%= !mediaNextUrl ? 'disabled' : '' %>">
                            <a class="page-link" href="<%= mediaNextUrl || '#' %>" aria-label="Next">
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
                <% } %>
            </div>

        <% } else if (searchTab === 'media' && mediaQuery) { %>
            <div class="alert alert-info">
                <i class="fas fa-info-circle me-2"></i>No media found matching your search.
            </div>
        <% } else if (searchTab === 'media') { %>
            <div class="text-center py-4 text-muted">
                <i class="fas fa-photo-video fa-3x mb-3"></i>
                <p>Search media by filename, caption, keyword, or year.</p>
            </div>
        <% } %>
    </div>
</div>

</div> <!-- Close search-page div -->

<script>
// Auto-submit on filter change
document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('advancedSearchForm');
    const checkboxes = form.querySelectorAll('input[type="checkbox"]');

    checkboxes.forEach(checkbox => {
        checkbox.addEventListener('change', function() {
            const hasQuery = document.getElementById('query').value.trim();
            const hasFilter = document.querySelector('input[name="category"]:checked, input[name="keywords"]:checked, input[name="systemKeywords"]:checked');
            if (hasQuery || hasFilter) {
                form.submit();
            }
        });
    });
});

// Page autocomplete
function initSearchPageAutocomplete() {
    if (typeof PageAutocomplete === 'undefined') {
        setTimeout(initSearchPageAutocomplete, 100);
        return;
    }

    const searchInput = document.getElementById('query');
    if (!searchInput) return;

    const autocomplete = new PageAutocomplete({
        minChars: 2,
        maxSuggestions: 10,
        onSelect: function(suggestion) {
            window.location.href = `/view/${encodeURIComponent(suggestion.name)}`;
        }
    });

    searchInput.addEventListener('input', function() {
        const query = searchInput.value.trim();
        if (query.length >= 2) {
            autocomplete.search(query, searchInput);
        } else {
            autocomplete.hideDropdown();
        }
    });

    searchInput.addEventListener('keydown', function(e) {
        if (autocomplete.handleKeydown(e)) {
            e.preventDefault();
        }
    });

    document.addEventListener('click', function(e) {
        if (e.target !== searchInput) {
            autocomplete.hideDropdown();
        }
    });
}

if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSearchPageAutocomplete);
} else {
    initSearchPageAutocomplete();
}

// Pages tab pagination — WikiPagination.renderNav + keyboard + swipe
(function () {
    var topNav = document.getElementById('pages-pagination-top');
    var botNav = document.getElementById('pages-pagination-bottom');
    if (!topNav && !botNav) return;

    var currentPage = <%= currentPage %>;
    var totalPages = <%= totalPages %>;

    function buildPageUrl(page) {
        var url = new URL(window.location.href);
        url.searchParams.set('page', page);
        return url.toString();
    }

    function navigate(page) { window.location.href = buildPageUrl(page); }

    WikiPagination.renderNav(topNav, currentPage, totalPages, navigate);
    WikiPagination.renderNav(botNav, currentPage, totalPages, navigate);

    WikiPagination.attachKeyboard(
        currentPage > 1 ? function () { navigate(currentPage - 1); } : null,
        currentPage < totalPages ? function () { navigate(currentPage + 1); } : null
    );
    WikiPagination.attachSwipe(document.body,
        currentPage > 1 ? function () { navigate(currentPage - 1); } : null,
        currentPage < totalPages ? function () { navigate(currentPage + 1); } : null
    );
})();

// Keyboard and swipe for media tab pagination (only when media tab is visible)
(function () {
    var tabParam = new URLSearchParams(window.location.search).get('tab');
    if (tabParam !== 'media') return;
    var paginationEl = document.querySelector('[data-pagination]');
    if (!paginationEl) return;
    WikiPagination.attachKeyboard(
        WikiPagination.urlNav('data-prev-url', '[data-pagination]'),
        WikiPagination.urlNav('data-next-url', '[data-pagination]')
    );
    WikiPagination.attachSwipe(document.body,
        WikiPagination.urlNav('data-prev-url', '[data-pagination]'),
        WikiPagination.urlNav('data-next-url', '[data-pagination]')
    );
})();
</script>

<%- include('_media-lightbox') %>
<%- include('footer') %>
