<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Slideshow</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        html, body {
            height: 100%;
            background: #111;
            color: #e8e6e3;
            font-family: Georgia, 'Times New Roman', serif;
            overflow: hidden;
        }

        /* ── slide stage ───────────────────────────────── */
        #ss-stage {
            position: fixed;
            inset: 0;
        }

        .ss-slide {
            position: absolute;
            inset: 0;
            display: flex;
            flex-direction: column;
            padding: clamp(2rem, 4vh, 3.5rem) clamp(2rem, 5vw, 6rem) 4.5rem;
            overflow: hidden;
            opacity: 0;
            transition: opacity 0.8s ease;
            text-decoration: none;
            color: inherit;
        }
        .ss-slide.active  { opacity: 1; }
        .ss-slide.exiting { opacity: 0; }

        /* ── title bar ──────────────────────────────────── */
        .ss-title {
            font-size: clamp(1.4rem, 3vw, 2.5rem);
            font-weight: 700;
            letter-spacing: -0.02em;
            line-height: 1.15;
            margin-bottom: 0.6rem;
            flex-shrink: 0;
            color: #fff;
            text-shadow: 0 1px 12px rgba(0,0,0,0.5);
        }

        .ss-divider {
            flex-shrink: 0;
            height: 1px;
            background: rgba(255,255,255,0.12);
            margin-bottom: 1.25rem;
        }

        /* ── reader pane ────────────────────────────────── */
        .ss-reader {
            flex: 1;
            overflow-y: auto;
            overflow-x: hidden;
            scrollbar-width: thin;
            scrollbar-color: rgba(255,255,255,0.18) transparent;
            padding-right: 0.75rem;
            /* fade-out bottom so text trails off gracefully */
            -webkit-mask-image: linear-gradient(to bottom, black 80%, transparent 100%);
            mask-image: linear-gradient(to bottom, black 80%, transparent 100%);
            font-size: clamp(0.95rem, 1.5vw, 1.15rem);
            line-height: 1.8;
            color: rgba(232,230,227,0.88);
            cursor: pointer;
        }

        /* ── reader content typography ──────────────────── */
        .ss-reader h1, .ss-reader h2, .ss-reader h3,
        .ss-reader h4, .ss-reader h5, .ss-reader h6 {
            color: #fff;
            font-weight: 600;
            line-height: 1.25;
            margin: 1.1em 0 0.45em;
        }
        .ss-reader h1 { font-size: 1.55em; }
        .ss-reader h2 { font-size: 1.3em; }
        .ss-reader h3 { font-size: 1.12em; }
        .ss-reader h4, .ss-reader h5, .ss-reader h6 { font-size: 1em; }
        .ss-reader p  { margin: 0 0 0.85em; }
        .ss-reader ul, .ss-reader ol { margin: 0 0 0.85em 1.6em; }
        .ss-reader li { margin-bottom: 0.3em; }
        .ss-reader a  { color: rgba(130,190,255,0.9); text-decoration: none; pointer-events: none; }
        .ss-reader blockquote {
            border-left: 3px solid rgba(255,255,255,0.25);
            margin: 0 0 0.85em;
            padding: 0.3em 0 0.3em 1em;
            color: rgba(232,230,227,0.6);
            font-style: italic;
        }
        .ss-reader code {
            background: rgba(255,255,255,0.1);
            padding: 0.15em 0.35em;
            border-radius: 3px;
            font-family: 'Menlo', 'Consolas', monospace;
            font-size: 0.88em;
        }
        .ss-reader pre {
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(255,255,255,0.1);
            padding: 0.8em 1em;
            border-radius: 6px;
            overflow-x: auto;
            margin: 0 0 0.85em;
        }
        .ss-reader pre code { background: none; padding: 0; }
        .ss-reader table {
            border-collapse: collapse;
            width: 100%;
            margin: 0 0 0.85em;
            font-size: 0.93em;
        }
        .ss-reader th, .ss-reader td {
            border: 1px solid rgba(255,255,255,0.14);
            padding: 0.4em 0.7em;
            text-align: left;
        }
        .ss-reader th { background: rgba(255,255,255,0.07); color: #fff; font-weight: 600; }
        .ss-reader img { max-width: 100%; height: auto; border-radius: 5px; margin: 0.5em 0; }
        .ss-reader hr { border: none; border-top: 1px solid rgba(255,255,255,0.12); margin: 1em 0; }
        /* hide Bootstrap alerts/badges noise in reader mode */
        .ss-reader .alert { background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.14); border-radius: 6px; padding: 0.6em 0.9em; margin: 0 0 0.85em; }
        .ss-reader .badge { display: none; }

        /* ── open-page hint ─────────────────────────────── */
        .ss-readmore {
            flex-shrink: 0;
            margin-top: 0.75rem;
            font-size: 0.78rem;
            font-family: system-ui, sans-serif;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.28);
            transition: color 0.2s;
        }
        .ss-slide:hover .ss-readmore { color: rgba(255,255,255,0.65); }

        /* ── progress bar ──────────────────────────────── */
        #ss-progress {
            position: fixed;
            top: 0; left: 0;
            height: 2px;
            background: rgba(255,255,255,0.55);
            width: 0%;
            z-index: 10;
        }

        /* ── HUD (counter + controls) ──────────────────── */
        #ss-hud {
            position: fixed;
            bottom: 0; left: 0; right: 0;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.75rem 1.5rem;
            background: linear-gradient(transparent, rgba(0,0,0,0.6));
            opacity: 0;
            transition: opacity 0.3s;
            z-index: 10;
        }
        body:hover #ss-hud, #ss-hud:focus-within { opacity: 1; }

        #ss-counter {
            font-family: system-ui, sans-serif;
            font-size: 0.8rem;
            color: rgba(255,255,255,0.45);
            letter-spacing: 0.08em;
        }

        .ss-controls { display: flex; gap: 0.4rem; align-items: center; }

        .ss-btn {
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.18);
            color: #fff;
            border-radius: 6px;
            padding: 0.3rem 0.6rem;
            font-size: 0.88rem;
            cursor: pointer;
            transition: background 0.15s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
        }
        .ss-btn:hover { background: rgba(255,255,255,0.22); color: #fff; }

        /* ── settings panel ────────────────────────────── */
        #ss-settings {
            position: fixed;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            background: rgba(18,18,18,0.97);
            border: 1px solid rgba(255,255,255,0.14);
            border-radius: 12px;
            padding: 1.5rem 2rem;
            z-index: 20;
            display: none;
            min-width: 280px;
            font-family: system-ui, sans-serif;
        }
        #ss-settings.open { display: block; }
        #ss-settings label { display: block; font-size: 0.85rem; color: rgba(255,255,255,0.55); margin-bottom: 0.25rem; margin-top: 0.75rem; }
        #ss-settings input[type=number] {
            width: 100%; padding: 0.4rem 0.6rem; border-radius: 6px;
            border: 1px solid rgba(255,255,255,0.18); background: rgba(255,255,255,0.07);
            color: #fff; font-size: 0.9rem;
        }
        #ss-settings .ss-settings-btns { display: flex; gap: 0.5rem; margin-top: 1.25rem; }
        #ss-settings .ss-settings-btns button { flex: 1; }
    </style>
</head>
<body>

<div id="ss-progress"></div>

<div id="ss-stage">
<% slides.forEach(function(slide, i) { %>
    <div class="ss-slide<% if (i === 0) { %> active<% } %>"
         data-index="<%= i %>" data-url="<%= slide.url %>">
        <div class="ss-title"><%= slide.title %></div>
        <div class="ss-divider"></div>
        <div class="ss-reader"><%- slide.html %></div>
        <div class="ss-readmore">
            <i class="fas fa-external-link-alt" style="font-size:0.75em;margin-right:0.35em;"></i>Open page
            &nbsp;·&nbsp; <kbd style="font-size:0.85em;opacity:0.6;">Space</kbd>
        </div>
    </div>
<% }); %>
</div>

<!-- HUD -->
<div id="ss-hud">
    <span id="ss-counter">1 / <%= slides.length %></span>
    <div class="ss-controls">
        <button class="ss-btn" id="ss-prev" title="Previous (←)"><i class="fas fa-chevron-left"></i></button>
        <button class="ss-btn" id="ss-pp"   title="Pause (P)"><i class="fas fa-pause" id="ss-pp-icon"></i></button>
        <button class="ss-btn" id="ss-next" title="Next (→)"><i class="fas fa-chevron-right"></i></button>
        <button class="ss-btn" id="ss-cfg"  title="Settings"><i class="fas fa-cog"></i></button>
        <button class="ss-btn" id="ss-fs"   title="Fullscreen (F)"><i class="fas fa-expand" id="ss-fs-icon"></i></button>
        <a class="ss-btn" href="/" title="Exit slideshow"><i class="fas fa-times"></i></a>
    </div>
</div>

<!-- Settings panel -->
<div id="ss-settings">
    <strong style="color:#fff;">Slideshow settings</strong>
    <label>Number of pages (1–50)</label>
    <input type="number" id="cfg-count" min="1" max="50" value="<%= count %>">
    <label>Seconds per slide</label>
    <input type="number" id="cfg-interval" min="1" max="120" value="<%= interval %>">
    <div class="ss-settings-btns">
        <button class="ss-btn" id="cfg-cancel">Cancel</button>
        <button class="ss-btn" id="cfg-apply" style="background:rgba(13,110,253,0.45);">Apply</button>
    </div>
</div>

<script>
(function () {
    var slideEls = document.querySelectorAll('.ss-slide');
    var total    = slideEls.length;
    var idx      = 0;
    var playing  = true;
    var timer    = null;
    var interval = <%- interval %> * 1000;
    var progEl   = document.getElementById('ss-progress');
    var counter  = document.getElementById('ss-counter');
    var ppIcon   = document.getElementById('ss-pp-icon');

    if (total === 0) return;

    function openCurrent() {
        var url = slideEls[idx].getAttribute('data-url');
        if (url) window.open(url, '_blank', 'noopener');
    }

    // ── navigation ───────────────────────────────────────
    function goTo(i, userTriggered) {
        slideEls[idx].classList.remove('active');
        // reset scroll on departing slide
        var oldReader = slideEls[idx].querySelector('.ss-reader');
        if (oldReader) oldReader.scrollTop = 0;
        idx = ((i % total) + total) % total;
        slideEls[idx].classList.add('active');
        counter.textContent = (idx + 1) + ' / ' + total;
        if (playing || userTriggered) startProgress();
    }

    // ── progress bar ─────────────────────────────────────
    function startProgress() {
        progEl.style.transition = 'none';
        progEl.style.width = '0%';
        void progEl.offsetWidth;
        if (!playing) { progEl.style.width = '0%'; return; }
        progEl.style.transition = 'width ' + (interval / 1000) + 's linear';
        progEl.style.width = '100%';
    }

    function scheduleNext() {
        clearTimeout(timer);
        if (playing) timer = setTimeout(function () { goTo(idx + 1); scheduleNext(); }, interval);
    }

    function pause() {
        playing = false;
        clearTimeout(timer);
        progEl.style.transition = 'none';
        progEl.style.width = '0%';
        ppIcon.className = 'fas fa-play';
    }

    function play() {
        playing = true;
        ppIcon.className = 'fas fa-pause';
        startProgress();
        scheduleNext();
    }

    // ── click on slide opens page ─────────────────────────
    slideEls.forEach(function (el) {
        el.addEventListener('click', function (e) {
            // Don't open if click was inside the scrollable reader (user may be scrolling)
            var reader = el.querySelector('.ss-reader');
            if (reader && reader.contains(e.target)) return;
            openCurrent();
        });
    });

    // ── controls ─────────────────────────────────────────
    document.getElementById('ss-prev').addEventListener('click', function (e) {
        e.stopPropagation();
        clearTimeout(timer);
        goTo(idx - 1, true);
        if (playing) scheduleNext();
    });
    document.getElementById('ss-next').addEventListener('click', function (e) {
        e.stopPropagation();
        clearTimeout(timer);
        goTo(idx + 1, true);
        if (playing) scheduleNext();
    });
    document.getElementById('ss-pp').addEventListener('click', function (e) {
        e.stopPropagation();
        if (playing) pause(); else play();
    });

    // ── fullscreen ────────────────────────────────────────
    var fsIcon = document.getElementById('ss-fs-icon');
    document.getElementById('ss-fs').addEventListener('click', function (e) {
        e.stopPropagation();
        if (!document.fullscreenElement) {
            void document.documentElement.requestFullscreen();
        } else {
            void document.exitFullscreen();
        }
    });
    document.addEventListener('fullscreenchange', function () {
        fsIcon.className = document.fullscreenElement ? 'fas fa-compress' : 'fas fa-expand';
    });

    // ── settings panel ────────────────────────────────────
    var panel = document.getElementById('ss-settings');
    document.getElementById('ss-cfg').addEventListener('click', function (e) {
        e.stopPropagation();
        panel.classList.toggle('open');
        if (panel.classList.contains('open')) pause();
    });
    document.getElementById('cfg-cancel').addEventListener('click', function () {
        panel.classList.remove('open');
        play();
    });
    document.getElementById('cfg-apply').addEventListener('click', function () {
        var c = Math.min(50, Math.max(1, parseInt(document.getElementById('cfg-count').value, 10) || 10));
        var s = Math.max(1, parseInt(document.getElementById('cfg-interval').value, 10) || 8);
        window.location.href = '/slideshow?count=' + c + '&interval=' + s;
    });

    // ── keyboard ──────────────────────────────────────────
    document.addEventListener('keydown', function (e) {
        if (panel.classList.contains('open')) return;
        if (e.key === 'ArrowLeft')                { document.getElementById('ss-prev').click(); }
        else if (e.key === 'ArrowRight')           { document.getElementById('ss-next').click(); }
        else if (e.key === ' ')                    { e.preventDefault(); openCurrent(); }
        else if (e.key === 'p' || e.key === 'P')  { document.getElementById('ss-pp').click(); }
        else if (e.key === 'f' || e.key === 'F')  { document.getElementById('ss-fs').click(); }
    });

    // ── start ─────────────────────────────────────────────
    startProgress();
    scheduleNext();
})();
</script>
</body>
</html>
