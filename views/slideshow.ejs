<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Slideshow</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        html, body {
            height: 100%;
            background: #0a0a0a;
            color: #fff;
            font-family: Georgia, 'Times New Roman', serif;
            overflow: hidden;
        }

        /* ── slide stage ───────────────────────────────── */
        #ss-stage {
            position: fixed;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .ss-slide {
            position: absolute;
            inset: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: clamp(2rem, 8vw, 8rem) clamp(2rem, 10vw, 14rem);
            text-align: center;
            opacity: 0;
            transition: opacity 0.8s ease;
            cursor: pointer;
            text-decoration: none;
            color: inherit;
        }
        .ss-slide.active  { opacity: 1; }
        .ss-slide.exiting { opacity: 0; }

        /* subtle radial glow behind active slide */
        .ss-slide::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse 70% 60% at 50% 50%,
                rgba(255,255,255,0.04) 0%, transparent 70%);
            pointer-events: none;
        }

        .ss-title {
            font-size: clamp(2rem, 5vw, 4.5rem);
            font-weight: 700;
            letter-spacing: -0.02em;
            line-height: 1.1;
            margin-bottom: 1.5rem;
            text-shadow: 0 2px 20px rgba(0,0,0,0.6);
        }

        .ss-excerpt {
            font-size: clamp(1rem, 2vw, 1.5rem);
            font-weight: 400;
            line-height: 1.7;
            color: rgba(255,255,255,0.72);
            max-width: 72ch;
            text-shadow: 0 1px 8px rgba(0,0,0,0.5);
        }

        .ss-readmore {
            margin-top: 2.5rem;
            font-size: 0.85rem;
            font-family: system-ui, sans-serif;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.35);
            transition: color 0.2s;
        }
        .ss-slide:hover .ss-readmore { color: rgba(255,255,255,0.75); }

        /* ── progress bar ──────────────────────────────── */
        #ss-progress {
            position: fixed;
            top: 0; left: 0;
            height: 2px;
            background: rgba(255,255,255,0.6);
            width: 0%;
            z-index: 10;
        }

        /* ── HUD (counter + controls) ──────────────────── */
        #ss-hud {
            position: fixed;
            bottom: 0; left: 0; right: 0;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1rem 1.5rem;
            background: linear-gradient(transparent, rgba(0,0,0,0.55));
            opacity: 0;
            transition: opacity 0.3s;
            z-index: 10;
        }
        body:hover #ss-hud, #ss-hud:focus-within { opacity: 1; }

        #ss-counter {
            font-family: system-ui, sans-serif;
            font-size: 0.8rem;
            color: rgba(255,255,255,0.5);
            letter-spacing: 0.08em;
        }

        .ss-controls { display: flex; gap: 0.5rem; align-items: center; }

        .ss-btn {
            background: rgba(255,255,255,0.12);
            border: 1px solid rgba(255,255,255,0.2);
            color: #fff;
            border-radius: 6px;
            padding: 0.35rem 0.65rem;
            font-size: 0.9rem;
            cursor: pointer;
            transition: background 0.15s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
        }
        .ss-btn:hover { background: rgba(255,255,255,0.25); color: #fff; }

        /* ── settings panel ────────────────────────────── */
        #ss-settings {
            position: fixed;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            background: rgba(20,20,20,0.96);
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 12px;
            padding: 1.5rem 2rem;
            z-index: 20;
            display: none;
            min-width: 280px;
            font-family: system-ui, sans-serif;
        }
        #ss-settings.open { display: block; }
        #ss-settings label { display: block; font-size: 0.85rem; color: rgba(255,255,255,0.6); margin-bottom: 0.25rem; margin-top: 0.75rem; }
        #ss-settings input[type=number] {
            width: 100%; padding: 0.4rem 0.6rem; border-radius: 6px;
            border: 1px solid rgba(255,255,255,0.2); background: rgba(255,255,255,0.08);
            color: #fff; font-size: 0.9rem;
        }
        #ss-settings .ss-settings-btns { display: flex; gap: 0.5rem; margin-top: 1.25rem; }
        #ss-settings .ss-settings-btns button { flex: 1; }
    </style>
</head>
<body>

<div id="ss-progress"></div>

<div id="ss-stage">
<% slides.forEach(function(slide, i) { %>
    <a href="<%= slide.url %>" target="_blank" rel="noopener"
       class="ss-slide<% if (i === 0) { %> active<% } %>"
       data-index="<%= i %>">
        <div class="ss-title"><%= slide.title %></div>
        <% if (slide.excerpt) { %>
        <div class="ss-excerpt"><%= slide.excerpt %></div>
        <% } %>
        <div class="ss-readmore"><i class="fas fa-external-link-alt" style="font-size:0.75em;margin-right:0.4em;"></i>Open page</div>
    </a>
<% }); %>
</div>

<!-- HUD -->
<div id="ss-hud">
    <span id="ss-counter">1 / <%= slides.length %></span>
    <div class="ss-controls">
        <button class="ss-btn" id="ss-prev" title="Previous (←)"><i class="fas fa-chevron-left"></i></button>
        <button class="ss-btn" id="ss-pp"   title="Pause (Space)"><i class="fas fa-pause" id="ss-pp-icon"></i></button>
        <button class="ss-btn" id="ss-next" title="Next (→)"><i class="fas fa-chevron-right"></i></button>
        <button class="ss-btn" id="ss-cfg"  title="Settings"><i class="fas fa-cog"></i></button>
        <button class="ss-btn" id="ss-fs"   title="Fullscreen (F)"><i class="fas fa-expand" id="ss-fs-icon"></i></button>
        <a class="ss-btn" href="/" title="Exit slideshow"><i class="fas fa-times"></i></a>
    </div>
</div>

<!-- Settings panel -->
<div id="ss-settings">
    <strong style="color:#fff;">Slideshow settings</strong>
    <label>Number of pages (1–50)</label>
    <input type="number" id="cfg-count" min="1" max="50" value="<%= count %>">
    <label>Seconds per slide</label>
    <input type="number" id="cfg-interval" min="1" max="120" value="<%= interval %>">
    <div class="ss-settings-btns">
        <button class="ss-btn" id="cfg-cancel">Cancel</button>
        <button class="ss-btn" id="cfg-apply" style="background:rgba(13,110,253,0.5);">Apply</button>
    </div>
</div>

<script>
(function () {
    var slides   = document.querySelectorAll('.ss-slide');
    var total    = slides.length;
    var idx      = 0;
    var playing  = true;
    var timer    = null;
    var interval = <%- interval %> * 1000;
    var progEl   = document.getElementById('ss-progress');
    var counter  = document.getElementById('ss-counter');
    var ppIcon   = document.getElementById('ss-pp-icon');

    if (total === 0) return;

    // ── navigation ───────────────────────────────────────
    function goTo(i, userTriggered) {
        slides[idx].classList.remove('active');
        idx = ((i % total) + total) % total;
        slides[idx].classList.add('active');
        counter.textContent = (idx + 1) + ' / ' + total;
        if (playing || userTriggered) startProgress();
    }

    // ── progress bar ─────────────────────────────────────
    function startProgress() {
        progEl.style.transition = 'none';
        progEl.style.width = '0%';
        void progEl.offsetWidth; // force reflow
        if (!playing) { progEl.style.width = '0%'; return; }
        progEl.style.transition = 'width ' + (interval / 1000) + 's linear';
        progEl.style.width = '100%';
    }

    function scheduleNext() {
        clearTimeout(timer);
        if (playing) timer = setTimeout(function () { goTo(idx + 1); scheduleNext(); }, interval);
    }

    function pause() {
        playing = false;
        clearTimeout(timer);
        progEl.style.transition = 'none';
        progEl.style.width = '0%';
        ppIcon.className = 'fas fa-play';
    }

    function play() {
        playing = true;
        ppIcon.className = 'fas fa-pause';
        startProgress();
        scheduleNext();
    }

    // ── controls ─────────────────────────────────────────
    document.getElementById('ss-prev').addEventListener('click', function () {
        clearTimeout(timer);
        goTo(idx - 1, true);
        if (playing) scheduleNext();
    });
    document.getElementById('ss-next').addEventListener('click', function () {
        clearTimeout(timer);
        goTo(idx + 1, true);
        if (playing) scheduleNext();
    });
    document.getElementById('ss-pp').addEventListener('click', function () {
        if (playing) pause(); else play();
    });

    // ── fullscreen ────────────────────────────────────────
    var fsIcon = document.getElementById('ss-fs-icon');
    document.getElementById('ss-fs').addEventListener('click', function () {
        if (!document.fullscreenElement) {
            void document.documentElement.requestFullscreen();
        } else {
            void document.exitFullscreen();
        }
    });
    document.addEventListener('fullscreenchange', function () {
        fsIcon.className = document.fullscreenElement ? 'fas fa-compress' : 'fas fa-expand';
    });

    // ── settings panel ────────────────────────────────────
    var panel = document.getElementById('ss-settings');
    document.getElementById('ss-cfg').addEventListener('click', function () {
        panel.classList.toggle('open');
        if (panel.classList.contains('open')) pause();
    });
    document.getElementById('cfg-cancel').addEventListener('click', function () {
        panel.classList.remove('open');
        play();
    });
    document.getElementById('cfg-apply').addEventListener('click', function () {
        var c = Math.min(50, Math.max(1, parseInt(document.getElementById('cfg-count').value, 10) || 10));
        var s = Math.max(1, parseInt(document.getElementById('cfg-interval').value, 10) || 8);
        window.location.href = '/slideshow?count=' + c + '&interval=' + s;
    });

    // ── keyboard ──────────────────────────────────────────
    document.addEventListener('keydown', function (e) {
        if (panel.classList.contains('open')) return;
        if (e.key === 'ArrowLeft')       { document.getElementById('ss-prev').click(); }
        else if (e.key === 'ArrowRight') { document.getElementById('ss-next').click(); }
        else if (e.key === ' ')          { document.getElementById('ss-pp').click(); e.preventDefault(); }
        else if (e.key === 'f' || e.key === 'F') { document.getElementById('ss-fs').click(); }
    });

    // ── start ─────────────────────────────────────────────
    startProgress();
    scheduleNext();
})();
</script>
</body>
</html>
