<%- include('header', { pageName: 'Media Search' }) %>

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1><i class="fas fa-search"></i> Media Search</h1>
                <a href="/media" class="btn btn-sm" style="background-color: var(--btn-secondary-bg); color: var(--btn-secondary-text); border-color: var(--btn-secondary-border);">
                    <i class="fas fa-arrow-left"></i> Browse
                </a>
            </div>

            <!-- Search form -->
            <form action="/media/search" method="GET" class="mb-4">
                <input type="hidden" name="sort" value="<%= sort %>">
                <input type="hidden" name="order" value="<%= order %>">
                <div class="input-group">
                    <input
                        type="text"
                        class="form-control form-control-lg"
                        name="q"
                        value="<%= query %>"
                        placeholder="Search by filename, event, year, title, description, keywords…"
                        autofocus
                    >
                    <button class="btn" type="submit" style="background-color: var(--btn-primary-bg); color: var(--btn-primary-text); border-color: var(--btn-primary-border);">
                        <i class="fas fa-search"></i> Search
                    </button>
                </div>
            </form>

            <% if (query) { %>
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <p class="text-muted mb-0">
                        <% if (items && items.length > 0) { %>
                            <%= items.length %> result<%= items.length !== 1 ? 's' : '' %> for <strong><%= query %></strong>
                        <% } else { %>
                            No results for <strong><%= query %></strong>
                        <% } %>
                    </p>
                    <% if (items && items.length > 0) { %>
                        <%
                          const sorts = [
                            { s: 'date',    o: 'asc',  label: 'Date ↑' },
                            { s: 'date',    o: 'desc', label: 'Date ↓' },
                            { s: 'caption', o: 'asc',  label: 'Caption A–Z' },
                            { s: 'caption', o: 'desc', label: 'Caption Z–A' }
                          ];
                        %>
                        <select class="form-select form-select-sm" style="width:auto;" aria-label="Sort" onchange="window.location.href=this.value">
                            <% sorts.forEach(function(opt) { %>
                                <option value="/media/search?q=<%= encodeURIComponent(query) %>&sort=<%= opt.s %>&order=<%= opt.o %>"
                                        <%= (sort === opt.s && order === opt.o) ? 'selected' : '' %>>
                                    <%= opt.label %>
                                </option>
                            <% }); %>
                        </select>
                    <% } %>
                </div>
            <% } %>

            <% if (items && items.length > 0) { %>
                <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-lg-5 g-2">
                    <% items.forEach(function(item) { %>
                        <div class="col">
                            <a href="/media/item/<%= item.id %>?sort=<%= sort %>&order=<%= order %>" class="text-decoration-none">
                                <div class="card h-100">
                                    <% if (item.mimeType && item.mimeType.startsWith('image/')) { %>
                                        <img
                                            src="/media/thumb/<%= item.id %>?size=300x300"
                                            class="card-img-top"
                                            alt="<%= item.filename %>"
                                            style="object-fit:contain; height:140px; background:#f8f9fa;"
                                            loading="lazy"
                                            onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
                                        >
                                        <div class="d-none align-items-center justify-content-center bg-light" style="height:140px;">
                                            <i class="fas fa-image fa-3x text-muted"></i>
                                        </div>
                                    <% } else { %>
                                        <div class="d-flex align-items-center justify-content-center bg-light" style="height:140px;">
                                            <i class="fas fa-film fa-3x text-muted"></i>
                                        </div>
                                    <% } %>
                                    <div class="card-body p-2">
                                        <small class="text-muted d-block text-truncate" title="<%= item.filename %>"><%= (item.metadata && item.metadata.caption) ? item.metadata.caption : item.filename %></small>
                                        <% if (item.year) { %><small class="text-muted"><%= item.year %></small><% } %>
                                    </div>
                                </div>
                            </a>
                        </div>
                    <% }); %>
                </div>
            <% } %>
        </div>
    </div>
</div>

<%- include('footer') %>
