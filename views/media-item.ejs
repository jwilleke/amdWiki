<%- include('header', { pageName: item.filename }) %>

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1><i class="fas <%= item.mimeType && item.mimeType.startsWith('video/') ? 'fa-film' : 'fa-image' %>"></i> <%= item.filename %></h1>
                <div>
                    <% if (item.year) { %>
                        <a href="/media/year/<%= item.year %>" class="btn btn-sm me-2" style="background-color: var(--btn-secondary-bg); color: var(--btn-secondary-text); border-color: var(--btn-secondary-border);">
                            <i class="fas fa-calendar-alt"></i> <%= item.year %>
                        </a>
                    <% } %>
                    <a href="/media" class="btn btn-sm" style="background-color: var(--btn-secondary-bg); color: var(--btn-secondary-text); border-color: var(--btn-secondary-border);">
                        <i class="fas fa-arrow-left"></i> Media
                    </a>
                </div>
            </div>

            <div class="row">
                <!-- Image / video preview -->
                <div class="col-md-8 mb-4">
                    <% if (item.mimeType && item.mimeType.startsWith('image/')) { %>
                        <img
                            src="/media/thumb/<%= item.id %>?size=800x600"
                            class="img-fluid rounded shadow"
                            alt="<%= item.filename %>"
                            style="max-width:100%;"
                        >
                    <% } else if (item.mimeType && item.mimeType.startsWith('video/')) { %>
                        <video
                            controls
                            preload="metadata"
                            style="max-width:100%; width:100%; border-radius:0.375rem; box-shadow:0 .5rem 1rem rgba(0,0,0,.15);"
                        >
                            <source src="/media/file/<%= item.id %>" type="<%= item.mimeType %>">
                            Your browser does not support the video tag.
                        </video>
                    <% } else { %>
                        <div class="d-flex align-items-center justify-content-center bg-light rounded" style="min-height:300px;">
                            <div class="text-center text-muted">
                                <i class="fas fa-file fa-5x mb-3"></i>
                                <p><%= item.filename %></p>
                                <a href="/media/file/<%= item.id %>" class="btn btn-sm btn-secondary">Download</a>
                            </div>
                        </div>
                    <% } %>
                    <% if (prevItem || nextItem) { %>
                    <% const kwSuffix = albumKeyword ? '?keyword=' + encodeURIComponent(albumKeyword) : ''; %>
                    <div class="d-flex justify-content-between mt-2">
                        <% if (prevItem) { %>
                            <a href="/media/item/<%= prevItem.id %><%= kwSuffix %>" class="btn btn-sm" style="background-color: var(--btn-secondary-bg); color: var(--btn-secondary-text); border-color: var(--btn-secondary-border);" title="<%= prevItem.filename %>">
                                &laquo; Prev
                            </a>
                        <% } else { %>
                            <span></span>
                        <% } %>
                        <% if (nextItem) { %>
                            <a href="/media/item/<%= nextItem.id %><%= kwSuffix %>" class="btn btn-sm" style="background-color: var(--btn-secondary-bg); color: var(--btn-secondary-text); border-color: var(--btn-secondary-border);" title="<%= nextItem.filename %>">
                                Next &raquo;
                            </a>
                        <% } %>
                    </div>
                    <% } %>
                </div>

                <!-- Metadata panel -->
                <div class="col-md-4">
                    <div class="card bg-dark text-white">
                        <div class="card-header bg-dark text-white border-secondary"><i class="fas fa-info-circle"></i> Details</div>
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item bg-dark text-white border-secondary d-flex justify-content-between">
                                <span class="text-white-50">Filename</span>
                                <span class="text-end" style="max-width:60%;overflow-wrap:break-word;"><%= item.filename %></span>
                            </li>
                            <% if (item.year) { %>
                            <li class="list-group-item bg-dark text-white border-secondary d-flex justify-content-between">
                                <span class="text-white-50">Year</span>
                                <a href="/media/year/<%= item.year %>" class="text-info"><%= item.year %></a>
                            </li>
                            <% } %>
                            <li class="list-group-item bg-dark text-white border-secondary d-flex justify-content-between">
                                <span class="text-white-50">Type</span>
                                <span><%= item.mimeType %></span>
                            </li>
                            <% if (item.metadata && item.metadata.make) { %>
                            <li class="list-group-item bg-dark text-white border-secondary d-flex justify-content-between">
                                <span class="text-white-50">Camera</span>
                                <span><%= item.metadata.make %><% if (item.metadata.model) { %> <%= item.metadata.model %><% } %></span>
                            </li>
                            <% } %>
                            <% if (item.metadata && item.metadata.title) { %>
                            <li class="list-group-item bg-dark text-white border-secondary d-flex justify-content-between">
                                <span class="text-white-50">Title</span>
                                <span><%= item.metadata.title %></span>
                            </li>
                            <% } %>
                            <% if (item.metadata && item.metadata.description) { %>
                            <li class="list-group-item bg-dark text-white border-secondary">
                                <span class="text-white-50 d-block">Description</span>
                                <span><%= item.metadata.description %></span>
                            </li>
                            <% } %>
                            <% if (item.metadata && item.metadata.keywords) { %>
                            <li class="list-group-item bg-dark text-white border-secondary">
                                <span class="text-white-50 d-block">Keywords</span>
                                <span>
                                    <% const kw = Array.isArray(item.metadata.keywords) ? item.metadata.keywords : [item.metadata.keywords]; %>
                                    <% kw.forEach(function(k, i) { var exists = keywordPageExists && keywordPageExists[k]; var href = exists ? '/wiki/' + encodeURIComponent(k) : '/edit/' + encodeURIComponent(k); %><a href="<%= href %>" class="<%= exists ? 'text-info' : 'redlink' %>"<% if (!exists) { %> title="Create page: <%= k %>"<% } %>><%= k %></a> <a href="/media/keyword/<%= encodeURIComponent(k) %>" class="text-white-50 ms-1" title="View media album for: <%= k %>"><i class="fas fa-images" style="font-size:0.85em;"></i></a><% if (i < kw.length - 1) { %>, <% } %><% }); %>
                                </span>
                            </li>
                            <% } %>
                            <% if (item.metadata && (item.metadata.gpsLatitude || item.metadata.gpsLongitude)) { %>
                            <% const lat = parseFloat(item.metadata.gpsLatitude); const lon = parseFloat(item.metadata.gpsLongitude); %>
                            <li class="list-group-item bg-dark text-white border-secondary d-flex justify-content-between">
                                <span class="text-white-50">GPS</span>
                                <span class="location-plugin"><a href="https://www.openstreetmap.org/?mlat=<%= lat %>&mlon=<%= lon %>#map=13/<%= lat %>/<%= lon %>" target="_blank" rel="noopener" class="location-link text-info" title="Open in OpenStreetMap"><i class="fas fa-map-marker-alt"></i> <%= lat.toFixed(4) %>, <%= lon.toFixed(4) %></a></span>
                            </li>
                            <% } %>
                            <% if (item.linkedPageName) { %>
                            <li class="list-group-item bg-dark text-white border-secondary d-flex justify-content-between">
                                <span class="text-white-50">Page</span>
                                <a href="/wiki/<%= item.linkedPageName %>" class="text-info"><%= item.linkedPageName %></a>
                            </li>
                            <% } %>
                        </ul>
                    </div>

                    <% if (item.dirPath) { %>
                    <div class="mt-3">
                        <small class="text-muted"><i class="fas fa-folder"></i> <%= item.dirPath %></small>
                    </div>
                    <% } %>

                    <!-- Media Information (collapsible) -->
                    <div class="mt-3">
                        <button class="btn btn-sm w-100 text-start"
                                style="background-color: var(--btn-secondary-bg); color: var(--btn-secondary-text); border-color: var(--btn-secondary-border);"
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#mediaInfoPanel"
                                aria-expanded="false">
                            <i class="fas fa-info-circle"></i> Media Information
                        </button>
                        <div class="collapse" id="mediaInfoPanel">
                            <div class="card bg-dark text-white border-secondary mt-1">
                                <ul class="list-group list-group-flush">
                                    <li class="list-group-item bg-dark text-white border-secondary">
                                        <span class="text-white-50 d-block" style="font-size:0.8em;">Item ID</span>
                                        <span class="font-monospace" style="font-size:0.85em; word-break:break-all;"><%= item.id %></span>
                                        <button class="btn btn-sm btn-outline-secondary ms-1 py-0 px-1" title="Copy ID" onclick="navigator.clipboard.writeText('<%= item.id %>')"><i class="fas fa-copy"></i></button>
                                    </li>
                                    <li class="list-group-item bg-dark text-white border-secondary">
                                        <span class="text-white-50 d-block" style="font-size:0.8em;">URL</span>
                                        <span class="font-monospace" style="font-size:0.85em;">/media/item/<%= item.id %></span>
                                        <button class="btn btn-sm btn-outline-secondary ms-1 py-0 px-1" title="Copy URL" onclick="navigator.clipboard.writeText(window.location.origin + '/media/item/<%= item.id %>')"><i class="fas fa-copy"></i></button>
                                    </li>
                                    <li class="list-group-item bg-dark text-white border-secondary">
                                        <span class="text-white-50 d-block" style="font-size:0.8em;">Plugin Syntax</span>
                                        <% const pluginKws = item.metadata && item.metadata.keywords ? (Array.isArray(item.metadata.keywords) ? item.metadata.keywords : [item.metadata.keywords]) : []; %>
                                        <% if (pluginKws.length > 0) { %>
                                            <% pluginKws.forEach(function(kw) { const q = String(kw).includes("'") ? '"' : "'"; const syn = "[{MediaPlugin format='list' keyword=" + q + kw + q + "}]"; %>
                                            <div class="d-flex align-items-center mb-1">
                                                <span class="font-monospace" style="font-size:0.85em;flex:1;word-break:break-all;"><%= syn %></span>
                                                <button class="btn btn-sm btn-outline-secondary ms-1 py-0 px-1 flex-shrink-0" title="Copy syntax" data-copy="<%= syn %>" onclick="navigator.clipboard.writeText(this.dataset.copy)"><i class="fas fa-copy"></i></button>
                                            </div>
                                            <% }); %>
                                        <% } else { %>
                                            <div class="d-flex align-items-center">
                                                <span class="font-monospace" style="font-size:0.85em;">[{MediaPlugin format='list' keyword='current'}]</span>
                                                <button class="btn btn-sm btn-outline-secondary ms-1 py-0 px-1" title="Copy syntax" onclick="navigator.clipboard.writeText(&quot;[{MediaPlugin format='list' keyword='current'}]&quot;)"><i class="fas fa-copy"></i></button>
                                            </div>
                                        <% } %>
                                    </li>
                                    <% if (item.filePath) { %>
                                    <li class="list-group-item bg-dark text-white border-secondary">
                                        <span class="text-white-50 d-block" style="font-size:0.8em;">File Path</span>
                                        <span class="font-monospace" style="font-size:0.75em; word-break:break-all;"><%= item.filePath %></span>
                                        <button class="btn btn-sm btn-outline-secondary ms-1 py-0 px-1" title="Copy path" data-copy="<%= item.filePath %>" onclick="navigator.clipboard.writeText(this.dataset.copy)"><i class="fas fa-copy"></i></button>
                                    </li>
                                    <% } %>
                                    <% if (item.metadata && item.metadata.imageWidth && item.metadata.imageHeight) { %>
                                    <li class="list-group-item bg-dark text-white border-secondary d-flex justify-content-between">
                                        <span class="text-white-50">Dimensions</span>
                                        <span><%= item.metadata.imageWidth %> × <%= item.metadata.imageHeight %></span>
                                    </li>
                                    <% } %>
                                    <% if (item.metadata && item.metadata.fileSize) { %>
                                    <li class="list-group-item bg-dark text-white border-secondary d-flex justify-content-between">
                                        <span class="text-white-50">File Size</span>
                                        <span><%= Math.round(Number(item.metadata.fileSize) / 1024) %> KB</span>
                                    </li>
                                    <% } %>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
window.amdwikiMediaItem = <%- JSON.stringify({
    id: item.id,
    filename: item.filename,
    filePath: item.filePath || null,
    mimeType: item.mimeType || null,
    keywords: (item.metadata && item.metadata.keywords) ? (Array.isArray(item.metadata.keywords) ? item.metadata.keywords : [item.metadata.keywords]) : [],
    imageWidth: (item.metadata && item.metadata.imageWidth) ? item.metadata.imageWidth : null,
    imageHeight: (item.metadata && item.metadata.imageHeight) ? item.metadata.imageHeight : null,
    fileSize: (item.metadata && item.metadata.fileSize) ? item.metadata.fileSize : null
}) %>;
</script>

<%- include('footer') %>
