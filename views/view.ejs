
<%- include('header', { pageName: pageName }) %>

<% if (typeof warningMessage !== 'undefined' && warningMessage) { %>
<div class="alert alert-warning alert-dismissible fade show mx-3 mt-3" role="alert">
    <i class="fas fa-exclamation-triangle me-2"></i><%= warningMessage %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
<% } %>

<!-- Page content -->
<article class="markdown-body mb-4" itemscope itemtype="https://schema.org/Article">
  <% if (metadata) { %>
    <% if (metadata.title) { %><meta itemprop="name" content="<%= metadata.title %>"><% } %>
    <% if (metadata.author) { %><meta itemprop="author" content="<%= metadata.author %>"><% } %>
    <% if (metadata.lastModified) { %><meta itemprop="dateModified" content="<%= metadata.lastModified %>"><% } %>
  <% } %>
  <%- content %>
</article>

<% if (metadata && (metadata['system-category'] || (metadata['user-keywords'] && metadata['user-keywords'].length) || (metadata['system-keywords'] && metadata['system-keywords'].length))) { %>
<!-- Microdata: keywords and category (screen-reader accessible, crawlable) — #149 -->
<div class="visually-hidden" aria-hidden="true">
  <% if (metadata['system-category']) { %>
    <span itemprop="keywords"<% if (keywordUris && keywordUris[metadata['system-category']]) { %> itemid="<%= keywordUris[metadata['system-category']] %>"<% } %>><%= metadata['system-category'] %></span>
  <% } %>
  <% if (metadata['system-keywords'] && metadata['system-keywords'].length) { %>
    <% metadata['system-keywords'].forEach(function(kw) { %>
      <span itemprop="keywords"<% if (keywordUris && keywordUris[kw]) { %> itemid="<%= keywordUris[kw] %>"<% } %>><%= kw %></span>
    <% }); %>
  <% } %>
  <% if (metadata['user-keywords'] && metadata['user-keywords'].length) { %>
    <% metadata['user-keywords'].forEach(function(kw) { %>
      <span itemprop="keywords"<% if (keywordUris && keywordUris[kw]) { %> itemid="<%= keywordUris[kw] %>"<% } %>><%= kw %></span>
    <% }); %>
  <% } %>
</div>
<% } %>

<% if (typeof sectionEditingEnabled !== 'undefined' && sectionEditingEnabled) { %>
<style>
.section-edit-link {
    opacity: 0;
    margin-left: 0.4em;
    font-size: 0.7em;
    vertical-align: middle;
    color: var(--link-color, #0d6efd);
    text-decoration: none;
    transition: opacity 0.15s;
}
.markdown-body h1:hover .section-edit-link,
.markdown-body h2:hover .section-edit-link,
.markdown-body h3:hover .section-edit-link,
.markdown-body h4:hover .section-edit-link,
.markdown-body h5:hover .section-edit-link,
.markdown-body h6:hover .section-edit-link { opacity: 1; }
</style>
<script>
document.addEventListener('DOMContentLoaded', function () {
    var body = document.querySelector('.markdown-body');
    if (!body) return;
    var headings = body.querySelectorAll('h1, h2, h3, h4, h5, h6');
    headings.forEach(function (h, i) {
        var a = document.createElement('a');
        a.href = '/edit/<%= encodeURIComponent(pageName) %>?section=' + i;
        a.className = 'section-edit-link';
        a.title = 'Edit this section';
        a.innerHTML = '<i class="fas fa-pencil-alt"></i>';
        h.appendChild(a);
    });
});
</script>
<% } %>

<!-- Page tags: auto-tags (ES systemKeywords) + user-keywords -->
<%
  var _autoTags = typeof autoTaggedKeywords !== 'undefined' ? autoTaggedKeywords : [];
  var _userKws  = (metadata && metadata['user-keywords']) ? metadata['user-keywords'] : [];
  var _hasAnyTag = _autoTags.length > 0 || _userKws.length > 0;
%>
<% if (_hasAnyTag) { %>
<div class="page-tags mb-3 px-1">
  <% if (_autoTags.length > 0) { %>
    <span class="text-muted small me-1" title="Auto-tagged system keywords"><i class="fas fa-tag"></i></span>
    <% _autoTags.forEach(function(kw) { %>
      <a href="/search?q=<%= encodeURIComponent(kw) %>" class="badge text-bg-secondary text-decoration-none me-1" title="Auto-tagged"><%= kw %></a>
    <% }); %>
  <% } %>
  <% if (_userKws.length > 0) { %>
    <% if (_autoTags.length > 0) { %><span class="text-muted small mx-1">|</span><% } %>
    <span class="text-muted small me-1" title="User keywords"><i class="fas fa-tags"></i></span>
    <% _userKws.forEach(function(kw) { %>
      <a href="/search?q=<%= encodeURIComponent(kw) %>" class="badge text-bg-info text-decoration-none me-1" title="User keyword"><%= kw %></a>
    <% }); %>
  <% } %>
</div>
<% } %>

<!-- Page tab section (Comments, Referring Pages, etc.) — Template:PageTabs (#551) -->
<% if (typeof tabSection !== 'undefined' && tabSection) { %>
<%- tabSection %>
<% } %>

<!-- More Information section (similar to JSPWiki) -->
<% if (referringPages && referringPages.length > 0) { %>
<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">
            <i class="fas fa-sitemap"></i> More Information
        </h5>
    </div>
    <div class="card-body">
        <p class="text-muted">There might be more information for this subject on one of the following:</p>
        <ul class="list-unstyled">
            <% referringPages.forEach(page => { %>
                <li class="mb-1">
                    <i class="fas fa-link"></i> 
                    <a href="/view/<%= page %>"><%= page %></a>
                </li>
            <% }); %>
        </ul>
    </div>
</div>
<% } %>

<script>
function deletePage(pageName) {
    if (confirm('Are you sure you want to delete this page?')) {
        fetch(`/delete/${encodeURIComponent(pageName)}`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Accept': 'application/json'
            }
        }).then(response => response.json())
        .then(data => {
            if (data.success) {
                window.location.href = data.redirect || '/';
            } else {
                alert('Error deleting page: ' + (data.error || 'Unknown error'));
            }
        }).catch(error => {
            alert('Error deleting page: ' + error.message);
        });
    }
}
</script>

<%- include('footer') %>
