<%
/*
 * _emoji-picker.ejs — Emoji shortcode picker modal body (Issue #512)
 *
 * No EJS locals required. Included inside #emojiPickerModal in edit.ejs.
 * Grid is populated lazily on shown.bs.modal by initEmojiPicker() in edit.ejs.
 */
%>
<ul class="nav nav-tabs mb-3" id="emojiCategoryTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" type="button" data-emoji-category="smileys">Smileys</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" type="button" data-emoji-category="gestures">Gestures</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" type="button" data-emoji-category="objects">Objects</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" type="button" data-emoji-category="nature">Nature</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" type="button" data-emoji-category="all">All</button>
    </li>
</ul>

<div id="emojiGrid" class="d-flex flex-wrap gap-1" style="max-height:320px;overflow-y:auto;">
    <!-- Populated by initEmojiPicker() on modal open -->
</div>

<p class="text-muted mt-2 mb-0 small">
    Click to insert shortcode at cursor &mdash; e.g. <code>:smile:</code> renders as 😄.
    You can also type <code>:ro</code> directly in the editor for inline autocomplete.
</p>
